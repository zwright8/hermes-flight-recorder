{
  "$id": "https://schemas.hermes-flight-recorder.dev/model_serving_probe_receipt.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "No-download serving-probe receipt for model registry entries.",
  "properties": {
    "candidate_id": {"minLength": 1, "type": "string"},
    "compatibility_report": {
      "additionalProperties": true,
      "properties": {
        "path": {"minLength": 1, "type": "string"},
        "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "size_bytes": {"minimum": 0, "type": "integer"}
      },
      "required": ["path", "sha256", "size_bytes"],
      "type": "object"
    },
    "download_policy": {"type": "object"},
    "entry_id": {"minLength": 1, "type": "string"},
    "execution": {"type": "object"},
    "generated_at": {"minLength": 1, "type": "string"},
    "model_id": {"minLength": 1, "type": "string"},
    "model_ref": {"minLength": 1, "type": "string"},
    "notes": {"items": {"type": "string"}, "type": "array"},
    "passed": {"type": "boolean"},
    "probe_mode": {"enum": ["metadata_only", "external_receipt"]},
    "probes": {"items": {"type": "object"}, "type": "array"},
    "readiness": {"enum": ["metadata_recorded", "external_receipt_recorded", "verified", "blocked"]},
    "receipt_path": {"minLength": 1, "type": "string"},
    "recommendation": {"enum": ["ready_for_external_serving_probe", "serving_verified", "block_serving_selection"]},
    "schema_version": {"const": "hfr.model_serving_probe_receipt.v1"},
    "serving_profile": {"type": "object"},
    "summary": {"type": "object"}
  },
  "required": [
    "schema_version",
    "receipt_path",
    "generated_at",
    "model_ref",
    "entry_id",
    "candidate_id",
    "model_id",
    "probe_mode",
    "passed",
    "readiness",
    "recommendation",
    "serving_profile",
    "download_policy",
    "execution",
    "probes",
    "summary"
  ],
  "title": "Hermes Flight Recorder Model Serving Probe Receipt",
  "type": "object"
}
