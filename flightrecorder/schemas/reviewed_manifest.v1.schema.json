{
  "$id": "https://schemas.hermes-flight-recorder.dev/reviewed_manifest.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Manifest for apply-review reviewed trainer handoffs.",
  "properties": {
    "artifact_fingerprints": {
      "additionalProperties": {
        "$ref": "#/$defs/fileFingerprint"
      },
      "type": "object"
    },
    "dpo_count": {
      "minimum": 0,
      "type": "integer"
    },
    "confidence_counts": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "properties": {
        "high": {
          "minimum": 0,
          "type": "integer"
        },
        "medium": {
          "minimum": 0,
          "type": "integer"
        },
        "low": {
          "minimum": 0,
          "type": "integer"
        },
        "unknown": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "dataset_version": {
      "pattern": "^hfrds-[0-9a-f]+$",
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "high_confidence_label_count": {
      "minimum": 0,
      "type": "integer"
    },
    "label_counts": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "type": "object"
    },
    "label_provenance": {
      "properties": {
        "schema_version": {
          "const": "hfr.rl.label_provenance.v1"
        }
      },
      "required": [
        "schema_version"
      ],
      "type": "object"
    },
    "labels_artifact": {
      "$ref": "#/$defs/fileFingerprint"
    },
    "labels_path": {
      "type": "string"
    },
    "max_pairs_per_family": {
      "minimum": 0,
      "type": "integer"
    },
    "medium_or_high_confidence_label_count": {
      "minimum": 0,
      "type": "integer"
    },
    "low_confidence_label_count": {
      "minimum": 0,
      "type": "integer"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "output_dir": {
      "type": "string"
    },
    "outputs": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "preference_count": {
      "minimum": 0,
      "type": "integer"
    },
    "reviewed_label_count": {
      "minimum": 0,
      "type": "integer"
    },
    "redaction_status": {
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "schema_version": {
          "const": "hfr.rl.redaction_status.v1"
        },
        "unredacted_secret_like_finding_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "schema_version",
        "passed",
        "unredacted_secret_like_finding_count"
      ],
      "type": "object"
    },
    "registry": {
      "properties": {
        "schema_version": {
          "const": "hfr.rl.dataset_registry.v1"
        },
        "mode_to_view": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "root_views": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "selection_key": {
          "pattern": "^hfrds-[0-9a-f]+$",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "selection_key",
        "root_views",
        "mode_to_view"
      ],
      "type": "object"
    },
    "reward_model_count": {
      "minimum": 0,
      "type": "integer"
    },
    "schema_version": {
      "const": "hfr.reviewed.manifest.v1"
    },
    "sft_count": {
      "minimum": 0,
      "type": "integer"
    },
    "source_review_artifacts": {
      "additionalProperties": {
        "$ref": "#/$defs/fileFingerprint"
      },
      "type": "object"
    },
    "source_review_export": {
      "type": "string"
    },
    "task_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "trainer_views": {
      "type": "object"
    },
    "unknown_confidence_label_count": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "dataset_version",
    "generated_at",
    "source_review_export",
    "labels_path",
    "output_dir",
    "max_pairs_per_family",
    "reviewed_label_count",
    "sft_count",
    "reward_model_count",
    "preference_count",
    "dpo_count",
    "label_counts",
    "confidence_counts",
    "high_confidence_label_count",
    "medium_or_high_confidence_label_count",
    "low_confidence_label_count",
    "unknown_confidence_label_count",
    "redaction_status",
    "label_provenance",
    "trainer_views",
    "registry",
    "task_families",
    "outputs",
    "source_review_artifacts",
    "labels_artifact",
    "artifact_fingerprints"
  ],
  "title": "Hermes Flight Recorder Reviewed Manifest",
  "type": "object",
  "$defs": {
    "fileFingerprint": {
      "additionalProperties": true,
      "properties": {
        "exists": {
          "const": true
        },
        "path": {
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "exists",
        "size_bytes",
        "sha256"
      ],
      "type": "object"
    }
  }
}
