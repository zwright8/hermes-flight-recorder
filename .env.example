# Hermes Flight Recorder requires no environment variables for installation,
# unit tests, the deterministic demo, or normal offline CLI use.
#
# Copy this file to .env only if an optional integration needs configuration:
#   cp .env.example .env
# The project does not automatically load .env files. Load a local copy with
# `set -a; source .env; set +a`, or export only the variables required by the
# command you are running. Never commit real credentials.

# Optional read-only Hermes observer collector settings.
HERMES_FLIGHT_RECORDER_OUTPUT_DIR=.hfr-events
HERMES_FLIGHT_RECORDER_MAX_FIELD_CHARS=12000

# Optional local source/runtime discovery for live smoke scripts.
# HERMES_AGENT_ROOT=../hermes-agent
# HFR_PNPM_BIN=/absolute/path/to/pnpm
# HFR_NODE_BIN_DIR=/absolute/path/to/node/bin

# Optional OpenAI-compatible evaluation endpoint credentials.
# Prefer a local mock endpoint; approval is required before using a networked
# endpoint or live data. Set the secret in your shell or secret manager.
# HERMES_EVAL_API_KEY=
# HERMES_LIVE_DATA_API_KEY=

# Optional read-only external verifier credentials. Uncomment only the provider
# being tested and inject values from a shell or secret manager. Provider
# resource identifiers and endpoint overrides are documented by the verifier
# examples in examples/external_verification/.
# GITHUB_TOKEN=
# GMAIL_ACCESS_TOKEN=
# SLACK_BOT_TOKEN=
# GOOGLE_CALENDAR_ACCESS_TOKEN=
# GOOGLE_DRIVE_ACCESS_TOKEN=
# KUBERNETES_BEARER_TOKEN=
# NOTION_TOKEN=
# LINEAR_API_KEY=
# JIRA_API_TOKEN=
# MICROSOFT_GRAPH_TOKEN=
# GITLAB_TOKEN=
# DISCORD_BOT_TOKEN=
# ZENDESK_API_TOKEN=
# PAGERDUTY_API_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1
