{
  "$id": "https://schemas.hermes-flight-recorder.dev/trainer_wrapper_dry_run.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Dry-run receipt from the reference external trainer wrapper consuming a trainer consumer plan.",
  "properties": {
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "inputs": {
      "$ref": "#/$defs/inputs"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "passed": {
      "type": "boolean"
    },
    "plan_path": {
      "minLength": 1,
      "type": "string"
    },
    "readiness": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "dry_run_ready",
        "block_dry_run"
      ]
    },
    "schema_version": {
      "const": "hfr.example_trainer_wrapper_dry_run.v1"
    },
    "validation": {
      "$ref": "#/$defs/validation"
    },
    "would_run": {
      "$ref": "#/$defs/wouldRun"
    },
    "wrapper": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "wrapper",
    "plan_path",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "validation",
    "would_run",
    "inputs",
    "metrics",
    "notes"
  ],
  "title": "Hermes Flight Recorder Trainer Wrapper Dry Run",
  "type": "object",
  "$defs": {
    "check": {
      "additionalProperties": true,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "scope": {
          "type": "object"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "actual",
        "expected",
        "scope",
        "summary"
      ],
      "type": "object"
    },
    "inputs": {
      "additionalProperties": true,
      "properties": {
        "external_code_files": {
          "items": {
            "$ref": "#/$defs/externalCodeFile"
          },
          "type": "array"
        },
        "trainer_inputs": {
          "items": {
            "$ref": "#/$defs/trainerInput"
          },
          "type": "array"
        }
      },
      "required": [
        "trainer_inputs",
        "external_code_files"
      ],
      "type": "object"
    },
    "externalCodeFile": {
      "additionalProperties": true,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "passed": {
                  "const": true
                }
              },
              "required": [
                "passed",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "passed": {
                  "const": false
                }
              },
              "required": [
                "passed"
              ],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "resolved_path": {
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "resolved_path",
        "sha256",
        "passed"
      ],
      "type": "object"
    },
    "trainerInput": {
      "additionalProperties": true,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "kind": {
                  "const": "file"
                },
                "expected_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "passed": {
                  "const": true
                }
              },
              "required": [
                "kind",
                "passed",
                "expected_sha256",
                "expected_size_bytes",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "kind": {
                  "const": "directory"
                },
                "expected_sha256": {
                  "pattern": "^[0-9a-f]{64}$",
                  "type": "string"
                },
                "passed": {
                  "const": true
                }
              },
              "required": [
                "kind",
                "passed",
                "expected_file_count",
                "expected_sha256",
                "expected_size_bytes",
                "file_count",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "passed": {
                  "const": false
                }
              },
              "required": [
                "passed"
              ],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "archive_path": {
          "type": "string"
        },
        "artifact_name": {
          "type": "string"
        },
        "expected_file_count": {
          "minimum": 0,
          "type": "integer"
        },
        "expected_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "expected_size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "file_count": {
          "minimum": 0,
          "type": "integer"
        },
        "kind": {
          "enum": [
            "file",
            "directory"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "resolved_path": {
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_name",
        "archive_path",
        "resolved_path",
        "kind",
        "sha256",
        "expected_sha256",
        "passed"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": true,
      "properties": {
        "command_arg_count": {
          "minimum": 0,
          "type": "integer"
        },
        "external_code_file_count": {
          "minimum": 0,
          "type": "integer"
        },
        "external_code_ready_count": {
          "minimum": 0,
          "type": "integer"
        },
        "trainer_input_count": {
          "minimum": 0,
          "type": "integer"
        },
        "trainer_input_ready_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "trainer_input_count",
        "trainer_input_ready_count",
        "external_code_file_count",
        "external_code_ready_count",
        "command_arg_count"
      ],
      "type": "object"
    },
    "validation": {
      "additionalProperties": true,
      "properties": {
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "strict": {
          "type": "boolean"
        },
        "target_count": {
          "minimum": 0,
          "type": "integer"
        },
        "warning_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "passed",
        "strict",
        "target_count",
        "error_count",
        "warning_count"
      ],
      "type": "object"
    },
    "wouldRun": {
      "additionalProperties": true,
      "properties": {
        "archive_root": {
          "type": "string"
        },
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "execution_cwd": {
          "type": "string"
        },
        "external_code_root": {
          "type": "string"
        },
        "mode": {
          "const": "dry_run"
        },
        "shell": {
          "type": "string"
        }
      },
      "required": [
        "mode",
        "execution_cwd",
        "archive_root",
        "external_code_root",
        "argv",
        "shell"
      ],
      "type": "object"
    }
  }
}
