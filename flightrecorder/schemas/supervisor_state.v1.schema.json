{
  "$id": "https://schemas.hermes-flight-recorder.dev/supervisor_state.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Local autonomous supervisor checkpoint state used to resume bounded layer-goal packets.",
  "properties": {
    "active_layer": {
      "enum": ["evidence", "harness", "data", "model", "training", "serving_demo", "eval", "governance"],
      "type": "string"
    },
    "blocked_packets": {
      "items": { "$ref": "#/$defs/packet" },
      "type": "array"
    },
    "completed_packets": {
      "items": { "$ref": "#/$defs/packet" },
      "type": "array"
    },
    "current_packet": {
      "minLength": 1,
      "type": "string"
    },
    "latest_artifacts": {
      "items": { "$ref": "#/$defs/artifact" },
      "type": "array"
    },
    "latest_verification": {
      "items": { "$ref": "#/$defs/verification" },
      "type": "array"
    },
    "next_packets": {
      "items": { "$ref": "#/$defs/packet" },
      "type": "array"
    },
    "privacy_guardrails": {
      "additionalProperties": true,
      "properties": {
        "public_repo": { "type": "boolean" },
        "local_state_untracked": { "type": "boolean" },
        "daily_email_suppressed": { "type": "boolean" },
        "private_fields_forbidden": {
          "items": { "type": "string" },
          "type": "array"
        }
      },
      "required": ["public_repo", "local_state_untracked", "daily_email_suppressed"],
      "type": "object"
    },
    "promotion_readiness": {
      "additionalProperties": false,
      "properties": {
        "data": { "$ref": "#/$defs/layer_status" },
        "evidence": { "$ref": "#/$defs/layer_status" },
        "eval": { "$ref": "#/$defs/layer_status" },
        "governance": { "$ref": "#/$defs/layer_status" },
        "harness": { "$ref": "#/$defs/layer_status" },
        "model": { "$ref": "#/$defs/layer_status" },
        "serving_demo": { "$ref": "#/$defs/layer_status" },
        "training": { "$ref": "#/$defs/layer_status" }
      },
      "required": ["evidence", "harness", "data", "model", "training", "serving_demo", "eval", "governance"],
      "type": "object"
    },
    "schema_version": {
      "const": "hfr.autonomy.supervisor_state.v1"
    },
    "updated_at": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "updated_at",
    "active_layer",
    "current_packet",
    "completed_packets",
    "blocked_packets",
    "next_packets",
    "latest_artifacts",
    "latest_verification",
    "promotion_readiness"
  ],
  "title": "Hermes Flight Recorder Supervisor State",
  "type": "object",
  "$defs": {
    "artifact": {
      "additionalProperties": true,
      "properties": {
        "description": { "minLength": 1, "type": "string" },
        "path": { "minLength": 1, "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "type": { "minLength": 1, "type": "string" }
      },
      "required": ["path"],
      "type": "object"
    },
    "layer_status": {
      "enum": ["not_started", "in_progress", "blocked", "ready", "complete"],
      "type": "string"
    },
    "packet": {
      "additionalProperties": true,
      "properties": {
        "id": { "minLength": 1, "type": "string" },
        "layer": {
          "enum": ["evidence", "harness", "data", "model", "training", "serving_demo", "eval", "governance"],
          "type": "string"
        },
        "reason": { "type": "string" },
        "status": {
          "enum": ["pending", "in_progress", "blocked", "complete"],
          "type": "string"
        },
        "title": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "layer", "title", "status"],
      "type": "object"
    },
    "verification": {
      "additionalProperties": true,
      "properties": {
        "command": { "minLength": 1, "type": "string" },
        "exit_code": { "minimum": 0, "type": "integer" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["command", "passed"],
      "type": "object"
    }
  }
}
