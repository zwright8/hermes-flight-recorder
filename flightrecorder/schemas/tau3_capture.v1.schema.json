{
  "$id": "https://schemas.hermes-flight-recorder.dev/tau3_capture.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Canonical observable Tau text-mode episode envelope used to create governed Flight Recorder training evidence.",
  "properties": {
    "schema_version": {"const": "hfr.tau3_capture.v1"},
    "trajectory_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "task_family": {"type": "string", "minLength": 1},
    "domain": {"enum": ["airline", "retail", "telecom"]},
    "split": {"enum": ["train", "development"]},
    "behavior": {"type": "string", "minLength": 1},
    "prompt": {"type": "string"},
    "prompt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "seed": {"type": "integer"},
    "generator_id": {"type": "string", "minLength": 1},
    "generator_revision": {"type": "string", "minLength": 1},
    "policy_revision": {"type": "string", "minLength": 1},
    "tool_schema_revision": {"type": "string", "minLength": 1},
    "starting_state_hash": {"type": "string", "minLength": 1},
    "tools": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "events": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "final_answer": {"type": "string"},
    "state_transition": {
      "type": "object",
      "additionalProperties": true,
      "required": ["before_hash", "after_hash", "changes", "executable"],
      "properties": {
        "before_hash": {"type": "string", "minLength": 1},
        "after_hash": {"type": "string", "minLength": 1},
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "kind", "before", "after"],
            "properties": {
              "path": {"type": "string", "minLength": 1},
              "kind": {"enum": ["added", "removed", "changed"]}
            }
          }
        },
        "executable": {"const": true}
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "required": ["success", "executable_label", "policy_violation", "harmful_mutation", "evidence_refs"],
      "properties": {
        "success": {"type": "boolean"},
        "executable_label": {"type": "string", "minLength": 1},
        "policy_violation": {"type": "boolean"},
        "harmful_mutation": {"type": "boolean"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reviewer", "verifier", "disposition", "reason"],
      "properties": {
        "reviewer": {"type": "string", "minLength": 1},
        "verifier": {"type": "string", "minLength": 1},
        "disposition": {"enum": ["admit", "reject"]},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  },
  "required": [
    "schema_version",
    "trajectory_id",
    "task_id",
    "task_family",
    "domain",
    "split",
    "behavior",
    "prompt",
    "prompt_hash",
    "seed",
    "generator_id",
    "generator_revision",
    "policy_revision",
    "tool_schema_revision",
    "starting_state_hash",
    "tools",
    "events",
    "state_transition",
    "outcome",
    "review"
  ],
  "title": "Tau-3 Capture",
  "type": "object"
}
