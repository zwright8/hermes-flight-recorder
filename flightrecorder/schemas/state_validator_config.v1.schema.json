{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.hermes-flight-recorder.dev/state_validator_config.v1.schema.json",
  "title": "Flight Recorder State Validator Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "hfr.state_validator_config.v1"
    },
    "validator": {
      "$ref": "#/$defs/validatorName"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validatorSpec"
      }
    }
  },
  "oneOf": [
    {
      "required": ["id", "validator"]
    },
    {
      "required": ["validators"]
    }
  ],
  "$defs": {
    "validatorName": {
      "enum": [
        "api_json_field",
        "calendar_event_created",
        "collection_count_changed",
        "collection_item_exists",
        "db_row_exists",
        "drive_file_created",
        "email_read",
        "email_sent",
        "file_created",
        "file_modified",
        "github_issue_closed",
        "github_issue_commented",
        "job_completed",
        "jira_issue_status",
        "k8s_resource_ready",
        "linear_issue_status",
        "notion_page_updated",
        "payment_status",
        "s3_object_exists",
        "slack_message_sent",
        "status_changed",
        "ticket_created",
        "webhook_delivered"
      ]
    },
    "traceConfig": {
      "oneOf": [
        {
          "const": false
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "id": {
              "type": "string"
            },
            "event_type": {
              "type": "string"
            },
            "tool_name": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "where": {
              "type": "object"
            }
          }
        }
      ]
    },
    "validatorSpec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "validator"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "validator": {
          "$ref": "#/$defs/validatorName"
        },
        "description": {
          "type": "string"
        },
        "state_path": {
          "type": "string"
        },
        "trace": {
          "$ref": "#/$defs/traceConfig"
        },
        "tool_name": {
          "type": "string"
        },
        "before_count": {
          "type": "integer",
          "minimum": 0
        },
        "after_count": {
          "type": "integer",
          "minimum": 0
        },
        "message_index": {
          "type": "integer",
          "minimum": 0
        },
        "thread_id": {
          "type": "string"
        },
        "ticket_id": {
          "type": "string"
        },
        "file_key": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "before_value": {},
        "after_value": {},
        "equals": {},
        "contains": {},
        "matches": {
          "type": "string"
        },
        "fields": {
          "type": "object"
        },
        "contains_fields": {
          "type": "object"
        },
        "matches_fields": {
          "type": "object"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "count_path": {
          "type": "string"
        }
      }
    }
  }
}
