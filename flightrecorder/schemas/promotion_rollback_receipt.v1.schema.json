{
  "$id": "https://schemas.hermes-flight-recorder.dev/promotion_rollback_receipt.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Promotion rollback receipt proving the rollback target is registered and matches the current champion before alias movement.",
  "properties": {
    "artifacts": {
      "additionalProperties": true,
      "properties": {
        "registry": {"type": "object"}
      },
      "required": ["registry"],
      "type": "object"
    },
    "available": {"type": "boolean"},
    "champion_id": {"type": "string"},
    "check_count": {"minimum": 0, "type": "integer"},
    "checks": {"items": {"type": "object"}, "type": "array"},
    "failed_check_count": {"minimum": 0, "type": "integer"},
    "metrics": {"type": "object"},
    "notes": {"items": {"type": "string"}, "type": "array"},
    "passed": {"type": "boolean"},
    "readiness": {"enum": ["ready", "blocked"], "type": "string"},
    "receipt_path": {"type": "string"},
    "recommendation": {"enum": ["use_rollback_target", "block_promotion"], "type": "string"},
    "registry": {
      "additionalProperties": true,
      "properties": {
        "aliases": {"type": "object"},
        "path": {"type": "string"},
        "sha256": {"type": ["string", "null"]}
      },
      "required": ["path", "sha256", "aliases"],
      "type": "object"
    },
    "rollback": {
      "additionalProperties": true,
      "properties": {
        "available": {"type": "boolean"},
        "champion_id": {"type": "string"},
        "id": {"type": "string"},
        "target_model_id": {"type": "string"}
      },
      "required": ["id", "target_model_id", "champion_id", "available"],
      "type": "object"
    },
    "rollback_id": {"type": "string"},
    "schema_version": {"const": "hfr.promotion_rollback_receipt.v1"},
    "target_model_id": {"type": "string"}
  },
  "required": [
    "schema_version",
    "receipt_path",
    "passed",
    "available",
    "readiness",
    "recommendation",
    "rollback_id",
    "target_model_id",
    "champion_id",
    "check_count",
    "failed_check_count",
    "checks",
    "rollback",
    "registry",
    "artifacts",
    "metrics",
    "notes"
  ],
  "title": "Hermes Flight Recorder Promotion Rollback Receipt",
  "type": "object"
}
