{
  "$id": "https://schemas.hermes-flight-recorder.dev/tau3_model_identity.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Content-addressed identity for a complete local model tree used by the Tau-3 study.",
  "properties": {
    "schema_version": {"const": "hfr.tau3_model_identity.v1"},
    "model_id": {"type": "string", "minLength": 1},
    "revision": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!(?:[Mm][Aa][Ii][Nn]|[Mm][Aa][Ss][Tt][Ee][Rr]|[Hh][Ee][Aa][Dd]|[Ll][Aa][Tt][Ee][Ss][Tt]|[Uu][Nn][Kk][Nn][Oo][Ww][Nn])$).+$"
    },
    "file_count": {"type": "integer", "minimum": 1},
    "total_size": {"type": "integer", "minimum": 1},
    "tree_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
          },
          "size": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  },
  "required": [
    "schema_version",
    "model_id",
    "revision",
    "file_count",
    "total_size",
    "tree_sha256",
    "files"
  ],
  "title": "Tau-3 Local Model Identity",
  "type": "object"
}
