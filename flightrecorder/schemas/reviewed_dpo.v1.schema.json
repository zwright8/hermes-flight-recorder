{
  "$id": "https://schemas.hermes-flight-recorder.dev/reviewed_dpo.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Trainer-ready DPO row derived from a human-reviewed preference pair.",
  "properties": {
    "chosen": {"type": "string"},
    "chosen_episode_id": {"minLength": 1, "type": "string"},
    "chosen_review_item_sha256": {"$ref": "#/$defs/sha256"},
    "chosen_reviewer_confidence": {"$ref": "#/$defs/confidence"},
    "preference_id": {"minLength": 1, "type": "string"},
    "prompt": {"type": "string"},
    "reason": {"minLength": 1, "type": "string"},
    "rejected": {"type": "string"},
    "rejected_episode_id": {"minLength": 1, "type": "string"},
    "rejected_review_item_sha256": {"$ref": "#/$defs/sha256"},
    "rejected_reviewer_confidence": {"$ref": "#/$defs/confidence"},
    "schema_version": {"const": "hfr.reviewed.dpo.v1"},
    "source_artifact": {"const": "reviewed_preferences.jsonl"},
    "task_contract_fingerprint": {"$ref": "#/$defs/sha256"},
    "task_family": {"minLength": 1, "type": "string"}
  },
  "required": ["schema_version", "preference_id", "task_contract_fingerprint", "task_family", "prompt", "chosen", "rejected", "chosen_episode_id", "rejected_episode_id", "chosen_review_item_sha256", "rejected_review_item_sha256", "chosen_reviewer_confidence", "rejected_reviewer_confidence", "reason", "source_artifact"],
  "title": "Hermes Flight Recorder Reviewed DPO Row",
  "type": "object",
  "$defs": {
    "confidence": {"enum": ["high", "medium", "low", "unknown"], "type": "string"},
    "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
  }
}
