{
  "$id": "https://schemas.hermes-flight-recorder.dev/training_plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Dry-run model training plan written before downloads, heavy ML imports, or GPU work.",
  "properties": {
    "blocked_reasons": {"items": {"type": "string"}, "type": "array"},
    "checks": {"items": {"type": "object"}, "type": "array"},
    "compatibility_report": {"type": "object"},
    "compute": {"type": "object"},
    "created_at": {"minLength": 1, "type": "string"},
    "dataset": {"type": "object"},
    "dry_run": {"const": true},
    "execution": {"type": "object"},
    "gpu_execution": {"const": false},
    "model": {"type": "object"},
    "no_weight_download": {"const": true},
    "notes": {"items": {"type": "string"}, "type": "array"},
    "output": {"type": "object"},
    "passed": {"const": true},
    "plan_path": {"minLength": 1, "type": "string"},
    "readiness": {"enum": ["ready", "blocked"]},
    "recommendation": {"enum": ["ready_for_dry_run_review", "block_training_plan"]},
    "schema_version": {"const": "hfr.training_plan.v1"},
    "trainer": {"type": "object"}
  },
  "required": [
    "schema_version",
    "plan_path",
    "created_at",
    "dry_run",
    "no_weight_download",
    "gpu_execution",
    "passed",
    "readiness",
    "recommendation",
    "model",
    "dataset",
    "trainer",
    "output",
    "compute",
    "execution",
    "checks",
    "blocked_reasons"
  ],
  "title": "Hermes Flight Recorder Training Plan",
  "type": "object"
}
