{
  "$id": "https://schemas.hermes-flight-recorder.dev/state_diff.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "comparison_complete": { "const": false }
        },
        "required": ["comparison_complete"]
      },
      "then": {
        "properties": {
          "change_count_exact": { "const": false },
          "comparison_truncated": { "const": true },
          "truncated": { "const": true }
        },
        "required": ["change_count_exact", "comparison_truncated", "truncation_reason"]
      }
    },
    {
      "if": {
        "properties": {
          "change_status": { "const": "changed" }
        },
        "required": ["change_status"]
      },
      "then": {
        "properties": {
          "changed": { "const": true },
          "change_count": { "minimum": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "change_status": { "const": "unchanged" }
        },
        "required": ["change_status"]
      },
      "then": {
        "properties": {
          "changed": { "const": false },
          "change_count": { "const": 0 },
          "comparison_complete": { "const": true }
        }
      }
    },
    {
      "if": {
        "properties": {
          "change_status": { "const": "unknown" }
        },
        "required": ["change_status"]
      },
      "then": {
        "properties": {
          "changed": { "const": false },
          "change_count": { "const": 0 },
          "comparison_complete": { "const": false }
        }
      }
    }
  ],
  "description": "Deterministic before/after state diff emitted as state_diff.json when a run has both pre-run and post-run state snapshots.",
  "properties": {
    "changed": {
      "type": "boolean"
    },
    "change_count": {
      "minimum": 0,
      "type": "integer"
    },
    "changes": {
      "items": {
        "$ref": "#/$defs/change"
      },
      "type": "array"
    },
    "change_status": {
      "enum": [
        "changed",
        "unchanged",
        "unknown"
      ]
    },
    "comparison_complete": {
      "type": "boolean"
    },
    "comparison_truncated": {
      "type": "boolean"
    },
    "change_count_exact": {
      "type": "boolean"
    },
    "max_changes": {
      "minimum": 0,
      "type": "integer"
    },
    "schema_version": {
      "const": "hfr.state_diff.v1"
    },
    "summary": {
      "type": "string"
    },
    "truncated": {
      "type": "boolean"
    },
    "truncation_reason": {
      "enum": [
        "incomplete_snapshot",
        "max_changes",
        "max_depth",
        "max_nodes"
      ]
    }
  },
  "required": [
    "schema_version",
    "changed",
    "change_count",
    "truncated",
    "comparison_complete",
    "change_status",
    "max_changes",
    "changes",
    "summary"
  ],
  "title": "Hermes Flight Recorder State Diff",
  "type": "object",
  "$defs": {
    "change": {
      "additionalProperties": true,
      "properties": {
        "after": true,
        "before": true,
        "kind": {
          "enum": [
            "added",
            "removed",
            "changed"
          ]
        },
        "path": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "path",
        "kind",
        "before",
        "after"
      ],
      "type": "object"
    }
  }
}
