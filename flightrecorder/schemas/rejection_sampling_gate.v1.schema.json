{
  "$id": "https://schemas.hermes-flight-recorder.dev/rejection_sampling_gate.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "artifactRef": {
      "additionalProperties": false,
      "properties": {
        "exists": { "type": "boolean" },
        "kind": { "enum": ["file", "directory"] },
        "passed": { "type": ["boolean", "null"] },
        "path": { "minLength": 1, "type": "string" },
        "readiness": { "type": "string" },
        "role": { "minLength": 1, "type": "string" },
        "schema_version": { "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": ["string", "null"] },
        "size_bytes": { "minimum": 0, "type": ["integer", "null"] }
      },
      "required": ["role", "path", "kind", "exists", "sha256", "size_bytes", "schema_version", "passed", "readiness"],
      "type": "object"
    },
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": {},
        "expected": { "type": "object" },
        "id": { "minLength": 1, "type": "string" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "rolloutRef": {
      "additionalProperties": false,
      "properties": {
        "dataset_rows_written": { "type": "boolean" },
        "exists": { "type": "boolean" },
        "kind": { "enum": ["file", "directory"] },
        "live_rollouts_started": { "type": "boolean" },
        "mock_receipt_only": { "type": "boolean" },
        "mock_rollout_count": { "minimum": 0, "type": "integer" },
        "passed": { "type": ["boolean", "null"] },
        "path": { "minLength": 1, "type": "string" },
        "readiness": { "type": "string" },
        "role": { "const": "agentic_rollout_receipt" },
        "schema_version": { "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": ["string", "null"] },
        "size_bytes": { "minimum": 0, "type": ["integer", "null"] }
      },
      "required": [
        "role",
        "path",
        "kind",
        "exists",
        "sha256",
        "size_bytes",
        "schema_version",
        "passed",
        "readiness",
        "mock_rollout_count",
        "mock_receipt_only",
        "live_rollouts_started",
        "dataset_rows_written"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Fail-closed admission gate for rejection sampling before dataset curation.",
  "properties": {
    "admission_policy": {
      "additionalProperties": false,
      "properties": {
        "accepted_dataset_roles": { "items": { "type": "string" }, "type": "array" },
        "accepts_uncalibrated_labels": { "const": false },
        "requires_calibrated_review": { "const": true },
        "requires_mock_rollout_receipt": { "const": true },
        "requires_model_grader_gate": { "const": true },
        "requires_reviewed_gate": { "const": true }
      },
      "required": [
        "requires_mock_rollout_receipt",
        "requires_calibrated_review",
        "requires_model_grader_gate",
        "requires_reviewed_gate",
        "accepts_uncalibrated_labels",
        "accepted_dataset_roles"
      ],
      "type": "object"
    },
    "blocked_reasons": { "items": { "type": "string" }, "type": "array" },
    "check_count": { "minimum": 0, "type": "integer" },
    "checks": { "items": { "$ref": "#/$defs/check" }, "type": "array" },
    "created_at": { "type": "string" },
    "execution_boundary": {
      "additionalProperties": false,
      "properties": {
        "dataset_rows_written": { "const": false },
        "gate_only": { "const": true },
        "model_provider_calls_started": { "const": false },
        "paid_model_grader_calls_started": { "const": false },
        "weights_updated_by_flight_recorder": { "const": false }
      },
      "required": [
        "gate_only",
        "dataset_rows_written",
        "model_provider_calls_started",
        "paid_model_grader_calls_started",
        "weights_updated_by_flight_recorder"
      ],
      "type": "object"
    },
    "failed_check_count": { "minimum": 0, "type": "integer" },
    "gate_path": { "type": "string" },
    "input_artifacts": {
      "additionalProperties": false,
      "properties": {
        "agentic_rollout_receipt": { "items": { "$ref": "#/$defs/rolloutRef" }, "type": "array" },
        "model_grader_gate": { "items": { "$ref": "#/$defs/artifactRef" }, "type": "array" },
        "review_calibration": { "items": { "$ref": "#/$defs/artifactRef" }, "type": "array" },
        "reviewed_gate": { "items": { "$ref": "#/$defs/artifactRef" }, "type": "array" }
      },
      "required": ["agentic_rollout_receipt", "model_grader_gate", "review_calibration", "reviewed_gate"],
      "type": "object"
    },
    "notes": { "items": { "type": "string" }, "type": "array" },
    "passed": { "type": "boolean" },
    "readiness": { "enum": ["ready_for_dataset_curation", "blocked"] },
    "recommendation": { "enum": ["curate_accepted_training_rows", "collect_calibrated_reviews_before_sampling"] },
    "rollout_summary": {
      "additionalProperties": false,
      "properties": {
        "dataset_rows_created": { "const": false },
        "live_rollouts_started": { "const": false },
        "mock_rollout_count": { "minimum": 0, "type": "integer" },
        "receipt_count": { "minimum": 0, "type": "integer" }
      },
      "required": ["receipt_count", "mock_rollout_count", "live_rollouts_started", "dataset_rows_created"],
      "type": "object"
    },
    "schema_version": { "const": "hfr.rejection_sampling_gate.v1" }
  },
  "required": [
    "schema_version",
    "created_at",
    "gate_path",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "input_artifacts",
    "rollout_summary",
    "admission_policy",
    "execution_boundary",
    "notes"
  ],
  "title": "Hermes Flight Recorder Rejection Sampling Gate",
  "type": "object"
}
