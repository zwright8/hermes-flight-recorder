{
  "$id": "https://schemas.hermes-flight-recorder.dev/model_compatibility_report.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "No-download compatibility report derived from model candidate metadata.",
  "properties": {
    "candidate_id": {"minLength": 1, "type": "string"},
    "download_policy": {"type": "object"},
    "generated_at": {"minLength": 1, "type": "string"},
    "model_id": {"minLength": 1, "type": "string"},
    "notes": {"items": {"type": "string"}, "type": "array"},
    "passed": {"type": "boolean"},
    "probes": {"items": {"type": "object"}, "type": "array"},
    "readiness": {"enum": ["metadata_recorded", "verified", "blocked"]},
    "recommendation": {"enum": ["ready_for_registry_dry_run", "block_training_selection"]},
    "report_path": {"minLength": 1, "type": "string"},
    "schema_version": {"const": "hfr.model_compatibility_report.v1"},
    "summary": {"type": "object"}
  },
  "required": [
    "schema_version",
    "report_path",
    "generated_at",
    "candidate_id",
    "model_id",
    "passed",
    "readiness",
    "recommendation",
    "download_policy",
    "probes",
    "summary"
  ],
  "title": "Hermes Flight Recorder Model Compatibility Report",
  "type": "object"
}
