{
  "$id": "https://schemas.hermes-flight-recorder.dev/model_grader_disagreement_queue.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Portable human-review queue derived from a model-grader dry-run receipt.",
  "properties": {
    "blocked_reasons": {
      "items": { "type": "string" },
      "type": "array"
    },
    "check_count": { "minimum": 0, "type": "integer" },
    "checks": {
      "items": { "$ref": "#/$defs/check" },
      "type": "array"
    },
    "created_at": { "minLength": 1, "type": "string" },
    "execution_boundary": { "$ref": "#/$defs/boundary" },
    "failed_check_count": { "minimum": 0, "type": "integer" },
    "notes": {
      "items": { "type": "string" },
      "type": "array"
    },
    "override_requirements": { "$ref": "#/$defs/overrideRequirements" },
    "passed": { "type": "boolean" },
    "queue": {
      "items": { "$ref": "#/$defs/queueItem" },
      "type": "array"
    },
    "queue_count": { "minimum": 0, "type": "integer" },
    "readiness": {
      "enum": ["ready_for_human_review", "queue_empty", "blocked"],
      "type": "string"
    },
    "recommendation": {
      "enum": ["collect_human_overrides", "no_human_override_required", "fix_dry_run_receipt"],
      "type": "string"
    },
    "required_review_item_ids": {
      "items": { "type": "string" },
      "type": "array"
    },
    "schema_version": { "const": "hfr.model_grader_disagreement_queue.v1" },
    "source_artifacts": {
      "additionalProperties": false,
      "properties": {
        "dry_run_receipt": { "$ref": "#/$defs/sourceArtifact" }
      },
      "required": ["dry_run_receipt"],
      "type": "object"
    },
    "training_admission": { "$ref": "#/$defs/trainingAdmission" }
  },
  "required": [
    "schema_version",
    "created_at",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "source_artifacts",
    "queue_count",
    "required_review_item_ids",
    "queue",
    "override_requirements",
    "training_admission",
    "execution_boundary",
    "notes"
  ],
  "title": "Hermes Flight Recorder Model Grader Disagreement Queue",
  "type": "object",
  "$defs": {
    "boundary": {
      "additionalProperties": false,
      "properties": {
        "cloud_cost_incurred_usd": { "const": 0 },
        "credential_values_recorded": { "const": false },
        "dry_run_only": { "const": true },
        "labels_admitted_to_training": { "const": false },
        "paid_model_grader_calls_started": { "const": false },
        "provider_api_called": { "const": false },
        "weights_updated_by_flight_recorder": { "const": false }
      },
      "required": [
        "dry_run_only",
        "provider_api_called",
        "paid_model_grader_calls_started",
        "cloud_cost_incurred_usd",
        "credential_values_recorded",
        "labels_admitted_to_training",
        "weights_updated_by_flight_recorder"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "type": "object" },
        "expected": { "type": "object" },
        "id": { "minLength": 1, "type": "string" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "overrideRequirements": {
      "additionalProperties": false,
      "properties": {
        "final_label_options": {
          "items": { "enum": ["accept", "reject", "unsafe", "incomplete"], "type": "string" },
          "type": "array"
        },
        "minimum_reviewer_confidence": { "const": "medium" },
        "required_before_training_admission": { "const": true },
        "required_override_count": { "minimum": 0, "type": "integer" }
      },
      "required": [
        "required_before_training_admission",
        "required_override_count",
        "final_label_options",
        "minimum_reviewer_confidence"
      ],
      "type": "object"
    },
    "queueItem": {
      "additionalProperties": false,
      "properties": {
        "episode_id": { "minLength": 1, "type": "string" },
        "mock_model_label": {
          "enum": ["accept", "reject", "needs_review", "unsafe", "incomplete"],
          "type": "string"
        },
        "reason": { "const": "human_review_required_by_rubric_or_low_confidence" },
        "review_item_id": { "minLength": 1, "type": "string" },
        "review_item_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "scenario_id": { "minLength": 1, "type": "string" },
        "source_report": { "type": ["string", "null"] },
        "task_family": { "minLength": 1, "type": "string" }
      },
      "required": [
        "review_item_id",
        "episode_id",
        "scenario_id",
        "task_family",
        "review_item_sha256",
        "mock_model_label",
        "reason",
        "source_report"
      ],
      "type": "object"
    },
    "sourceArtifact": {
      "additionalProperties": false,
      "properties": {
        "exists": { "type": "boolean" },
        "path": { "type": ["string", "null"] },
        "role": { "minLength": 1, "type": "string" },
        "schema_error_count": { "minimum": 0, "type": "integer" },
        "schema_errors": {
          "items": { "type": "string" },
          "type": "array"
        },
        "schema_name": { "minLength": 1, "type": "string" },
        "schema_passed": { "type": "boolean" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": ["string", "null"] },
        "size_bytes": { "minimum": 0, "type": ["integer", "null"] },
        "source_passed": { "type": ["boolean", "null"] },
        "source_recommendation": { "type": "string" }
      },
      "required": [
        "role",
        "path",
        "exists",
        "sha256",
        "size_bytes",
        "schema_name",
        "schema_passed",
        "schema_error_count",
        "schema_errors",
        "source_passed",
        "source_recommendation"
      ],
      "type": "object"
    },
    "trainingAdmission": {
      "additionalProperties": false,
      "properties": {
        "labels_admitted_count": { "const": 0 },
        "labels_allowed_for_training": { "const": false },
        "requires_model_grader_gate": { "const": true }
      },
      "required": ["labels_allowed_for_training", "labels_admitted_count", "requires_model_grader_gate"],
      "type": "object"
    }
  }
}
