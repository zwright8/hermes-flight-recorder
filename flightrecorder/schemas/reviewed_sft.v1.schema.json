{
  "$id": "https://schemas.hermes-flight-recorder.dev/reviewed_sft.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Human-accepted supervised fine-tuning row emitted by apply-review.",
  "properties": {
    "episode_id": {"minLength": 1, "type": "string"},
    "human_label": {"const": "accept"},
    "prompt": {"type": "string"},
    "quality_gate": {"const": "human_reviewed_accept"},
    "response": {"type": "string"},
    "review_item_id": {"minLength": 1, "type": "string"},
    "review_item_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "reviewer_confidence": {"enum": ["high", "medium", "low", "unknown"], "type": "string"},
    "scenario_id": {"minLength": 1, "type": "string"},
    "schema_version": {"const": "hfr.reviewed.sft.v1"},
    "source_artifact": {"const": "reviewed_labels.jsonl"},
    "task_family": {"minLength": 1, "type": "string"}
  },
  "required": ["schema_version", "review_item_id", "review_item_sha256", "episode_id", "scenario_id", "task_family", "prompt", "response", "human_label", "reviewer_confidence", "quality_gate", "source_artifact"],
  "title": "Hermes Flight Recorder Reviewed SFT Row",
  "type": "object"
}
