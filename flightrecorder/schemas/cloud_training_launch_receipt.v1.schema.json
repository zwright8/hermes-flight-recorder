{
  "$id": "https://schemas.hermes-flight-recorder.dev/cloud_training_launch_receipt.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Dry-run or blocked live cloud training launch receipt.",
  "properties": {
    "blocked_reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "created_at": {
      "type": "string"
    },
    "execution_boundary": {
      "$ref": "#/$defs/executionBoundary"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "launch": {
      "additionalProperties": false,
      "properties": {
        "cloud_job_started": {
          "const": false
        },
        "cost_incurred_usd": {
          "const": 0
        },
        "mode": {
          "enum": [
            "dry_run",
            "live"
          ]
        },
        "provider_api_called": {
          "const": false
        },
        "provider_job_id": {
          "const": null
        }
      },
      "required": [
        "mode",
        "cloud_job_started",
        "provider_job_id",
        "provider_api_called",
        "cost_incurred_usd"
      ],
      "type": "object"
    },
    "passed": {
      "type": "boolean"
    },
    "readiness": {
      "enum": [
        "dry_run_recorded",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "safe_to_archive_dry_run_receipt",
        "block_live_cloud_launch"
      ]
    },
    "schema_version": {
      "const": "hfr.cloud_training_launch_receipt.v1"
    },
    "source_artifacts": {
      "additionalProperties": false,
      "properties": {
        "launch_plan": {
          "$ref": "#/$defs/sourceArtifact"
        }
      },
      "required": [
        "launch_plan"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "created_at",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "source_artifacts",
    "launch",
    "execution_boundary"
  ],
  "title": "Hermes Flight Recorder Cloud Training Launch Receipt",
  "type": "object",
  "$defs": {
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "actual",
        "expected",
        "summary"
      ],
      "type": "object"
    },
    "executionBoundary": {
      "additionalProperties": false,
      "properties": {
        "allow_live": {
          "const": false
        },
        "cloud_cost_incurred_usd": {
          "const": 0
        },
        "cloud_job_started": {
          "const": false
        },
        "credential_values_recorded": {
          "const": false
        },
        "dry_run_only": {
          "const": true
        },
        "live_preflight_requested": {
          "type": "boolean"
        },
        "live_requested": {
          "type": "boolean"
        },
        "model_downloads_started": {
          "const": false
        },
        "provider_api_called": {
          "const": false
        },
        "weights_updated_by_flight_recorder": {
          "const": false
        }
      },
      "required": [
        "dry_run_only",
        "live_preflight_requested",
        "live_requested",
        "allow_live",
        "provider_api_called",
        "cloud_job_started",
        "cloud_cost_incurred_usd",
        "model_downloads_started",
        "weights_updated_by_flight_recorder",
        "credential_values_recorded"
      ],
      "type": "object"
    },
    "sourceArtifact": {
      "additionalProperties": false,
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "role": {
          "minLength": 1,
          "type": "string"
        },
        "schema_error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "schema_errors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "schema_name": {
          "type": "string"
        },
        "schema_passed": {
          "type": "boolean"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": [
            "string",
            "null"
          ]
        },
        "size_bytes": {
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "source_passed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "source_recommendation": {
          "type": "string"
        }
      },
      "required": [
        "role",
        "path",
        "exists",
        "sha256",
        "size_bytes",
        "schema_name",
        "schema_passed",
        "schema_error_count",
        "schema_errors",
        "source_passed",
        "source_recommendation"
      ],
      "type": "object"
    }
  }
}
