{
  "$id": "https://schemas.hermes-flight-recorder.dev/review_calibration.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Calibration report comparing reviewed human labels with deterministic scorecard outcomes.",
  "properties": {
    "check_count": { "minimum": 0, "type": "integer" },
    "checks": {
      "items": { "$ref": "#/$defs/check" },
      "type": "array"
    },
    "disagreements": {
      "items": { "$ref": "#/$defs/disagreement" },
      "type": "array"
    },
    "effective_policy": { "$ref": "#/$defs/effective_policy" },
    "failed_check_count": { "minimum": 0, "type": "integer" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "notes": {
      "items": { "type": "string" },
      "type": "array"
    },
    "passed": { "type": "boolean" },
    "reviewed_export": { "minLength": 1, "type": "string" },
    "schema_version": { "const": "hfr.review_calibration.v1" },
    "source": { "$ref": "#/$defs/source" },
    "source_artifacts": { "$ref": "#/$defs/source_artifacts" }
  },
  "required": [
    "schema_version",
    "reviewed_export",
    "source",
    "passed",
    "check_count",
    "failed_check_count",
    "checks",
    "metrics",
    "disagreements",
    "notes"
  ],
  "title": "Hermes Flight Recorder Review Calibration",
  "type": "object",
  "$defs": {
    "effective_policy": {
      "additionalProperties": false,
      "properties": {
        "max_disagreements": { "minimum": 0, "type": ["integer", "null"] },
        "max_false_negatives": { "minimum": 0, "type": ["integer", "null"] },
        "max_false_positives": { "minimum": 0, "type": ["integer", "null"] },
        "min_agreement_rate": { "maximum": 1, "minimum": 0, "type": ["number", "null"] },
        "min_comparable_labels": { "minimum": 0, "type": ["integer", "null"] },
        "require_valid_export": { "type": "boolean" },
        "strict_validation": { "type": "boolean" }
      },
      "required": [
        "min_agreement_rate",
        "max_disagreements",
        "max_false_positives",
        "max_false_negatives",
        "min_comparable_labels",
        "require_valid_export",
        "strict_validation"
      ],
      "type": "object"
    },
    "check": {
      "oneOf": [
        { "$ref": "#/$defs/min_check" },
        { "$ref": "#/$defs/max_check" },
        { "$ref": "#/$defs/source_paths_check" },
        { "$ref": "#/$defs/validation_check" }
      ]
    },
    "expected_max": {
      "additionalProperties": false,
      "properties": {
        "max": { "minimum": 0, "type": "integer" }
      },
      "required": ["max"],
      "type": "object"
    },
    "expected_source_paths": {
      "additionalProperties": false,
      "properties": {
        "safe_relative_paths": { "const": true }
      },
      "required": ["safe_relative_paths"],
      "type": "object"
    },
    "expected_min": {
      "additionalProperties": false,
      "properties": {
        "min": { "minimum": 0, "type": "number" }
      },
      "required": ["min"],
      "type": "object"
    },
    "max_check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "minimum": 0, "type": "integer" },
        "expected": { "$ref": "#/$defs/expected_max" },
        "id": { "enum": ["max_disagreements", "max_false_positives", "max_false_negatives"], "type": "string" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "min_check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "minimum": 0, "type": "number" },
        "expected": { "$ref": "#/$defs/expected_min" },
        "id": { "enum": ["min_comparable_labels", "min_agreement_rate"], "type": "string" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "source_paths": {
      "additionalProperties": false,
      "properties": {
        "reviewed_export": { "minLength": 1, "type": "string" },
        "reviewed_labels": { "minLength": 1, "type": "string" }
      },
      "required": ["reviewed_export", "reviewed_labels"],
      "type": "object"
    },
    "source_paths_check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "$ref": "#/$defs/source_paths" },
        "expected": { "$ref": "#/$defs/expected_source_paths" },
        "id": { "const": "source_paths_replayable" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "validation_check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "$ref": "#/$defs/validation" },
        "expected": { "$ref": "#/$defs/validation_expected" },
        "id": { "const": "valid_reviewed_export" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "disagreement": {
      "additionalProperties": false,
      "properties": {
        "critical_failures": {
          "items": { "type": "string" },
          "type": "array"
        },
        "disagreement_type": {
          "enum": ["scorecard_passed_human_rejected", "scorecard_failed_human_accepted"],
          "type": "string"
        },
        "episode_id": { "minLength": 1, "type": "string" },
        "failed_rules": {
          "items": { "type": "string" },
          "type": "array"
        },
        "human_label": { "minLength": 1, "type": "string" },
        "review_item_id": { "minLength": 1, "type": "string" },
        "scenario_id": { "minLength": 1, "type": "string" },
        "scorecard_passed": { "type": "boolean" },
        "scorecard_score": { "maximum": 100, "minimum": 0, "type": "integer" },
        "source_lineage": { "type": ["string", "null"] },
        "source_report": { "type": ["string", "null"] },
        "task_family": { "minLength": 1, "type": "string" }
      },
      "required": [
        "review_item_id",
        "episode_id",
        "scenario_id",
        "task_family",
        "human_label",
        "scorecard_passed",
        "scorecard_score",
        "failed_rules",
        "critical_failures",
        "source_report",
        "source_lineage",
        "disagreement_type"
      ],
      "type": "object"
    },
    "label_count": {
      "additionalProperties": false,
      "properties": {
        "count": { "minimum": 0, "type": "integer" },
        "label": { "enum": ["accept", "reject", "needs_review", "unsafe", "incomplete"], "type": "string" }
      },
      "required": ["label", "count"],
      "type": "object"
    },
    "mean_score": {
      "additionalProperties": false,
      "properties": {
        "average_score": { "maximum": 100, "minimum": 0, "type": "number" },
        "count": { "minimum": 0, "type": "integer" },
        "label": { "minLength": 1, "type": "string" }
      },
      "required": ["label", "count", "average_score"],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": false,
      "properties": {
        "agreement_count": { "minimum": 0, "type": "integer" },
        "agreement_rate": { "maximum": 1, "minimum": 0, "type": "number" },
        "comparable_label_count": { "minimum": 0, "type": "integer" },
        "disagreement_count": { "minimum": 0, "type": "integer" },
        "false_negative_count": { "minimum": 0, "type": "integer" },
        "false_positive_count": { "minimum": 0, "type": "integer" },
        "human_negative_count": { "minimum": 0, "type": "integer" },
        "human_positive_count": { "minimum": 0, "type": "integer" },
        "label_counts": {
          "items": { "$ref": "#/$defs/label_count" },
          "type": "array"
        },
        "mean_score_by_human_label": {
          "items": { "$ref": "#/$defs/mean_score" },
          "type": "array"
        },
        "needs_review_count": { "minimum": 0, "type": "integer" },
        "reviewed_label_count": { "minimum": 0, "type": "integer" },
        "scorecard_negative_count": { "minimum": 0, "type": "integer" },
        "scorecard_positive_count": { "minimum": 0, "type": "integer" },
        "task_families": {
          "items": { "type": "string" },
          "type": "array"
        },
        "validation": { "$ref": "#/$defs/validation" }
      },
      "required": [
        "reviewed_label_count",
        "comparable_label_count",
        "needs_review_count",
        "agreement_count",
        "disagreement_count",
        "agreement_rate",
        "scorecard_positive_count",
        "scorecard_negative_count",
        "human_positive_count",
        "human_negative_count",
        "false_positive_count",
        "false_negative_count",
        "label_counts",
        "mean_score_by_human_label",
        "task_families"
      ],
      "type": "object"
    },
    "source": {
      "additionalProperties": false,
      "properties": {
        "reviewed_labels": { "minLength": 1, "type": "string" }
      },
      "required": ["reviewed_labels"],
      "type": "object"
    },
    "source_artifact": {
      "additionalProperties": false,
      "properties": {
        "contains_symlinks": { "const": false },
        "dataset_version": { "minLength": 1, "type": "string" },
        "exists": { "const": true },
        "file_count": { "minimum": 1, "type": "integer" },
        "kind": { "const": "directory" },
        "manifest_path": { "minLength": 1, "type": "string" },
        "manifest_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "manifest_size_bytes": { "minimum": 1, "type": "integer" },
        "path": { "minLength": 1, "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 1, "type": "integer" },
        "tree_hash_algorithm": { "const": "hfr.sha256.file-tree.v1" }
      },
      "required": [
        "path",
        "kind",
        "exists",
        "tree_hash_algorithm",
        "sha256",
        "file_count",
        "size_bytes",
        "contains_symlinks",
        "manifest_path",
        "manifest_sha256",
        "manifest_size_bytes",
        "dataset_version"
      ],
      "type": "object"
    },
    "source_artifacts": {
      "additionalProperties": false,
      "properties": {
        "reviewed_export": { "$ref": "#/$defs/source_artifact" }
      },
      "required": ["reviewed_export"],
      "type": "object"
    },
    "validation": {
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "error_count": { "minimum": 0, "type": "integer" },
        "passed": { "type": "boolean" },
        "strict": { "type": "boolean" },
        "target_count": { "minimum": 0, "type": "integer" },
        "warning_count": { "minimum": 0, "type": "integer" }
      },
      "required": ["available", "passed", "strict", "target_count", "error_count", "warning_count"],
      "type": "object"
    },
    "validation_expected": {
      "additionalProperties": false,
      "properties": {
        "error_count": { "const": 0 },
        "passed": { "const": true }
      },
      "required": ["passed", "error_count"],
      "type": "object"
    }
  }
}
