{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Gmail thread evidence using a read-only OAuth token in GMAIL_ACCESS_TOKEN.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "gmail_threads",
      "type": "gmail_threads",
      "token_env": "GMAIL_ACCESS_TOKEN",
      "query": "subject:email-123",
      "max_threads": 5,
      "format": "metadata",
      "state_path": "gmail"
    }
  ]
}

