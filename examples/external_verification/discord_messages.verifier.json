{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Discord channel messages using a read-only bot token.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "discord_channel_messages",
      "type": "discord_messages",
      "channel_id": "C123",
      "limit": 50,
      "token_env": "DISCORD_BOT_TOKEN",
      "state_path": "discord"
    }
  ]
}
