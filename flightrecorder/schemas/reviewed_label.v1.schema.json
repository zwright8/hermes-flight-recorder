{
  "$id": "https://schemas.hermes-flight-recorder.dev/reviewed_label.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Human-reviewed label joined to its evidence and scorecard provenance.",
  "properties": {
    "accepted_evidence_refs": {"items": {}, "type": "array"},
    "corrected_score": {"maximum": 100, "minimum": 0, "type": ["integer", "null"]},
    "episode_id": {"minLength": 1, "type": "string"},
    "human_label": {"$ref": "#/$defs/label"},
    "notes": {"type": "string"},
    "prompt": {"type": "string"},
    "rejected_evidence_refs": {"items": {}, "type": "array"},
    "response": {"type": "string"},
    "review_item_id": {"minLength": 1, "type": "string"},
    "review_item_sha256": {"$ref": "#/$defs/sha256"},
    "reviewed_at": {"minLength": 1, "type": "string"},
    "reviewer": {"minLength": 1, "type": "string"},
    "reviewer_confidence": {"$ref": "#/$defs/confidence"},
    "reward": {"maximum": 1, "minimum": 0, "type": "number"},
    "scenario_id": {"minLength": 1, "type": "string"},
    "scenario_title": {"type": "string"},
    "schema_version": {"const": "hfr.reviewed.label.v1"},
    "score": {"maximum": 100, "minimum": 0, "type": "integer"},
    "scorecard": {"$ref": "#/$defs/scorecard"},
    "source_artifacts": {"additionalProperties": {"minLength": 1, "type": "string"}, "minProperties": 4, "type": "object"},
    "source_label_file": {"minLength": 1, "type": "string"},
    "source_label_sha256": {"$ref": "#/$defs/sha256"},
    "suggested_human_label": {"oneOf": [{"$ref": "#/$defs/label"}, {"type": "null"}]},
    "task_family": {"minLength": 1, "type": "string"}
  },
  "required": ["schema_version", "review_item_id", "review_item_sha256", "episode_id", "scenario_id", "scenario_title", "task_family", "prompt", "response", "human_label", "suggested_human_label", "corrected_score", "score", "reward", "reviewer", "reviewer_confidence", "reviewed_at", "notes", "accepted_evidence_refs", "rejected_evidence_refs", "source_label_file", "source_label_sha256", "source_artifacts", "scorecard"],
  "title": "Hermes Flight Recorder Reviewed Label",
  "type": "object",
  "$defs": {
    "confidence": {"enum": ["high", "medium", "low", "unknown"], "type": "string"},
    "label": {"enum": ["accept", "reject", "needs_review", "unsafe", "incomplete"], "type": "string"},
    "scorecard": {
      "additionalProperties": false,
      "properties": {
        "critical_failures": {"items": {"type": "string"}, "type": "array"},
        "failed_rules": {"items": {"type": "string"}, "type": "array"},
        "passed": {"type": "boolean"},
        "score": {"maximum": 100, "minimum": 0, "type": "integer"},
        "summary": {"type": "string"}
      },
      "required": ["passed", "score", "failed_rules", "critical_failures", "summary"],
      "type": "object"
    },
    "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
  }
}
