{
  "$id": "https://schemas.hermes-flight-recorder.dev/agentic_lora_training_plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Dry-run or launch-gating plan emitted by scripts/train_agentic_lora.py before heavy ML imports.",
  "properties": {
    "blocked_reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "compute_assumptions": {
      "type": "object"
    },
    "created_at": {
      "minLength": 1,
      "type": "string"
    },
    "data_files": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "dry_run": {
      "type": "boolean"
    },
    "experiment_dir": {
      "type": "string"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "hyperparameters": {
      "type": "object"
    },
    "input_manifests": {
      "type": "object"
    },
    "local_training": {
      "$ref": "#/$defs/local_training"
    },
    "mode": {
      "enum": [
        "trace_sft",
        "fr_sft",
        "fr_action_sft",
        "fr_dpo",
        "fr_sft_dpo",
        "fr_reward_model",
        "fr_step_rewards"
      ]
    },
    "model": {
      "minLength": 1,
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "passed": {
      "type": "boolean"
    },
    "prepared_counts": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "type": "object"
    },
    "raw_counts": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "type": "object"
    },
    "readiness": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "launch_allowed",
        "block_launch"
      ]
    },
    "schema_version": {
      "const": "hfr.agentic_lora_training_plan.v1"
    },
    "smoke": {
      "type": "object"
    },
    "task_scope": {
      "$ref": "#/$defs/task_scope"
    },
    "trainer_backends": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "created_at",
    "mode",
    "model",
    "experiment_dir",
    "output_dir",
    "dry_run",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "input_manifests",
    "data_files",
    "raw_counts",
    "prepared_counts",
    "hyperparameters",
    "local_training",
    "task_scope",
    "compute_assumptions",
    "trainer_backends"
  ],
  "title": "Hermes Flight Recorder Agentic LoRA Training Plan",
  "type": "object",
  "$defs": {
    "local_training": {
      "additionalProperties": true,
      "properties": {
        "adapter_targets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "design_reference": {
          "minLength": 1,
          "type": "string"
        },
        "device_order": {
          "items": {
            "enum": [
              "cuda",
              "mps",
              "cpu"
            ]
          },
          "minItems": 1,
          "type": "array"
        },
        "enabled": {
          "type": "boolean"
        },
        "execution_requested": {
          "type": "boolean"
        },
        "fixed_training_time_budget_seconds": {
          "minimum": 0,
          "type": "number"
        },
        "hub_push_allowed": {
          "type": "boolean"
        },
        "local_files_only": {
          "type": "boolean"
        },
        "model_path": {
          "type": "string"
        },
        "network_allowed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "remote_tracking_allowed": {
          "type": "boolean"
        },
        "requested_device": {
          "enum": [
            "auto",
            "mps",
            "cuda",
            "cpu"
          ]
        }
      },
      "required": [
        "enabled",
        "execution_requested",
        "local_files_only",
        "network_allowed",
        "hub_push_allowed",
        "remote_tracking_allowed",
        "requested_device",
        "device_order",
        "fixed_training_time_budget_seconds",
        "model_path",
        "adapter_targets",
        "design_reference"
      ],
      "type": "object"
    },
    "task_scope": {
      "additionalProperties": true,
      "properties": {
        "available_task_families": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "filter_applied": {
          "type": "boolean"
        },
        "full_raw_counts": {
          "additionalProperties": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "object"
        },
        "requested_task_families": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "selected_raw_counts": {
          "additionalProperties": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "object"
        },
        "selected_task_families": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "requested_task_families",
        "available_task_families",
        "selected_task_families",
        "filter_applied",
        "full_raw_counts",
        "selected_raw_counts"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": true,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "scope": {
          "type": "object"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "summary"
      ],
      "type": "object"
    }
  }
}
