{
  "$id": "https://schemas.hermes-flight-recorder.dev/rl_sft.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Trainer-ready supervised fine-tuning row emitted in export-rl sft.jsonl.",
  "properties": {
    "episode_id": {
      "minLength": 1,
      "type": "string"
    },
    "messages": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "prompt": {
      "type": "string"
    },
    "quality_gate": {
      "type": "string"
    },
    "response": {
      "type": "string"
    },
    "reward": {
      "type": "number"
    },
    "sample_id": {
      "minLength": 1,
      "type": "string"
    },
    "scenario_id": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "hfr.rl.sft.v1"
    },
    "score": {
      "minimum": 0,
      "type": "integer"
    },
    "source_artifact": {
      "const": "episodes.jsonl"
    },
    "source_fingerprint_status": {
      "type": "string"
    },
    "source_fingerprints": {
      "type": "object"
    },
    "task_completion_passed": {
      "type": "boolean"
    },
    "task_completion_status": {
      "type": "string"
    },
    "task_family": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "sample_id",
    "episode_id",
    "scenario_id",
    "task_family",
    "prompt",
    "response",
    "messages",
    "score",
    "reward",
    "quality_gate",
    "task_completion_status",
    "task_completion_passed",
    "source_fingerprint_status",
    "source_fingerprints",
    "source_artifact"
  ],
  "title": "Hermes Flight Recorder RL SFT Row",
  "type": "object"
}
