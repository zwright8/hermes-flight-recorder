{
  "$id": "https://schemas.hermes-flight-recorder.dev/reviewed_gate.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Gate result over an apply-review reviewed trainer handoff and optional reviewed-gate policy.",
  "properties": {
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "decision": {
      "$ref": "#/$defs/decision"
    },
    "effective_policy": {
      "$ref": "#/$defs/effective_policy"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "passed": {
      "type": "boolean"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "reviewed_export": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "hfr.reviewed_gate.v1"
    },
    "source_artifacts": {
      "$ref": "#/$defs/source_artifacts"
    }
  },
  "required": [
    "schema_version",
    "reviewed_export",
    "passed",
    "check_count",
    "failed_check_count",
    "checks",
    "metrics",
    "decision"
  ],
  "title": "Hermes Flight Recorder Reviewed Gate",
  "type": "object",
  "$defs": {
    "blocking_check": {
      "additionalProperties": true,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "scope": {
          "type": "object"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": true,
      "properties": {
        "actual": {},
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "scope": {
          "type": "object"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "actual",
        "expected",
        "summary"
      ],
      "type": "object"
    },
    "count_map": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "type": "object"
    },
    "decision": {
      "additionalProperties": true,
      "properties": {
        "blocking_check_count": {
          "minimum": 0,
          "type": "integer"
        },
        "blocking_checks": {
          "items": {
            "$ref": "#/$defs/blocking_check"
          },
          "type": "array"
        },
        "failed_checks": {
          "items": {
            "$ref": "#/$defs/blocking_check"
          },
          "type": "array"
        },
        "key_metrics": {
          "$ref": "#/$defs/metrics"
        },
        "next_action_count": {
          "minimum": 0,
          "type": "integer"
        },
        "next_actions": {
          "items": {
            "type": "object"
          },
          "type": "array"
        },
        "readiness": {
          "enum": [
            "blocked",
            "ready"
          ],
          "type": "string"
        },
        "recommendation": {
          "enum": [
            "block_iteration",
            "promote_iteration"
          ],
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "readiness",
        "recommendation",
        "summary",
        "blocking_check_count",
        "blocking_checks",
        "failed_checks",
        "next_action_count",
        "next_actions",
        "key_metrics"
      ],
      "type": "object"
    },
    "effective_policy": {
      "additionalProperties": false,
      "properties": {
        "forbid_labels": {
          "items": {
            "enum": [
              "accept",
              "reject",
              "needs_review",
              "unsafe",
              "incomplete"
            ]
          },
          "type": "array"
        },
        "max_low_confidence_labels": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "max_needs_review": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "max_unknown_confidence_labels": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_accepted": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_dpo": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_high_confidence_labels": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_medium_or_high_confidence_labels": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_preferences": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_rejected": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_reviewed_labels": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_reward_model": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "min_sft": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "require_task_families": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "require_valid_export": {
          "type": "boolean"
        },
        "strict_validation": {
          "type": "boolean"
        }
      },
      "required": [
        "min_reviewed_labels",
        "min_accepted",
        "min_rejected",
        "min_sft",
        "min_reward_model",
        "min_preferences",
        "min_dpo",
        "min_high_confidence_labels",
        "min_medium_or_high_confidence_labels",
        "max_needs_review",
        "max_low_confidence_labels",
        "max_unknown_confidence_labels",
        "forbid_labels",
        "require_task_families",
        "require_valid_export",
        "strict_validation"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": true,
      "properties": {
        "accepted_count": {
          "minimum": 0,
          "type": "integer"
        },
        "confidence_counts": {
          "$ref": "#/$defs/count_map"
        },
        "dpo_count": {
          "minimum": 0,
          "type": "integer"
        },
        "high_confidence_label_count": {
          "minimum": 0,
          "type": "integer"
        },
        "label_counts": {
          "$ref": "#/$defs/count_map"
        },
        "low_confidence_label_count": {
          "minimum": 0,
          "type": "integer"
        },
        "medium_or_high_confidence_label_count": {
          "minimum": 0,
          "type": "integer"
        },
        "preference_count": {
          "minimum": 0,
          "type": "integer"
        },
        "rejected_count": {
          "minimum": 0,
          "type": "integer"
        },
        "reviewed_label_count": {
          "minimum": 0,
          "type": "integer"
        },
        "reward_model_count": {
          "minimum": 0,
          "type": "integer"
        },
        "sft_count": {
          "minimum": 0,
          "type": "integer"
        },
        "task_families": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unknown_confidence_label_count": {
          "minimum": 0,
          "type": "integer"
        },
        "validation": {
          "$ref": "#/$defs/validation"
        }
      },
      "required": [
        "reviewed_label_count",
        "accepted_count",
        "rejected_count",
        "sft_count",
        "reward_model_count",
        "preference_count",
        "dpo_count",
        "label_counts",
        "confidence_counts",
        "high_confidence_label_count",
        "medium_or_high_confidence_label_count",
        "low_confidence_label_count",
        "unknown_confidence_label_count",
        "task_families",
        "validation"
      ],
      "type": "object"
    },
    "policy": {
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "effective": {
          "type": "object"
        },
        "path": {
          "type": "string"
        },
        "schema_version": {
          "const": "hfr.reviewed_gate.policy.v1"
        }
      },
      "required": [
        "schema_version",
        "path",
        "effective"
      ],
      "type": "object"
    },
    "source_artifact": {
      "additionalProperties": false,
      "properties": {
        "contains_symlinks": {
          "const": false
        },
        "dataset_version": {
          "minLength": 1,
          "type": "string"
        },
        "exists": {
          "const": true
        },
        "file_count": {
          "minimum": 1,
          "type": "integer"
        },
        "kind": {
          "const": "directory"
        },
        "manifest_path": {
          "minLength": 1,
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "manifest_size_bytes": {
          "minimum": 1,
          "type": "integer"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "type": "integer"
        },
        "tree_hash_algorithm": {
          "const": "hfr.sha256.file-tree.v1"
        }
      },
      "required": [
        "path",
        "kind",
        "exists",
        "tree_hash_algorithm",
        "sha256",
        "file_count",
        "size_bytes",
        "contains_symlinks",
        "manifest_path",
        "manifest_sha256",
        "manifest_size_bytes",
        "dataset_version"
      ],
      "type": "object"
    },
    "source_artifacts": {
      "additionalProperties": false,
      "properties": {
        "reviewed_export": {
          "$ref": "#/$defs/source_artifact"
        }
      },
      "required": [
        "reviewed_export"
      ],
      "type": "object"
    },
    "validation": {
      "additionalProperties": true,
      "properties": {
        "available": {
          "type": "boolean"
        },
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "strict": {
          "type": "boolean"
        },
        "target_count": {
          "minimum": 0,
          "type": "integer"
        },
        "warning_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "available",
        "passed",
        "strict",
        "target_count",
        "error_count",
        "warning_count"
      ],
      "type": "object"
    }
  }
}
