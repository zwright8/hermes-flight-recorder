{
  "$id": "https://schemas.hermes-flight-recorder.dev/cloud_training_preflight.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Fail-closed cloud training provider preflight.",
  "properties": {
    "blocked_reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "constraints": {
      "type": "object"
    },
    "created_at": {
      "type": "string"
    },
    "credential_checks": {
      "items": {
        "$ref": "#/$defs/credentialCheck"
      },
      "type": "array"
    },
    "execution_boundary": {
      "$ref": "#/$defs/boundary"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "handoff_contract": {
      "$ref": "#/$defs/handoffContract"
    },
    "live_preflight": {
      "$ref": "#/$defs/livePreflight"
    },
    "passed": {
      "type": "boolean"
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "readiness": {
      "enum": [
        "ready_for_dry_run_launch_plan",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "build_dry_run_launch_plan",
        "block_cloud_training_launch"
      ]
    },
    "schema_version": {
      "const": "hfr.cloud_training_preflight.v1"
    },
    "source_artifacts": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "created_at",
    "provider",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "constraints",
    "credential_checks",
    "source_artifacts",
    "execution_boundary",
    "handoff_contract"
  ],
  "title": "Hermes Flight Recorder Cloud Training Preflight",
  "type": "object",
  "$defs": {
    "boundary": {
      "type": "object"
    },
    "check": {
      "additionalProperties": true,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "actual",
        "expected",
        "summary"
      ],
      "type": "object"
    },
    "credentialCheck": {
      "additionalProperties": true,
      "properties": {
        "env_var": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        },
        "value_recorded": {
          "const": false
        }
      },
      "required": [
        "env_var",
        "present",
        "value_recorded"
      ],
      "type": "object"
    },
    "handoffContract": {
      "additionalProperties": true,
      "properties": {
        "default_live_execution_allowed": {
          "const": false
        },
        "external_provider_owns_execution": {
          "const": true
        },
        "flight_recorder_controls_preflight_only": {
          "const": true
        },
        "requires_cost_limit": {
          "const": true
        },
        "requires_environment_credentials_for_live": {
          "const": true
        },
        "requires_explicit_live_opt_in": {
          "const": true
        },
        "requires_region_and_gpu_constraints": {
          "const": true
        },
        "requires_status_and_cancel_receipts": {
          "const": true
        }
      },
      "required": [
        "default_live_execution_allowed",
        "requires_explicit_live_opt_in",
        "requires_environment_credentials_for_live",
        "requires_cost_limit",
        "requires_region_and_gpu_constraints",
        "requires_status_and_cancel_receipts",
        "flight_recorder_controls_preflight_only",
        "external_provider_owns_execution"
      ],
      "type": "object"
    },
    "livePreflight": {
      "additionalProperties": true,
      "properties": {
        "client_dependency_available_count": {
          "minimum": 0,
          "type": "integer"
        },
        "client_dependency_checks": {
          "items": {
            "additionalProperties": true,
            "properties": {
              "available": {
                "type": "boolean"
              },
              "module": {
                "type": "string"
              },
              "module_imported": {
                "const": false
              }
            },
            "required": [
              "module",
              "available",
              "module_imported"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "client_dependency_required_count": {
          "minimum": 0,
          "type": "integer"
        },
        "client_modules_imported": {
          "const": false
        },
        "credential_present_count": {
          "minimum": 0,
          "type": "integer"
        },
        "credential_required_count": {
          "minimum": 0,
          "type": "integer"
        },
        "credential_values_recorded": {
          "const": false
        },
        "provider_api_called": {
          "const": false
        },
        "requested": {
          "type": "boolean"
        },
        "transport": {
          "const": "metadata_only"
        }
      },
      "required": [
        "requested",
        "transport",
        "provider_api_called",
        "client_modules_imported",
        "credential_values_recorded",
        "credential_present_count",
        "credential_required_count",
        "client_dependency_checks",
        "client_dependency_available_count",
        "client_dependency_required_count"
      ],
      "type": "object"
    },
    "provider": {
      "type": "object"
    }
  }
}
