{
  "$id": "https://schemas.hermes-flight-recorder.dev/trainer_preflight.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Trainer preflight launch guard over passed gates and trainer-facing evidence artifacts.",
  "properties": {
    "artifacts": {
      "additionalProperties": {
        "$ref": "#/$defs/artifact"
      },
      "type": "object"
    },
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "dataset_selection": {
      "items": {
        "$ref": "#/$defs/datasetSelection"
      },
      "type": "array"
    },
    "gate_count": {
      "minimum": 0,
      "type": "integer"
    },
    "gates": {
      "items": {
        "$ref": "#/$defs/preflightGate"
      },
      "type": "array"
    },
    "metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "passed": {
      "type": "boolean"
    },
    "passed_gate_count": {
      "minimum": 0,
      "type": "integer"
    },
    "preflight_path": {
      "minLength": 1,
      "type": "string"
    },
    "readiness": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "launch_allowed",
        "block_launch"
      ]
    },
    "required_gates": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_dataset_versions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "hfr.trainer_preflight.v1"
    },
    "schema_contracts": {
      "additionalProperties": {
        "$ref": "#/$defs/schemaContract"
      },
      "type": "object"
    },
    "trainer_command": {
      "$ref": "#/$defs/trainerCommand"
    },
    "validation_summaries": {
      "items": {
        "$ref": "#/$defs/validationSummary"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "preflight_path",
    "passed",
    "readiness",
    "recommendation",
    "gate_count",
    "passed_gate_count",
    "required_gates",
    "required_dataset_versions",
    "check_count",
    "failed_check_count",
    "checks",
    "gates",
    "artifacts",
    "dataset_selection",
    "trainer_command",
    "notes"
  ],
  "title": "Hermes Flight Recorder Trainer Preflight",
  "type": "object",
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "exists": {
                  "const": true
                },
                "kind": {
                  "const": "file"
                },
                "regular_file": {
                  "const": true
                }
              },
              "required": [
                "kind",
                "exists",
                "regular_file",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "kind": {
                  "const": "file"
                },
                "regular_file": {
                  "const": false
                }
              },
              "required": [
                "kind",
                "regular_file"
              ],
              "type": "object"
            },
            {
              "properties": {
                "exists": {
                  "const": true
                },
                "kind": {
                  "const": "directory"
                },
                "regular_directory": {
                  "const": true
                }
              },
              "required": [
                "kind",
                "exists",
                "regular_directory",
                "entry_count",
                "file_count",
                "sha256",
                "size_bytes",
                "tree_hash_algorithm"
              ],
              "type": "object"
            },
            {
              "properties": {
                "kind": {
                  "const": "directory"
                },
                "regular_directory": {
                  "const": false
                }
              },
              "required": [
                "kind",
                "regular_directory"
              ],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "entry_count": {
          "minimum": 0,
          "type": "integer"
        },
        "exists": {
          "type": "boolean"
        },
        "file_count": {
          "minimum": 0,
          "type": "integer"
        },
        "kind": {
          "enum": [
            "file",
            "directory"
          ]
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "regular_directory": {
          "type": "boolean"
        },
        "regular_file": {
          "type": "boolean"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "symlink": {
          "type": "boolean"
        },
        "tree_hash_algorithm": {
          "const": "sha256(sorted-relative-path-size-file-sha256)"
        }
      },
      "required": [
        "path",
        "exists",
        "kind"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "scope": {
          "type": "object"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "summary"
      ],
      "type": "object"
    },
    "preflightGate": {
      "additionalProperties": false,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "exists": {
                  "const": true
                }
              },
              "required": [
                "exists",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "exists": {
                  "const": false
                }
              },
              "required": [
                "exists"
              ],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "schema_version": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "validation": {
          "$ref": "#/$defs/validation"
        }
      },
      "required": [
        "id",
        "path",
        "exists",
        "schema_version",
        "passed"
      ],
      "type": "object"
    },
    "schemaContract": {
      "additionalProperties": false,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "exists": {
                  "const": true
                },
                "regular_file": {
                  "const": true
                }
              },
              "required": [
                "exists",
                "regular_file",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "regular_file": {
                  "const": false
                }
              },
              "required": [
                "regular_file"
              ],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "errors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "exists": {
          "type": "boolean"
        },
        "kind": {
          "enum": [
            "json",
            "jsonl"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "regular_file": {
          "type": "boolean"
        },
        "row_count": {
          "minimum": 0,
          "type": "integer"
        },
        "row_schema_counts": {
          "items": {
            "$ref": "#/$defs/rowSchemaCount"
          },
          "type": "array"
        },
        "schema_name": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "symlink": {
          "type": "boolean"
        }
      },
      "required": [
        "path",
        "exists",
        "kind",
        "schema_name",
        "regular_file",
        "symlink",
        "passed",
        "error_count",
        "errors"
      ],
      "type": "object"
    },
    "rowSchemaCount": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "minimum": 0,
          "type": "integer"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "count"
      ],
      "type": "object"
    },
    "trainerCommand": {
      "additionalProperties": false,
      "properties": {
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "parseable": {
          "type": "boolean"
        },
        "provided": {
          "type": "boolean"
        },
        "raw": {
          "type": "string"
        }
      },
      "required": [
        "provided",
        "raw",
        "argv"
      ],
      "type": "object"
    },
    "validation": {
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "boolean"
        },
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "strict": {
          "type": "boolean"
        },
        "summary_passed": {
          "type": "boolean"
        },
        "target_type": {
          "type": "string"
        },
        "warning_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "available",
        "passed",
        "strict",
        "error_count",
        "warning_count"
      ],
      "type": "object"
    },
    "validationSummary": {
      "additionalProperties": false,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "exists": {
                  "const": true
                },
                "regular_file": {
                  "const": true
                }
              },
              "required": [
                "exists",
                "regular_file",
                "sha256",
                "size_bytes"
              ],
              "type": "object"
            },
            {
              "properties": {
                "regular_file": {
                  "const": false
                }
              },
              "required": [
                "regular_file"
              ],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "exists": {
          "type": "boolean"
        },
        "kind": {
          "const": "file"
        },
        "passed": {
          "type": "boolean"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "regular_file": {
          "type": "boolean"
        },
        "schema_version": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "strict": {
          "type": "boolean"
        },
        "symlink": {
          "type": "boolean"
        },
        "target_count": {
          "minimum": 0,
          "type": "integer"
        },
        "targets": {
          "items": {
            "$ref": "#/$defs/validationTarget"
          },
          "type": "array"
        },
        "warning_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "exists",
        "kind",
        "regular_file",
        "symlink",
        "schema_version",
        "passed",
        "strict",
        "target_count",
        "error_count",
        "warning_count",
        "targets"
      ],
      "type": "object"
    },
    "validationTarget": {
      "additionalProperties": false,
      "properties": {
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "type": "string"
        },
        "warning_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "type",
        "path",
        "passed",
        "error_count",
        "warning_count"
      ],
      "type": "object"
    },
    "datasetSelection": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "enum": [
            "reviewed_export",
            "training_export"
          ]
        },
        "dataset_version": {
          "type": "string"
        },
        "heldout_scenario_exclusive": {
          "type": "boolean"
        },
        "heldout_scenario_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "manifest_path": {
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "matches_required": {
          "type": "boolean"
        },
        "redaction_passed": {
          "type": "boolean"
        },
        "registry_dataset_version": {
          "type": "string"
        },
        "registry_manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "registry_path": {
          "type": "string"
        },
        "registry_selection_key": {
          "type": "string"
        },
        "registry_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "required_dataset_versions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "root": {
          "type": "string"
        },
        "trainer_modes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "trainer_views": {
          "$ref": "#/$defs/trainerViews"
        }
      },
      "required": [
        "artifact",
        "root",
        "manifest_path",
        "manifest_sha256",
        "registry_path",
        "registry_sha256",
        "dataset_version",
        "required_dataset_versions",
        "matches_required",
        "registry_dataset_version",
        "registry_selection_key",
        "registry_manifest_sha256",
        "redaction_passed",
        "trainer_views",
        "trainer_modes"
      ],
      "type": "object"
    },
    "trainerViews": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "type": "string"
        },
        "mode_to_view": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "root_views": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "views": {
          "items": {
            "$ref": "#/$defs/trainerView"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "trainerView": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "type": "string"
        },
        "artifact_format": {
          "enum": [
            "json",
            "jsonl"
          ]
        },
        "artifact_path": {
          "type": "string"
        },
        "available": {
          "type": "boolean"
        },
        "label_policy": {
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "row_count": {
          "minimum": 0,
          "type": "integer"
        },
        "schema_version": {
          "type": "string"
        },
        "source_artifacts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "split_paths": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "training_modes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "view_id": {
          "type": "string"
        }
      },
      "required": [
        "view_id",
        "training_modes",
        "artifact",
        "artifact_path",
        "artifact_format",
        "schema_version",
        "row_count",
        "source_artifacts",
        "label_policy",
        "available",
        "split_paths",
        "notes"
      ],
      "type": "object"
    }
  }
}
