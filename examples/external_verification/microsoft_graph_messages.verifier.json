{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Microsoft Graph mail messages using a read-only OAuth token.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "graph_sent_messages",
      "type": "microsoft_graph_messages",
      "folder_id": "SentItems",
      "top": 50,
      "token_env": "MICROSOFT_GRAPH_TOKEN",
      "state_path": "graph.mail"
    }
  ]
}
