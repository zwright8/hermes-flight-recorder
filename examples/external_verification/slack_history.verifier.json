{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Slack-style channel history from a read-only JSON API response.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "slack_channel_history",
      "type": "http_json",
      "url": "https://slack.com/api/conversations.history?channel=C123&limit=50",
      "bearer_token_env": "SLACK_BOT_TOKEN",
      "state_path": "slack.messages",
      "state_value_path": "json.messages"
    }
  ]
}
