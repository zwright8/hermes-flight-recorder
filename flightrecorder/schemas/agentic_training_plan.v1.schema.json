{
  "$id": "https://schemas.hermes-flight-recorder.dev/agentic_training_plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Registry-backed dry-run plan for agentic fine-tuning modes.",
  "properties": {
    "blocked_reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "created_at": {
      "minLength": 1,
      "type": "string"
    },
    "execution": {
      "$ref": "#/$defs/execution"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "handoff_contract": {
      "$ref": "#/$defs/handoffContract"
    },
    "input_manifests": {
      "$ref": "#/$defs/inputManifests"
    },
    "mode_contract": {
      "$ref": "#/$defs/modeContract"
    },
    "mode": {
      "enum": [
        "sft",
        "action_sft",
        "dpo",
        "sft_then_dpo",
        "reward_model",
        "process_rewards",
        "grpo",
        "rl"
      ]
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "passed": {
      "type": "boolean"
    },
    "plan_path": {
      "minLength": 1,
      "type": "string"
    },
    "readiness": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "ready_for_external_trainer_plan",
        "block_external_training"
      ]
    },
    "schema_version": {
      "const": "hfr.agentic_training_plan.v1"
    },
    "selected_views": {
      "items": {
        "$ref": "#/$defs/view"
      },
      "type": "array"
    },
    "trainer_plan": {
      "$ref": "#/$defs/trainerPlan"
    }
  },
  "required": [
    "schema_version",
    "created_at",
    "plan_path",
    "mode",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "input_manifests",
    "selected_views",
    "mode_contract",
    "trainer_plan",
    "execution",
    "handoff_contract",
    "notes"
  ],
  "allOf": [
    {
      "oneOf": [
        {
          "$ref": "#/$defs/sftModePlan"
        },
        {
          "$ref": "#/$defs/actionSftModePlan"
        },
        {
          "$ref": "#/$defs/dpoModePlan"
        },
        {
          "$ref": "#/$defs/sftThenDpoModePlan"
        },
        {
          "$ref": "#/$defs/rewardModelModePlan"
        },
        {
          "$ref": "#/$defs/processRewardsModePlan"
        },
        {
          "$ref": "#/$defs/grpoModePlan"
        },
        {
          "$ref": "#/$defs/rlModePlan"
        }
      ]
    }
  ],
  "title": "Hermes Flight Recorder Agentic Training Plan",
