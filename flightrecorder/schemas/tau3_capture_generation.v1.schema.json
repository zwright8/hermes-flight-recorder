{
  "$id": "https://schemas.hermes-flight-recorder.dev/tau3_capture_generation.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tau-3 Capture Generation Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "passed",
    "tau_revision",
    "generator",
    "inputs",
    "artifacts",
    "capture_count",
    "split_counts",
    "domain_counts",
    "behavior_counts",
    "token_share_by_domain",
    "token_count_by_domain",
    "domain_balance_limit",
    "domain_balance_passed",
    "tool_call_count",
    "sampling",
    "source_rejection_count",
    "sealed_payload_accessed",
    "sealed_manifest_accessed",
    "worker",
    "capture_sha256"
  ],
  "properties": {
    "schema_version": {"const": "hfr.tau3_capture_generation.v1"},
    "passed": {"const": true},
    "tau_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "boundary", "training_started", "sealed_evaluation_started"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "boundary": {"const": "subprocess-json"},
        "training_started": {"const": false},
        "sealed_evaluation_started": {"const": false}
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train_tasks", "development_tasks"],
      "properties": {
        "train_tasks": {"$ref": "#/$defs/file"},
        "development_tasks": {"$ref": "#/$defs/file"}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captures.jsonl"],
      "properties": {"captures.jsonl": {"$ref": "#/$defs/file"}}
    },
    "capture_count": {"type": "integer", "minimum": 8},
    "split_counts": {"$ref": "#/$defs/splitCounts"},
    "domain_counts": {"$ref": "#/$defs/domainCounts"},
    "behavior_counts": {"$ref": "#/$defs/behaviorCounts"},
    "token_share_by_domain": {"$ref": "#/$defs/tokenShares"},
    "token_count_by_domain": {"$ref": "#/$defs/domainCounts"},
    "domain_balance_limit": {"type": "number", "const": 0.45},
    "domain_balance_passed": {"const": true},
    "tool_call_count": {"type": "integer", "minimum": 1},
    "sampling": {"type": "object"},
    "source_rejection_count": {"type": "integer", "minimum": 0},
    "sealed_payload_accessed": {"const": false},
    "sealed_manifest_accessed": {"const": false},
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "tool_schemas_recorded_exact", "source_rejections", "selected_sources"],
      "properties": {
        "runtime": {"type": "object"},
        "tool_schemas_recorded_exact": {"const": true},
        "source_rejections": {"type": "array", "items": {"type": "object"}},
        "selected_sources": {"type": "array", "minItems": 1, "items": {"type": "object"}}
      }
    },
    "capture_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "splitCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "development"],
      "properties": {
        "train": {"type": "integer", "minimum": 1},
        "development": {"type": "integer", "minimum": 1}
      }
    },
    "domainCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["airline", "retail", "telecom"],
      "properties": {
        "airline": {"type": "integer", "minimum": 1},
        "retail": {"type": "integer", "minimum": 1},
        "telecom": {"type": "integer", "minimum": 1}
      }
    },
    "tokenShares": {
      "type": "object",
      "additionalProperties": false,
      "required": ["airline", "retail", "telecom"],
      "properties": {
        "airline": {"type": "number", "exclusiveMinimum": 0, "maximum": 0.45},
        "retail": {"type": "number", "exclusiveMinimum": 0, "maximum": 0.45},
        "telecom": {"type": "number", "exclusiveMinimum": 0, "maximum": 0.45}
      }
    },
    "behaviorCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "correction", "clarification_refusal", "recovery", "policy_failure", "harmful_mutation", "hallucinated_tool", "premature_completion"],
      "properties": {
        "success": {"type": "integer", "minimum": 1},
        "correction": {"type": "integer", "minimum": 1},
        "clarification_refusal": {"type": "integer", "minimum": 1},
        "recovery": {"type": "integer", "minimum": 1},
        "policy_failure": {"type": "integer", "minimum": 1},
        "harmful_mutation": {"type": "integer", "minimum": 1},
        "hallucinated_tool": {"type": "integer", "minimum": 1},
        "premature_completion": {"type": "integer", "minimum": 1}
      }
    }
  }
}
