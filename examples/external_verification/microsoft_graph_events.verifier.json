{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Microsoft Graph calendar events using a read-only OAuth token.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "graph_events",
      "type": "microsoft_graph_events",
      "top": 50,
      "token_env": "MICROSOFT_GRAPH_TOKEN",
      "state_path": "graph.calendar"
    }
  ]
}
