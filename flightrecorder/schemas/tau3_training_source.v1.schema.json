{
  "$id": "https://schemas.hermes-flight-recorder.dev/tau3_training_source.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tau-3 Training-Side Task Source",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "hfr.tau3_training_source.v1"},
    "source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "domain": {"enum": ["airline", "retail", "telecom"]},
    "split": {"enum": ["train", "development"]},
    "task_family": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "task_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "task": {"type": "object"}
  },
  "required": ["schema_version", "source_revision", "domain", "split", "task_family", "task_sha256", "prompt_sha256", "task"]
}
