{
  "$id": "https://schemas.hermes-flight-recorder.dev/cloud_training_launch_plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Dry-run cloud training launch plan.",
  "properties": {
    "blocked_reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "check_count": {
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "created_at": {
      "type": "string"
    },
    "execution_boundary": {
      "$ref": "#/$defs/boundary"
    },
    "failed_check_count": {
      "type": "integer"
    },
    "handoff_contract": {
      "$ref": "#/$defs/handoffContract"
    },
    "launch": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "live_launch_supported": {
          "const": false
        },
        "mode": {
          "const": "dry_run"
        },
        "provider_api_call_planned": {
          "const": false
        }
      },
      "required": [
        "mode",
        "live_launch_supported",
        "provider_api_call_planned",
        "command"
      ],
      "type": "object"
    },
    "passed": {
      "type": "boolean"
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "provider_chain": {
      "additionalProperties": false,
      "properties": {
        "artifact_manifest_provider_id": {
          "type": "string"
        },
        "artifact_manifest_required": {
          "type": "boolean"
        },
        "mismatched_provider_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "preflight_provider_id": {
          "type": "string"
        },
        "provider_consistent": {
          "type": "boolean"
        }
      },
      "required": [
        "preflight_provider_id",
        "artifact_manifest_provider_id",
        "artifact_manifest_required",
        "provider_consistent",
        "mismatched_provider_ids"
      ],
      "type": "object"
    },
    "readiness": {
      "enum": [
        "ready_for_dry_run_launch",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "emit_dry_run_launch_receipt",
        "block_launch_receipt"
      ]
    },
    "schema_version": {
      "const": "hfr.cloud_training_launch_plan.v1"
    },
    "source_artifacts": {
      "additionalProperties": false,
      "properties": {
        "artifact_manifest": {
          "$ref": "#/$defs/sourceArtifact"
        },
        "preflight": {
          "$ref": "#/$defs/sourceArtifact"
        }
      },
      "required": [
        "preflight",
        "artifact_manifest"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "created_at",
    "provider",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "source_artifacts",
    "provider_chain",
    "launch",
    "execution_boundary",
    "handoff_contract"
  ],
  "title": "Hermes Flight Recorder Cloud Training Launch Plan",
  "type": "object",
  "$defs": {
    "boundary": {
      "additionalProperties": false,
      "properties": {
        "allow_live": {
          "const": false
        },
        "cloud_cost_incurred_usd": {
          "const": 0
        },
        "cloud_job_started": {
          "const": false
        },
        "credential_values_recorded": {
          "const": false
        },
        "dry_run_only": {
          "const": true
        },
        "live_preflight_requested": {
          "const": false
        },
        "live_requested": {
          "const": false
        },
        "model_downloads_started": {
          "const": false
        },
        "provider_api_called": {
          "const": false
        },
        "weights_updated_by_flight_recorder": {
          "const": false
        }
      },
      "required": [
        "dry_run_only",
        "live_preflight_requested",
        "live_requested",
        "allow_live",
        "provider_api_called",
        "cloud_job_started",
        "cloud_cost_incurred_usd",
        "model_downloads_started",
        "weights_updated_by_flight_recorder",
        "credential_values_recorded"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "actual",
        "expected",
        "summary"
      ],
      "type": "object"
    },
    "handoffContract": {
      "additionalProperties": false,
      "properties": {
        "default_live_execution_allowed": {
          "const": false
        },
        "external_provider_owns_execution": {
          "const": true
        },
        "flight_recorder_controls_preflight_only": {
          "const": true
        },
        "requires_artifact_upload_manifest": {
          "const": true
        },
        "requires_cost_limit": {
          "const": true
        },
        "requires_environment_credentials_for_live": {
          "const": true
        },
        "requires_explicit_live_opt_in": {
          "const": true
        },
        "requires_region_and_gpu_constraints": {
          "const": true
        },
        "requires_status_and_cancel_receipts": {
          "const": true
        }
      },
      "required": [
        "default_live_execution_allowed",
        "requires_explicit_live_opt_in",
        "requires_environment_credentials_for_live",
        "requires_cost_limit",
        "requires_region_and_gpu_constraints",
        "requires_artifact_upload_manifest",
        "requires_status_and_cancel_receipts",
        "flight_recorder_controls_preflight_only",
        "external_provider_owns_execution"
      ],
      "type": "object"
    },
    "provider": {
      "additionalProperties": false,
      "properties": {
        "adapter_contract": {
          "$ref": "#/$defs/adapterContract"
        },
        "artifact_protocols": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "client_import_names": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "credential_env_vars": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "default_live_execution_allowed": {
          "const": false
        },
        "display_name": {
          "type": "string"
        },
        "gpu_classes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "job_modes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "live_status": {
          "const": "preflight_only"
        },
        "regions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "display_name"
      ],
      "type": "object"
    },
    "adapterContract": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": {
          "minLength": 1,
          "type": "string"
        },
        "client_modules_imported_by_flight_recorder": {
          "const": false
        },
        "cloud_cost_incurred_usd": {
          "const": 0
        },
        "credential_values_recorded": {
          "const": false
        },
        "dry_run_transport": {
          "const": "mock_receipts"
        },
        "live_launch_supported": {
          "const": false
        },
        "live_preflight_supported": {
          "const": true
        },
        "live_preflight_transport": {
          "const": "metadata_only"
        },
        "model_downloads_started": {
          "const": false
        },
        "provider_api_called_by_flight_recorder": {
          "const": false
        },
        "provider_id": {
          "type": "string"
        },
        "receipt_types": {
          "items": {
            "enum": [
              "hfr.cloud_training_artifact_manifest.v1",
              "hfr.cloud_training_launch_plan.v1",
              "hfr.cloud_training_launch_receipt.v1",
              "hfr.cloud_training_preflight.v1",
              "hfr.cloud_training_provider_registry.v1",
              "hfr.cloud_training_status_receipt.v1"
            ],
            "type": "string"
          },
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "type": "array"
        },
        "requires_cost_limit": {
          "const": true
        },
        "requires_environment_credentials_for_live": {
          "const": true
        },
        "requires_explicit_live_opt_in": {
          "const": true
        },
        "requires_region_and_gpu_constraints": {
          "const": true
        },
        "schema_version": {
          "const": "hfr.cloud_training_provider_adapter.v1"
        },
        "status_cancel_receipts_supported": {
          "const": true
        },
        "weights_updated_by_flight_recorder": {
          "const": false
        }
      },
      "required": [
        "schema_version",
        "adapter_id",
        "provider_id",
        "receipt_types",
        "dry_run_transport",
        "live_preflight_transport",
        "live_preflight_supported",
        "live_launch_supported",
        "status_cancel_receipts_supported",
        "provider_api_called_by_flight_recorder",
        "client_modules_imported_by_flight_recorder",
        "credential_values_recorded",
        "cloud_cost_incurred_usd",
        "model_downloads_started",
        "weights_updated_by_flight_recorder",
        "requires_explicit_live_opt_in",
        "requires_environment_credentials_for_live",
        "requires_cost_limit",
        "requires_region_and_gpu_constraints"
      ],
      "type": "object"
    },
    "sourceArtifact": {
      "additionalProperties": false,
      "properties": {
        "exists": { "type": "boolean" },
        "path": { "type": "string" },
        "role": { "type": "string" },
        "schema_error_count": { "minimum": 0, "type": "integer" },
        "schema_errors": { "items": { "type": "string" }, "type": "array" },
        "schema_name": { "type": "string" },
        "schema_passed": { "type": "boolean" },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": ["string", "null"]
        },
        "size_bytes": { "minimum": 0, "type": ["integer", "null"] },
        "source_passed": { "type": ["boolean", "null"] },
        "source_recommendation": { "type": "string" }
      },
      "required": ["role", "path", "exists", "sha256", "size_bytes"],
      "type": "object"
    }
  }
}
