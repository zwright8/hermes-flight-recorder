{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Google Calendar events using a read-only OAuth token.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "calendar_events",
      "type": "google_calendar_events",
      "calendar_id": "primary",
      "time_min": "2026-06-29T00:00:00Z",
      "max_results": 50,
      "token_env": "GOOGLE_CALENDAR_ACCESS_TOKEN",
      "state_path": "calendar"
    }
  ]
}
