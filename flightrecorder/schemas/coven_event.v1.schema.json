{
  "$id": "https://schemas.hermes-flight-recorder.dev/coven_event.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Raw Coven stream-json frame, daemon/API event row, or Flight Recorder-wrapped Coven row.",
  "oneOf": [
    {
      "additionalProperties": true,
      "properties": {
        "type": {
          "enum": ["system", "user", "assistant", "tool_result", "result"]
        },
        "session_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["type", "session_id"],
      "type": "object"
    },
    {
      "additionalProperties": true,
      "anyOf": [
        {
          "required": ["payload_json"]
        },
        {
          "required": ["payload"]
        }
      ],
      "properties": {
        "created_at": {
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "type": "string"
        },
        "payload": {
          "type": "object"
        },
        "payload_json": {
          "type": "string"
        },
        "session_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["kind", "session_id"],
      "type": "object"
    },
    {
      "additionalProperties": true,
      "properties": {
        "event": {
          "type": "object"
        },
        "schema_version": {
          "const": "hfr.coven.event.v1"
        }
      },
      "required": ["schema_version", "event"],
      "type": "object"
    }
  ],
  "title": "Flight Recorder Coven Event",
  "type": "object"
}
