{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Google Drive files using a read-only OAuth token.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "drive_files",
      "type": "google_drive_files",
      "query": "name contains 'handoff'",
      "page_size": 50,
      "token_env": "GOOGLE_DRIVE_ACCESS_TOKEN",
      "state_path": "drive"
    }
  ]
}
