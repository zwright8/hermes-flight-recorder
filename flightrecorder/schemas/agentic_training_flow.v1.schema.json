{
  "$id": "https://schemas.hermes-flight-recorder.dev/agentic_training_flow.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Fail-closed delegated trainer-flow receipt for executable SFT, action-SFT, and DPO handoffs.",
  "properties": {
    "blocked_reasons": {
      "items": { "type": "string" },
      "type": "array"
    },
    "check_count": { "minimum": 0, "type": "integer" },
    "checks": {
      "items": { "$ref": "#/$defs/check" },
      "type": "array"
    },
    "created_at": { "minLength": 1, "type": "string" },
    "delegated_flow": { "$ref": "#/$defs/delegatedFlow" },
    "execution_boundary": { "$ref": "#/$defs/executionBoundary" },
    "failed_check_count": { "minimum": 0, "type": "integer" },
    "flow_mode_gate": { "$ref": "#/$defs/flowModeGate" },
    "flow_id": { "minLength": 1, "type": "string" },
    "flow_path": { "type": "string" },
    "handoff_contract": { "$ref": "#/$defs/handoffContract" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "mode_contract_check": { "$ref": "#/$defs/modeContractCheck" },
    "notes": {
      "items": { "type": "string" },
      "type": "array"
    },
    "passed": { "type": "boolean" },
    "readiness": { "enum": ["ready", "blocked"] },
    "recommendation": {
      "enum": ["ready_for_delegated_trainer_execution", "block_delegated_trainer_execution"]
    },
    "schema_version": { "const": "hfr.agentic_training_flow.v1" },
    "source_artifacts": { "$ref": "#/$defs/sourceArtifacts" }
  },
  "required": [
    "schema_version",
    "created_at",
    "flow_path",
    "flow_id",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "mode_contract_check",
    "flow_mode_gate",
    "source_artifacts",
    "delegated_flow",
    "metrics",
    "execution_boundary",
    "handoff_contract",
    "notes"
  ],
  "title": "Hermes Flight Recorder Agentic Training Flow",
  "type": "object",
  "$defs": {
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "type": "object" },
        "expected": { "type": "object" },
        "id": { "minLength": 1, "type": "string" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "command": {
      "additionalProperties": false,
      "properties": {
        "archive_root": { "type": "string" },
        "command_arg_count": { "minimum": 0, "type": "integer" },
        "command_argv": {
          "items": { "type": "string" },
          "type": "array"
        },
        "command_shell": { "type": "string" },
        "execution_cwd": { "type": "string" },
        "external_code_file_count": { "minimum": 0, "type": "integer" },
        "external_code_root": { "type": "string" },
        "trainer_input_count": { "minimum": 0, "type": "integer" }
      },
      "required": [
        "execution_cwd",
        "archive_root",
        "external_code_root",
        "command_argv",
        "command_shell",
        "trainer_input_count",
        "external_code_file_count"
      ],
      "type": "object"
    },
    "delegatedFlow": {
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "string" },
        "command": { "$ref": "#/$defs/command" },
        "mode": { "type": "string" },
        "stage_sequence": {
          "items": { "type": "string" },
          "type": "array"
        },
        "stages": {
          "items": { "$ref": "#/$defs/stage" },
          "type": "array"
        }
      },
      "required": ["mode", "backend", "stage_sequence", "stages", "command"],
      "type": "object"
    },
    "executionBoundary": {
      "additionalProperties": false,
      "properties": {
        "cloud_jobs_started": { "const": false },
        "credential_values_recorded": { "const": false },
        "flow_plan_only": { "const": true },
        "model_downloads_started": { "const": false },
        "subprocess_started": { "const": false },
        "trainer_command_executed": { "const": false },
        "trainer_modules_imported": { "const": false },
        "training_started": { "const": false },
        "weights_updated_by_flight_recorder": { "const": false }
      },
      "required": [
        "flow_plan_only",
        "training_started",
        "trainer_command_executed",
        "subprocess_started",
        "cloud_jobs_started",
        "model_downloads_started",
        "weights_updated_by_flight_recorder",
        "trainer_modules_imported",
        "credential_values_recorded"
      ],
      "type": "object"
    },
    "flowModeGate": {
      "additionalProperties": false,
      "properties": {
        "blocked_by_default": { "type": "boolean" },
        "category": { "type": "string" },
        "executable_by_default": { "type": "boolean" },
        "external_runner_must_supply_reward": { "type": "boolean" },
        "external_runner_must_validate_reward": { "type": "boolean" },
        "mode": { "type": "string" },
        "mode_contract_ready": { "type": "boolean" },
        "promotion_required": { "type": "boolean" },
        "promotion_status": {
          "enum": ["default_executable", "blocked_until_flow_promotion"]
        },
        "reason": { "type": "string" },
        "required_plan_opt_in_flag": { "type": ["string", "null"] },
        "reward_contract_kind": { "type": "string" }
      },
      "required": [
        "mode",
        "category",
        "executable_by_default",
        "blocked_by_default",
        "promotion_required",
        "promotion_status",
        "required_plan_opt_in_flag",
        "mode_contract_ready",
        "reward_contract_kind",
        "external_runner_must_supply_reward",
        "external_runner_must_validate_reward",
        "reason"
      ],
      "type": "object"
    },
    "handoffContract": {
      "additionalProperties": false,
      "properties": {
        "blocked_mode_categories": {
          "items": { "type": "string" },
          "type": "array"
        },
        "blocked_modes": {
          "items": { "type": "string" },
          "type": "array"
        },
        "blocked_mode_stages": {
          "items": { "type": "string" },
          "type": "array"
        },
        "executable_modes": {
          "items": { "type": "string" },
          "type": "array"
        },
        "flight_recorder_executed_trainer": { "const": false },
        "requires_mode_contract": { "const": true },
        "requires_mode_contract_ready": { "const": true },
        "requires_redacted_dataset": { "const": true },
        "requires_registered_model_and_dataset": { "const": true },
        "requires_runtime_preflight": { "const": true },
        "requires_trainer_consumer_plan": { "const": true },
        "runner_must_emit_result_schema": { "const": "hfr.agentic_training_result.v1" },
        "runner_must_require_recommendation": { "const": "ready_for_delegated_trainer_execution" },
        "runner_owns_execution": { "const": true }
      },
      "required": [
        "runner_owns_execution",
        "runner_must_require_recommendation",
        "runner_must_emit_result_schema",
        "requires_runtime_preflight",
        "requires_trainer_consumer_plan",
        "requires_mode_contract",
        "requires_mode_contract_ready",
        "requires_registered_model_and_dataset",
        "requires_redacted_dataset",
        "executable_modes",
        "blocked_modes",
        "blocked_mode_categories",
        "blocked_mode_stages",
        "flight_recorder_executed_trainer"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": false,
      "properties": {
        "check_count": { "minimum": 0, "type": "integer" },
        "command_arg_count": { "minimum": 0, "type": "integer" },
        "executable_stage_count": { "minimum": 0, "type": "integer" },
        "external_code_file_count": { "minimum": 0, "type": "integer" },
        "failed_check_count": { "minimum": 0, "type": "integer" },
        "selected_view_count": { "minimum": 0, "type": "integer" },
        "stage_count": { "minimum": 0, "type": "integer" },
        "trainer_input_count": { "minimum": 0, "type": "integer" }
      },
      "required": [
        "check_count",
        "failed_check_count",
        "stage_count",
        "executable_stage_count",
        "selected_view_count",
        "command_arg_count",
        "trainer_input_count",
        "external_code_file_count"
      ],
      "type": "object"
    },
    "modeContractCheck": {
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "data_requirement_count": { "minimum": 0, "type": "integer" },
        "error_count": { "minimum": 0, "type": "integer" },
        "errors": {
          "items": { "type": "string" },
          "type": "array"
        },
        "external_runner_contract": { "$ref": "#/$defs/modeExternalRunnerContract" },
        "mode": { "type": "string" },
        "mode_matches_plan": { "type": "boolean" },
        "passed": { "type": "boolean" },
        "planning_gate_open": { "type": "boolean" },
        "planning_required_flag": { "type": ["string", "null"] },
        "present": { "type": "boolean" },
        "reward_contract": { "$ref": "#/$defs/modeRewardContract" },
        "side_effect_boundary": { "$ref": "#/$defs/modeSideEffectBoundary" },
        "unsatisfied_data_requirement_ids": {
          "items": { "type": "string" },
          "type": "array"
        }
      },
      "required": [
        "mode",
        "category",
        "present",
        "mode_matches_plan",
        "planning_gate_open",
        "planning_required_flag",
        "data_requirement_count",
        "unsatisfied_data_requirement_ids",
        "reward_contract",
        "side_effect_boundary",
        "external_runner_contract",
        "passed",
        "error_count",
        "errors"
      ],
      "type": "object"
    },
    "modeExternalRunnerContract": {
      "additionalProperties": false,
      "properties": {
        "runner_must_block_unredacted_traces": { "type": "boolean" },
        "runner_must_require_recommendation": { "type": "string" },
        "runner_must_revalidate_inputs": { "type": "boolean" },
        "runner_must_validate_reward_contract": { "type": "boolean" },
        "runner_owns_execution": { "type": "boolean" }
      },
      "required": [
        "runner_owns_execution",
        "runner_must_revalidate_inputs",
        "runner_must_require_recommendation",
        "runner_must_validate_reward_contract",
        "runner_must_block_unredacted_traces"
      ],
      "type": "object"
    },
    "modeRewardContract": {
      "additionalProperties": false,
      "properties": {
        "callable_signature": { "type": "string" },
        "external_runner_must_supply": { "type": "boolean" },
        "external_runner_must_validate": { "type": "boolean" },
        "flight_recorder_supplies_callable": { "type": "boolean" },
        "kind": { "type": "string" },
        "may_call_paid_services_by_default": { "type": "boolean" },
        "may_require_secrets_by_default": { "type": "boolean" },
        "must_not_use_unredacted_traces": { "type": "boolean" },
        "required": { "type": "boolean" }
      },
      "required": [
        "kind",
        "required",
        "external_runner_must_supply",
        "external_runner_must_validate",
        "flight_recorder_supplies_callable",
        "may_call_paid_services_by_default",
        "may_require_secrets_by_default",
        "must_not_use_unredacted_traces",
        "callable_signature"
      ],
      "type": "object"
    },
    "modeSideEffectBoundary": {
      "additionalProperties": false,
      "properties": {
        "cloud_jobs_started": { "type": "boolean" },
        "dry_run_only": { "type": "boolean" },
        "model_downloads_started": { "type": "boolean" },
        "paid_model_grader_calls_started": { "type": "boolean" },
        "provider_credentials_required_by_flight_recorder": { "type": "boolean" },
        "training_started": { "type": "boolean" },
        "weights_updated": { "type": "boolean" }
      },
      "required": [
        "dry_run_only",
        "training_started",
        "cloud_jobs_started",
        "model_downloads_started",
        "paid_model_grader_calls_started",
        "weights_updated",
        "provider_credentials_required_by_flight_recorder"
      ],
      "type": "object"
    },
    "sourceArtifact": {
      "additionalProperties": false,
      "properties": {
        "exists": { "type": "boolean" },
        "passed": { "type": ["boolean", "null"] },
        "path": { "minLength": 1, "type": "string" },
        "recommendation": { "type": "string" },
        "regular_file": { "type": "boolean" },
        "role": { "minLength": 1, "type": "string" },
        "schema_version": { "type": "string" },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": ["string", "null"]
        },
        "size_bytes": {
          "minimum": 0,
          "type": ["integer", "null"]
        }
      },
      "required": [
        "role",
        "path",
        "exists",
        "regular_file",
        "schema_version",
        "passed",
        "recommendation",
        "sha256",
        "size_bytes"
      ],
      "type": "object"
    },
    "sourceArtifacts": {
      "additionalProperties": false,
      "properties": {
        "agentic_training_plan": { "$ref": "#/$defs/sourceArtifact" },
        "agentic_training_runtime_preflight": { "$ref": "#/$defs/sourceArtifact" },
        "trainer_consumer_plan": { "$ref": "#/$defs/sourceArtifact" }
      },
      "required": ["agentic_training_plan", "agentic_training_runtime_preflight", "trainer_consumer_plan"],
      "type": "object"
    },
    "stage": {
      "additionalProperties": false,
      "properties": {
        "row_count": { "minimum": 0, "type": "integer" },
        "stage_id": { "minLength": 1, "type": "string" },
        "stage_index": { "minimum": 0, "type": "integer" },
        "view_name": { "type": "string" },
        "view_path": { "type": "string" },
        "view_ready": { "type": "boolean" },
        "view_schema_version": { "type": "string" }
      },
      "required": ["stage_index", "stage_id", "view_name", "view_path", "view_schema_version", "row_count", "view_ready"],
      "type": "object"
    }
  }
}
