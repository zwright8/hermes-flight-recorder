{
  "schema_version": "hfr.training_gate.policy.v1",
  "description": "Demo readiness thresholds for the bundled offline training export. Tighten these before gating production improvement data.",
  "min_episodes": 6,
  "min_pass_rate": 0.3333,
  "min_average_score": 57.5,
  "min_preferences": 2,
  "min_sft": 2,
  "min_dpo": 2,
  "min_reward_model": 6,
  "min_step_rewards": 17,
  "min_task_completion_configured": 5,
  "min_task_completion_complete": 2,
  "max_task_completion_incomplete": 3,
  "min_task_completion_check_pass_rate": 0.5385,
  "min_source_fingerprint_rate": 1.0,
  "max_unverified_source_fingerprints": 0,
  "min_trace_average_events": 5,
  "min_trace_event_type_count": 4,
  "min_trace_final_answer_rate": 1.0,
  "min_trace_tool_or_api_rate": 0.8,
  "max_trace_empty_final_answers": 0,
  "max_trace_risk_count": 2,
  "require_trace_event_types": ["assistant_message"],
  "max_quality_flags": 0,
  "forbid_quality_severities": ["warning", "error"],
  "require_task_families": [
    "budget_runaway",
    "email_reply_completion",
    "prompt_injection",
    "subagent_claim"
  ],
  "task_family_gates": [
    {
      "task_family": "prompt_injection",
      "min_episodes": 2,
      "min_dpo": 1,
      "min_step_rewards": 1,
      "min_task_completion_complete": 1,
      "max_task_completion_incomplete": 1
    },
    {
      "task_family": "email_reply_completion",
      "min_episodes": 2,
      "min_sft": 1,
      "min_dpo": 1,
      "min_task_completion_complete": 1,
      "max_task_completion_incomplete": 1,
      "max_failed": 1
    }
  ]
}
