{
  "$id": "https://schemas.hermes-flight-recorder.dev/tau3_mlx_training_run.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Prelaunch or final receipt for a local MLX-LM QLoRA Tau-3 training run.",
  "properties": {
    "adapter": {
      "properties": {
        "path": {
          "$ref": "#/$defs/outputRelativePath"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "adapter_weight_file_count": {
      "minimum": 0,
      "type": "integer"
    },
    "bundle": {
      "type": "object"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "command": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "config": {
      "type": "object"
    },
    "created_at": {
      "minLength": 1,
      "type": "string"
    },
    "elapsed_seconds": {
      "minimum": 0,
      "type": "number"
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "interrupted": {
      "type": "boolean"
    },
    "losses": {
      "type": "object"
    },
    "mlx_lora_config": {
      "$ref": "#/$defs/outputFileRecord"
    },
    "output_dir": {
      "const": "."
    },
    "peak_child_rss_kb": {
      "minimum": 0,
      "type": "integer"
    },
    "phase": {
      "enum": [
        "prelaunch",
        "final"
      ]
    },
    "prelaunch_receipt": {
      "$ref": "#/$defs/outputFileRecord"
    },
    "schema_checked": {
      "type": "boolean"
    },
    "schema_version": {
      "const": "hfr.tau3_mlx_training_run.v1"
    },
    "telemetry": {
      "additionalProperties": true,
      "properties": {
        "path": {
          "$ref": "#/$defs/outputRelativePath"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "training_binding": {
      "description": "Cryptographic binding for mixture training protocol, local base model identity, dataset provenance, and deterministic recipe.",
      "type": [
        "object",
        "null"
      ]
    },
    "terminal_status": {
      "enum": [
        "prelaunch",
        "success",
        "crash",
        "timeout",
        "interrupted",
        "oom",
        "no_output"
      ]
    },
    "timed_out": {
      "type": "boolean"
    },
    "weights_updated": {
      "type": "boolean"
    }
  },
  "required": [
    "schema_version",
    "phase",
    "created_at",
    "bundle",
    "output_dir",
    "command",
    "config",
    "checks",
    "weights_updated",
    "terminal_status"
  ],
  "title": "Hermes Flight Recorder Tau-3 MLX Training Run",
  "type": "object",
  "$defs": {
    "check": {
      "additionalProperties": true,
      "properties": {
        "actual": {},
        "expected": {},
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "passed",
        "actual",
        "expected"
      ],
      "type": "object"
    },
    "outputFileRecord": {
      "additionalProperties": true,
      "properties": {
        "path": {
          "$ref": "#/$defs/outputRelativePath"
        },
        "read_only": {
          "type": "boolean"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "path",
        "read_only",
        "sha256"
      ],
      "type": "object"
    },
    "outputRelativePath": {
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "^[A-Za-z]:"
          },
          {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        ]
      },
      "type": "string"
    }
  }
}
