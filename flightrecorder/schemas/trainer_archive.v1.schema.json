{
  "$id": "https://schemas.hermes-flight-recorder.dev/trainer_archive.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Portable trainer handoff archive manifest with copied evidence artifact hashes.",
  "properties": {
    "archive_path": {
      "minLength": 1,
      "type": "string"
    },
    "approved_command": {
      "$ref": "#/$defs/approvedCommand"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "type": "array"
    },
    "consumer_contract": {
      "$ref": "#/$defs/consumerContract"
    },
    "launch_check_included": {
      "type": "boolean"
    },
    "manifest_path": {
      "minLength": 1,
      "type": "string"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "missing": {
      "items": {
        "$ref": "#/$defs/missing"
      },
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "passed": {
      "type": "boolean"
    },
    "path_rewrites": {
      "items": {
        "$ref": "#/$defs/pathRewrite"
      },
      "type": "array"
    },
    "portable_command": {
      "$ref": "#/$defs/portableCommand"
    },
    "readiness": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "ready_for_training": {
      "type": "boolean"
    },
    "recommendation": {
      "enum": [
        "handoff_ready",
        "block_handoff"
      ]
    },
    "relationships": {
      "items": {
        "$ref": "#/$defs/relationship"
      },
      "type": "array"
    },
    "require_self_contained": {
      "type": "boolean"
    },
    "schema_version": {
      "const": "hfr.trainer_archive.v1"
    },
    "self_contained": {
      "type": "boolean"
    },
    "trainer_inputs": {
      "items": {
        "$ref": "#/$defs/trainerInput"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "archive_path",
    "manifest_path",
    "passed",
    "readiness",
    "recommendation",
    "self_contained",
    "require_self_contained",
    "ready_for_training",
    "launch_check_included",
    "approved_command",
    "trainer_inputs",
    "path_rewrites",
    "portable_command",
    "consumer_contract",
    "artifacts",
    "missing",
    "relationships",
    "metrics",
    "notes"
  ],
  "title": "Hermes Flight Recorder Trainer Archive",
  "type": "object",
  "$defs": {
    "approvedCommand": {
      "additionalProperties": false,
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "parseable": {
          "type": "boolean"
        },
        "provided": {
          "type": "boolean"
        },
        "raw": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        }
      },
      "required": [
        "approved",
        "provided",
        "raw",
        "argv",
        "parseable",
        "shell"
      ],
      "type": "object"
    },
    "artifact": {
      "additionalProperties": false,
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "file_count": {
          "minimum": 0,
          "type": "integer"
        },
        "index": {
          "minimum": 0,
          "type": "integer"
        },
        "kind": {
          "enum": [
            "file",
            "directory"
          ]
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "original_path": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "role": {
          "enum": [
            "trainer_preflight",
            "trainer_launch_check",
            "gate",
            "validation_summary",
            "trainer_artifact",
            "schema_contract"
          ]
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "source_passed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "tree_hash_algorithm": {
          "type": "string"
        }
      },
      "required": [
        "index",
        "name",
        "role",
        "kind",
        "path",
        "original_path",
        "exists",
        "size_bytes",
        "sha256"
      ],
      "type": "object"
    },
    "countRow": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "minimum": 0,
          "type": "integer"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "count"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": false,
      "properties": {
        "artifact_count": {
          "minimum": 0,
          "type": "integer"
        },
        "directory_artifact_count": {
          "minimum": 0,
          "type": "integer"
        },
        "external_command_path_count": {
          "minimum": 0,
          "type": "integer"
        },
        "file_artifact_count": {
          "minimum": 0,
          "type": "integer"
        },
        "missing_count": {
          "minimum": 0,
          "type": "integer"
        },
        "missing_role_counts": {
          "items": {
            "$ref": "#/$defs/countRow"
          },
          "type": "array"
        },
        "role_counts": {
          "items": {
            "$ref": "#/$defs/countRow"
          },
          "type": "array"
        },
        "total_size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "path_rewrite_count": {
          "minimum": 0,
          "type": "integer"
        },
        "trainer_input_count": {
          "minimum": 0,
          "type": "integer"
        },
        "unique_sha256_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_count",
        "file_artifact_count",
        "directory_artifact_count",
        "trainer_input_count",
        "path_rewrite_count",
        "external_command_path_count",
        "missing_count",
        "total_size_bytes",
        "role_counts",
        "missing_role_counts",
        "unique_sha256_count"
      ],
      "type": "object"
    },
    "consumerContract": {
      "additionalProperties": false,
      "properties": {
        "command_kind": {
          "const": "advisory_portable_command"
        },
        "execution_cwd": {
          "const": "archive_root"
        },
        "external_code_required": {
          "type": "boolean"
        },
        "external_command_path_count": {
          "minimum": 0,
          "type": "integer"
        },
        "external_command_paths": {
          "items": {
            "$ref": "#/$defs/externalCommandPath"
          },
          "type": "array"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "path_rewrite_count": {
          "minimum": 0,
          "type": "integer"
        },
        "portable_command_available": {
          "type": "boolean"
        },
        "portable_command_rewritten": {
          "type": "boolean"
        },
        "trainer_input_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "execution_cwd",
        "command_kind",
        "portable_command_available",
        "portable_command_rewritten",
        "trainer_input_count",
        "path_rewrite_count",
        "external_code_required",
        "external_command_path_count",
        "external_command_paths",
        "notes"
      ],
      "type": "object"
    },
    "externalCommandPath": {
      "additionalProperties": false,
      "properties": {
        "argv_index": {
          "minimum": 0,
          "type": "integer"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "type": "string"
        },
        "token": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "argv_index",
        "token",
        "path",
        "reason"
      ],
      "type": "object"
    },
    "missing": {
      "additionalProperties": false,
      "properties": {
        "index": {
          "minimum": 0,
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "type": "string"
        },
        "role": {
          "enum": [
            "trainer_launch_check",
            "gate",
            "validation_summary",
            "trainer_artifact",
            "schema_contract"
          ]
        }
      },
      "required": [
        "role",
        "index",
        "reason"
      ],
      "type": "object"
    },
    "pathRewrite": {
      "additionalProperties": false,
      "properties": {
        "archive_path": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_name": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "enum": [
            "file",
            "directory"
          ]
        },
        "original_path": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "artifact_name",
        "kind",
        "original_path",
        "archive_path"
      ],
      "type": "object"
    },
    "portableCommand": {
      "additionalProperties": false,
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "available": {
          "type": "boolean"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "path_rewrite_count": {
          "minimum": 0,
          "type": "integer"
        },
        "rewritten": {
          "type": "boolean"
        },
        "shell": {
          "type": "string"
        }
      },
      "required": [
        "approved",
        "available",
        "rewritten",
        "path_rewrite_count",
        "argv",
        "shell",
        "notes"
      ],
      "type": "object"
    },
    "relationship": {
      "additionalProperties": false,
      "properties": {
        "from": {
          "minLength": 1,
          "type": "string"
        },
        "to": {
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "from",
        "to",
        "type"
      ],
      "type": "object"
    },
    "trainerInput": {
      "additionalProperties": false,
      "properties": {
        "archive_path": {
          "minLength": 1,
          "type": "string"
        },
        "artifact_index": {
          "minimum": 0,
          "type": "integer"
        },
        "artifact_name": {
          "minLength": 1,
          "type": "string"
        },
        "file_count": {
          "minimum": 0,
          "type": "integer"
        },
        "kind": {
          "enum": [
            "file",
            "directory"
          ]
        },
        "original_path": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "tree_hash_algorithm": {
          "type": "string"
        }
      },
      "required": [
        "artifact_index",
        "artifact_name",
        "kind",
        "original_path",
        "archive_path",
        "size_bytes",
        "sha256"
      ],
      "type": "object"
    }
  }
}
