{
  "$id": "https://schemas.hermes-flight-recorder.dev/external_eval_plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Fail-closed readiness plan for optional external eval harness adapters.",
  "properties": {
    "adapter_count": { "minimum": 0, "type": "integer" },
    "adapters": {
      "items": { "$ref": "#/$defs/adapter" },
      "type": "array"
    },
    "allow_installed": { "type": "boolean" },
    "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
    "generated_at": { "minLength": 1, "type": "string" },
    "governance_handoff": {
      "additionalProperties": false,
      "properties": {
        "external_eval_claims_allowed": { "type": "boolean" },
        "recommendation": { "minLength": 1, "type": "string" },
        "requires_identical_heldout_scenarios": { "type": "boolean" }
      },
      "required": ["external_eval_claims_allowed", "requires_identical_heldout_scenarios", "recommendation"],
      "type": "object"
    },
    "inputs": {
      "additionalProperties": false,
      "properties": {
        "inspect_task_set": { "type": ["string", "null"] },
        "lm_eval_task_list": { "items": { "type": "string" }, "type": "array" },
        "model": { "type": ["string", "null"] },
        "model_endpoint": { "type": ["string", "null"] },
        "sandbox_policy": { "type": ["string", "null"] },
        "scenario_manifest": { "$ref": "#/$defs/scenario_manifest_ref" },
        "swe_bench_task_set": { "type": ["string", "null"] },
        "tool_schema_set": { "type": ["string", "null"] }
      },
      "required": ["scenario_manifest", "model_endpoint", "model", "tool_schema_set", "inspect_task_set", "lm_eval_task_list", "swe_bench_task_set", "sandbox_policy"],
      "type": "object"
    },
    "ready": { "type": "boolean" },
    "ready_adapter_count": { "minimum": 0, "type": "integer" },
    "schema_version": { "const": "hfr.external_eval_adapters.v1" },
    "selected_adapters": {
      "items": { "enum": ["bfcl", "inspect_ai", "lm_eval_harness", "swe_bench"], "type": "string" },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "generated_at",
    "ready",
    "adapter_count",
    "ready_adapter_count",
    "selected_adapters",
    "allow_installed",
    "inputs",
    "adapters",
    "blocking_reasons",
    "governance_handoff"
  ],
  "title": "Hermes Flight Recorder External Eval Plan",
  "type": "object",
  "$defs": {
    "adapter": {
      "additionalProperties": false,
      "properties": {
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "adapter_contract": { "$ref": "#/$defs/adapterContract" },
        "dependency_status": { "$ref": "#/$defs/dependencyStatus" },
        "domain": { "minLength": 1, "type": "string" },
        "execution_contract": { "$ref": "#/$defs/executionContract" },
        "full_name": { "minLength": 1, "type": "string" },
        "id": { "enum": ["bfcl", "inspect_ai", "lm_eval_harness", "swe_bench"], "type": "string" },
        "name": { "minLength": 1, "type": "string" },
        "provided_inputs": { "items": { "type": "string" }, "type": "array" },
        "ready": { "type": "boolean" },
        "required_inputs": { "items": { "type": "string" }, "type": "array" },
        "suite_tags": { "items": { "type": "string" }, "type": "array" }
      },
      "required": [
        "id",
        "name",
        "full_name",
        "domain",
        "suite_tags",
        "required_inputs",
        "provided_inputs",
        "dependency_status",
        "execution_contract",
        "adapter_contract",
        "ready",
        "blocking_reasons"
      ],
      "type": "object"
    },
    "adapterContract": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "minLength": 1, "type": "string" },
        "cost_incurred_usd": { "const": 0 },
        "credential_values_recorded": { "const": false },
        "dry_run_transport": { "const": "plan_and_receipt_only" },
        "external_adapter_id": { "enum": ["bfcl", "inspect_ai", "lm_eval_harness", "swe_bench"], "type": "string" },
        "live_benchmark_supported": { "const": false },
        "model_downloads_started_by_flight_recorder": { "const": false },
        "provider_api_called_by_flight_recorder": { "const": false },
        "receipt_types": {
          "items": { "type": "string" },
          "minItems": 2,
          "type": "array"
        },
        "requires_dependency_probe_before_live": { "const": true },
        "requires_explicit_live_opt_in": { "const": true },
        "requires_external_runner_receipt_for_live": { "const": true },
        "requires_identical_heldout_scenarios": { "const": true },
        "schema_version": { "const": "hfr.external_eval_adapter_contract.v1" }
      },
      "required": [
        "schema_version",
        "adapter_id",
        "external_adapter_id",
        "receipt_types",
        "dry_run_transport",
        "live_benchmark_supported",
        "provider_api_called_by_flight_recorder",
        "model_downloads_started_by_flight_recorder",
        "credential_values_recorded",
        "cost_incurred_usd",
        "requires_identical_heldout_scenarios",
        "requires_external_runner_receipt_for_live",
        "requires_dependency_probe_before_live",
        "requires_explicit_live_opt_in"
      ],
      "type": "object"
    },
    "dependencyStatus": {
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "commands": {
          "additionalProperties": { "type": "boolean" },
          "type": "object"
        },
        "imports": {
          "additionalProperties": { "type": "boolean" },
          "type": "object"
        }
      },
      "required": ["available", "imports", "commands"],
      "type": "object"
    },
    "executionContract": {
      "additionalProperties": false,
      "properties": {
        "boundary": { "minLength": 1, "type": "string" },
        "requires_identical_heldout_scenarios": { "const": true },
        "scenario_manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": ["string", "null"]
        }
      },
      "required": ["requires_identical_heldout_scenarios", "scenario_manifest_sha256", "boundary"],
      "type": "object"
    },
    "scenario_manifest_ref": {
      "additionalProperties": false,
      "properties": {
        "exists": { "type": "boolean" },
        "path": { "type": ["string", "null"] },
        "ready": { "type": ["boolean", "null"] },
        "scenario_count": { "type": ["integer", "null"], "minimum": 0 },
        "schema_version": { "type": ["string", "null"] },
        "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 }
      },
      "required": ["path", "exists", "sha256", "size_bytes", "schema_version", "ready", "scenario_count"],
      "type": "object"
    }
  }
}
