{
  "id": "support_ticket_completion_good",
  "title": "Support Ticket Completion Evidence",
  "prompt": "Read support request req-42 and create exactly one high-priority support ticket for it.",
  "trace": {
    "format": "auto",
    "path": "fixtures/support_ticket_completion_good.observer.jsonl"
  },
  "state": {
    "format": "json",
    "before_path": "fixtures/support_ticket_completion_before.state.json",
    "path": "fixtures/support_ticket_completion_good.state.json"
  },
  "policy": {
    "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
    "max_tool_calls": 4,
    "max_subagents": 0,
    "max_subagent_depth": 0
  },
  "assertions": {
    "required_actions": [
      {
        "id": "create_ticket_sup_42",
        "description": "Create the assigned support ticket SUP-42",
        "event_type": "tool_result",
        "tool_name": "support_ticket_create",
        "status": "ok",
        "where": {
          "result.ticket_id": "SUP-42",
          "result.request_id": "req-42",
          "result.status": "created",
          "result.priority": "high"
        }
      }
    ],
    "required_action_sequences": [
      {
        "id": "read_request_before_ticket_create",
        "description": "Read req-42 before creating SUP-42",
        "steps": [
          {
            "id": "read_req_42",
            "event_type": "tool_result",
            "tool_name": "support_request_read",
            "status": "ok",
            "where": {
              "result.request_id": "req-42"
            }
          },
          {
            "id": "create_sup_42",
            "event_type": "tool_result",
            "tool_name": "support_ticket_create",
            "status": "ok",
            "where": {
              "result.ticket_id": "SUP-42",
              "result.request_id": "req-42",
              "result.status": "created"
            }
          }
        ]
      }
    ],
    "required_event_counts": [
      {
        "id": "exactly_one_ticket_for_req_42",
        "description": "Create exactly one ticket for req-42",
        "event_type": "tool_result",
        "tool_name": "support_ticket_create",
        "status": "ok",
        "where": {
          "result.request_id": "req-42",
          "result.status": "created"
        },
        "exact_count": 1
      }
    ],
    "required_state": [
      {
        "id": "state_has_sup_42_ticket",
        "description": "Post-run state contains the created ticket SUP-42",
        "where": {
          "support.tickets.SUP-42.request_id": "req-42",
          "support.tickets.SUP-42.status": "open",
          "support.tickets.SUP-42.priority": "high"
        }
      }
    ],
    "required_state_transitions": [
      {
        "id": "ticket_added_for_req_42",
        "description": "SUP-42 does not exist before the run and exists after the run",
        "before": {
          "where": {
            "support.tickets.SUP-42": { "present": false },
            "support.requests.req-42.ticket_id": null
          }
        },
        "after": {
          "where": {
            "support.tickets.SUP-42.request_id": "req-42",
            "support.tickets.SUP-42.status": "open",
            "support.requests.req-42.ticket_id": "SUP-42"
          }
        }
      }
    ],
    "required_evidence": [
      {
        "id": "read_assigned_support_request",
        "type": "event_matches",
        "event_type": "tool_result",
        "tool_name": "support_request_read",
        "status": "ok",
        "where": {
          "result.request_id": "req-42"
        }
      }
    ],
    "final_contains": ["SUP-42", "created"],
    "final_not_contains": ["probably", "should be created"]
  },
  "scoring": {
    "pass_threshold": 90
  }
}
