{
  "$id": "https://schemas.hermes-flight-recorder.dev/eval_summary.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Governance-facing held-out evaluation summary across suite, comparison, gate, and external-adapter artifacts.",
  "properties": {
    "arm_count": { "minimum": 0, "type": "integer" },
    "arms": {
      "items": { "$ref": "#/$defs/arm" },
      "type": "array"
    },
    "compare_gates": {
      "items": { "$ref": "#/$defs/gate" },
      "type": "array"
    },
    "comparison_count": { "minimum": 0, "type": "integer" },
    "comparisons": {
      "items": { "$ref": "#/$defs/comparison" },
      "type": "array"
    },
    "conclusion": { "$ref": "#/$defs/conclusion" },
    "external_adapter_plan_count": { "minimum": 0, "type": "integer" },
    "external_adapter_result_count": { "minimum": 0, "type": "integer" },
    "external_adapter_plans": {
      "items": { "$ref": "#/$defs/external_adapter_plan" },
      "type": "array"
    },
    "external_adapter_results": {
      "items": { "$ref": "#/$defs/external_adapter_result" },
      "type": "array"
    },
    "gate_count": { "minimum": 0, "type": "integer" },
    "generated_at": { "minLength": 1, "type": "string" },
    "governance_ready": { "type": "boolean" },
    "heldout_scenarios": { "$ref": "#/$defs/heldout_scenarios" },
    "passed": { "type": "boolean" },
    "repair_curriculum": { "$ref": "#/$defs/repair_curriculum" },
    "risks": {
      "items": { "$ref": "#/$defs/risk" },
      "type": "array"
    },
    "schema_version": { "const": "hfr.eval_summary.v1" },
    "serving_preflight": { "$ref": "#/$defs/serving_preflight_summary" }
  },
  "required": [
    "schema_version",
    "generated_at",
    "passed",
    "governance_ready",
    "arm_count",
    "comparison_count",
    "gate_count",
    "external_adapter_plan_count",
    "external_adapter_result_count",
    "heldout_scenarios",
    "arms",
    "comparisons",
    "compare_gates",
    "external_adapter_plans",
    "external_adapter_results",
    "repair_curriculum",
    "risks",
    "conclusion"
  ],
  "title": "Hermes Flight Recorder Eval Summary",
  "type": "object",
  "$defs": {
    "arm": {
      "additionalProperties": false,
      "properties": {
        "average_score": { "type": ["number", "null"] },
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "critical_failure_counts": { "items": { "type": "object" }, "type": "array" },
        "error_count": { "minimum": 0, "type": "integer" },
        "failed": { "minimum": 0, "type": "integer" },
        "failed_rule_counts": { "items": { "type": "object" }, "type": "array" },
        "label": { "minLength": 1, "type": "string" },
        "operational_metrics": { "type": "object" },
        "pass_rate": { "type": ["number", "null"] },
        "passed": { "minimum": 0, "type": "integer" },
        "path": { "minLength": 1, "type": "string" },
        "scenario_count": { "minimum": 0, "type": "integer" },
        "scenario_ids": { "items": { "type": "string" }, "type": "array" },
        "schema_version": { "type": ["string", "null"] },
        "serving_preflight": { "$ref": "#/$defs/serving_preflight" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" },
        "source_validation": { "$ref": "#/$defs/validation_summary" },
        "total": { "minimum": 0, "type": "integer" },
        "validation": {
          "anyOf": [
            { "$ref": "#/$defs/validation_summary" },
            { "type": "null" }
          ]
        }
      },
      "required": ["label", "path", "sha256", "size_bytes", "scenario_count", "scenario_ids", "total", "passed", "failed", "error_count", "validation", "source_validation", "blocking_reasons"],
      "type": "object"
    },
    "comparison": {
      "additionalProperties": false,
      "properties": {
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "claims_allowed": { "type": "boolean" },
        "governance_claims": { "$ref": "#/$defs/governance_claims" },
        "label": { "minLength": 1, "type": "string" },
        "manifest": { "minLength": 1, "type": "string" },
        "manifest_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "manifest_size_bytes": { "minimum": 0, "type": "integer" },
        "passed": { "type": "boolean" },
        "path": { "minLength": 1, "type": "string" },
        "raw_movement": { "$ref": "#/$defs/raw_movement" },
        "schema_version": { "type": ["string", "null"] }
      },
      "required": ["label", "path", "manifest", "manifest_sha256", "manifest_size_bytes", "claims_allowed", "passed", "blocking_reasons", "raw_movement", "governance_claims"],
      "type": "object"
    },
    "conclusion": {
      "additionalProperties": false,
      "properties": {
        "recommendation": { "minLength": 1, "type": "string" },
        "risk_count": { "minimum": 0, "type": "integer" },
        "status": { "enum": ["ready", "blocked"], "type": "string" }
      },
      "required": ["status", "recommendation"],
      "type": "object"
    },
    "external_adapter_plan": {
      "additionalProperties": false,
      "properties": {
        "adapter_count": { "minimum": 0, "type": "integer" },
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "label": { "minLength": 1, "type": "string" },
        "path": { "minLength": 1, "type": "string" },
        "ready": { "type": "boolean" },
        "ready_adapter_count": { "minimum": 0, "type": "integer" },
        "selected_adapters": { "items": { "type": "string" }, "type": "array", "uniqueItems": true },
        "schema_version": { "type": ["string", "null"] },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["label", "path", "sha256", "size_bytes", "ready", "adapter_count", "ready_adapter_count", "selected_adapters", "blocking_reasons"],
      "type": "object"
    },
    "external_adapter_result": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "minLength": 1, "type": "string" },
        "benchmark_status": { "enum": ["passed", "failed", "inconclusive", "not_available"] },
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "coverage_complete": { "type": "boolean" },
        "execution_status": { "enum": ["completed", "incomplete", "failed"] },
        "external_eval_claims_allowed": { "type": "boolean" },
        "governance_readiness": { "enum": ["ready_for_review", "blocked"] },
        "heldout_manifest_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "integrity_passed": { "type": "boolean" },
        "label": { "minLength": 1, "type": "string" },
        "model_id": { "minLength": 1, "type": "string" },
        "path": { "minLength": 1, "type": "string" },
        "schema_version": { "const": "hfr.external_eval_result.v1" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" },
        "source_plan_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" }
      },
      "required": [
        "label", "path", "sha256", "size_bytes", "schema_version", "adapter_id", "model_id",
        "source_plan_sha256", "heldout_manifest_sha256", "integrity_passed", "execution_status",
        "benchmark_status", "coverage_complete", "governance_readiness", "external_eval_claims_allowed",
        "blocking_reasons"
      ],
      "type": "object"
    },
    "gate": {
      "additionalProperties": false,
      "properties": {
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "check_count": { "minimum": 0, "type": "integer" },
        "failed_check_count": { "minimum": 0, "type": "integer" },
        "failed_checks": { "items": { "type": "object" }, "type": "array" },
        "label": { "minLength": 1, "type": "string" },
        "passed": { "type": "boolean" },
        "path": { "minLength": 1, "type": "string" },
        "schema_version": { "type": ["string", "null"] },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["label", "path", "sha256", "size_bytes", "passed", "check_count", "failed_check_count", "failed_checks", "blocking_reasons"],
      "type": "object"
    },
    "heldout_scenarios": {
      "additionalProperties": false,
      "properties": {
        "arms": { "items": { "type": "object" }, "type": "array" },
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "cross_arm_claims_allowed": { "type": "boolean" },
        "identical": { "type": "boolean" },
        "mismatches": { "items": { "type": "object" }, "type": "array" },
        "scenario_count": { "minimum": 0, "type": "integer" },
        "scenario_ids": { "items": { "type": "string" }, "type": "array" },
        "status": {
          "enum": ["missing_suite_summaries", "single_arm", "identical", "mismatched", "empty", "blocked"],
          "type": "string"
        }
      },
      "required": ["status", "identical", "cross_arm_claims_allowed", "scenario_count", "scenario_ids", "arms", "mismatches", "blocking_reasons"],
      "type": "object"
    },
    "governance_claims": {
      "additionalProperties": false,
      "properties": {
        "candidate_win_count": { "minimum": 0, "type": "integer" },
        "candidate_win_scenarios": { "items": { "type": "string" }, "type": "array" },
        "suppressed_raw_claims": { "type": "boolean" },
        "suppression_reasons": { "items": { "type": "string" }, "type": "array" },
        "task_completion_improvement_count": { "minimum": 0, "type": "integer" },
        "task_completion_improvement_scenarios": { "items": { "type": "string" }, "type": "array" }
      },
      "required": [
        "candidate_win_count",
        "candidate_win_scenarios",
        "task_completion_improvement_count",
        "task_completion_improvement_scenarios",
        "suppressed_raw_claims",
        "suppression_reasons"
      ],
      "type": "object"
    },
    "raw_movement": {
      "additionalProperties": false,
      "properties": {
        "baseline_win_count": { "minimum": 0, "type": "integer" },
        "baseline_win_scenarios": { "items": { "type": "string" }, "type": "array" },
        "candidate_win_count": { "minimum": 0, "type": "integer" },
        "candidate_win_scenarios": { "items": { "type": "string" }, "type": "array" },
        "contract_drift_count": { "minimum": 0, "type": "integer" },
        "fixed_rule_counts": { "additionalProperties": { "minimum": 0, "type": "integer" }, "type": "object" },
        "missing_in_candidate": { "items": { "type": "string" }, "type": "array" },
        "new_critical_failure_counts": { "additionalProperties": { "minimum": 0, "type": "integer" }, "type": "object" },
        "new_in_candidate": { "items": { "type": "string" }, "type": "array" },
        "pair_count": { "minimum": 0, "type": "integer" },
        "regressed_rule_counts": { "additionalProperties": { "minimum": 0, "type": "integer" }, "type": "object" },
        "skipped_pair_count": { "minimum": 0, "type": "integer" },
        "task_completion_improvement_count": { "minimum": 0, "type": "integer" },
        "task_completion_improvement_scenarios": { "items": { "type": "string" }, "type": "array" },
        "task_completion_regression_count": { "minimum": 0, "type": "integer" },
        "task_completion_regression_scenarios": { "items": { "type": "string" }, "type": "array" },
        "unverified_contract_count": { "minimum": 0, "type": "integer" }
      },
      "required": [
        "pair_count",
        "candidate_win_count",
        "baseline_win_count",
        "candidate_win_scenarios",
        "baseline_win_scenarios",
        "task_completion_improvement_count",
        "task_completion_regression_count",
        "task_completion_improvement_scenarios",
        "task_completion_regression_scenarios",
        "fixed_rule_counts",
        "regressed_rule_counts",
        "new_critical_failure_counts",
        "contract_drift_count",
        "unverified_contract_count",
        "skipped_pair_count",
        "missing_in_candidate",
        "new_in_candidate"
      ],
      "type": "object"
    },
    "repair_curriculum": {
      "additionalProperties": false,
      "properties": {
        "category_counts": { "items": { "type": "object" }, "type": "array" },
        "critical_work_item_count": { "minimum": 0, "type": "integer" },
        "items": { "items": { "$ref": "#/$defs/work_item" }, "type": "array" },
        "notes": { "items": { "type": "string" }, "type": "array" },
        "priority_counts": { "items": { "type": "object" }, "type": "array" },
        "work_item_count": { "minimum": 0, "type": "integer" }
      },
      "required": ["work_item_count", "critical_work_item_count", "priority_counts", "category_counts", "items", "notes"],
      "type": "object"
    },
    "risk": {
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "reason": { "minLength": 1, "type": "string" },
        "source": { "minLength": 1, "type": "string" }
      },
      "required": ["source", "reason"],
      "type": "object"
    },
    "serving_preflight": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "provided": { "const": true } },
            "required": ["provided"]
          },
          "then": {
            "required": ["path", "sha256", "size_bytes"]
          }
        }
      ],
      "properties": {
        "artifacts": { "type": "object" },
        "base_url": { "type": "string" },
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "failed_checks": { "items": { "type": "string" }, "type": "array" },
        "model": { "type": "string" },
        "passed": { "type": "boolean" },
        "path": { "type": ["string", "null"] },
        "profile_id": { "type": "string" },
        "provided": { "type": "boolean" },
        "readiness": { "enum": ["ready", "blocked", "missing"], "type": "string" },
        "required": { "type": "boolean" },
        "schema_version": { "type": ["string", "null"] },
        "served_model_id": { "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["provided", "required", "passed", "readiness", "failed_checks", "artifacts", "blocking_reasons"],
      "type": "object"
    },
    "serving_preflight_summary": {
      "additionalProperties": false,
      "properties": {
        "attached_count": { "minimum": 0, "type": "integer" },
        "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
        "duplicate_labels": { "items": { "type": "string" }, "type": "array" },
        "input_count": { "minimum": 0, "type": "integer" },
        "required": { "type": "boolean" },
        "unmatched_labels": { "items": { "type": "string" }, "type": "array" }
      },
      "required": ["required", "input_count", "attached_count", "unmatched_labels", "duplicate_labels", "blocking_reasons"],
      "type": "object"
    },
    "validation_summary": {
      "additionalProperties": false,
      "properties": {
        "error_count": { "minimum": 0, "type": "integer" },
        "passed": { "type": "boolean" },
        "target_count": { "minimum": 0, "type": "integer" },
        "warning_count": { "minimum": 0, "type": "integer" }
      },
      "required": ["passed", "target_count", "error_count", "warning_count"],
      "type": "object"
    },
    "work_item": {
      "additionalProperties": false,
      "properties": {
        "category": { "enum": ["repair", "curriculum", "eval_gate", "eval_harness"], "type": "string" },
        "count": { "minimum": 0, "type": "integer" },
        "label": { "minLength": 1, "type": "string" },
        "priority": { "enum": ["critical", "high", "medium", "low"], "type": "string" },
        "reason": { "minLength": 1, "type": "string" },
        "rule_id": { "type": "string" },
        "scenario_id": { "type": "string" },
        "source": { "minLength": 1, "type": "string" },
        "suggested_action": { "minLength": 1, "type": "string" },
        "summary": { "minLength": 1, "type": "string" },
        "work_item_id": { "pattern": "^eval-[0-9a-f]{16}$", "type": "string" }
      },
      "required": ["category", "priority", "source", "label", "reason", "summary", "suggested_action", "work_item_id"],
      "type": "object"
    }
  }
}
