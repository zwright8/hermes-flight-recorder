{
  "$id": "https://schemas.hermes-flight-recorder.dev/harness_run_result.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Harness run result linking sandbox, tool policy, trace, scorecard, and replay artifacts.",
  "properties": {
    "artifacts": {
      "additionalProperties": true,
      "properties": {
        "lineage": { "minLength": 1, "type": "string" },
        "lineage_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "lineage_size_bytes": { "minimum": 0, "type": "integer" },
        "normalized_trace": { "minLength": 1, "type": "string" },
        "normalized_trace_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "normalized_trace_size_bytes": { "minimum": 0, "type": "integer" },
        "report": { "minLength": 1, "type": "string" },
        "report_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "report_size_bytes": { "minimum": 0, "type": "integer" },
        "run_digest": { "minLength": 1, "type": "string" },
        "run_digest_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "run_digest_size_bytes": { "minimum": 0, "type": "integer" },
        "scorecard": { "minLength": 1, "type": "string" },
        "scorecard_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "scorecard_size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": [
        "normalized_trace",
        "normalized_trace_sha256",
        "normalized_trace_size_bytes",
        "scorecard",
        "scorecard_sha256",
        "scorecard_size_bytes",
        "run_digest",
        "run_digest_sha256",
        "run_digest_size_bytes",
        "report",
        "report_sha256",
        "report_size_bytes",
        "lineage",
        "lineage_sha256",
        "lineage_size_bytes"
      ],
      "type": "object"
    },
    "created_at": { "type": "string" },
    "fake_secret_canary_check": {
      "additionalProperties": true,
      "properties": {
        "canary_count": { "minimum": 0, "type": "integer" },
        "checked_artifact_count": { "minimum": 0, "type": "integer" },
        "checked_artifacts": {
          "items": {
            "$ref": "#/$defs/canary_artifact"
          },
          "type": "array"
        },
        "leaked_artifacts": {
          "items": {
            "$ref": "#/$defs/leaked_canary_artifact"
          },
          "type": "array"
        },
        "passed": { "type": "boolean" }
      },
      "required": ["passed", "canary_count", "checked_artifact_count", "checked_artifacts", "leaked_artifacts"],
      "type": "object"
    },
    "model": { "type": "object" },
    "provider": { "minLength": 1, "type": "string" },
    "replay": {
      "additionalProperties": true,
      "properties": {
        "command": { "type": "string" },
        "lineage": { "minLength": 1, "type": "string" },
        "lineage_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "lineage_size_bytes": { "minimum": 0, "type": "integer" },
        "self_contained": { "type": "boolean" }
      },
      "required": ["lineage", "lineage_sha256", "lineage_size_bytes", "self_contained"],
      "type": "object"
    },
    "runner": { "minLength": 1, "type": "string" },
    "sandbox": { "type": "object" },
    "scenario_id": { "minLength": 1, "type": "string" },
    "schema_version": { "const": "hfr.harness_run_result.v1" },
    "scorecard": {
      "additionalProperties": true,
      "properties": {
        "passed": { "type": "boolean" },
        "path": { "minLength": 1, "type": "string" },
        "score": { "type": "number" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["path", "sha256", "size_bytes", "passed", "score"],
      "type": "object"
    },
    "tool_policy": {
      "additionalProperties": true,
      "properties": {
        "blocked_action_canaries": {
          "items": {
            "additionalProperties": true,
            "properties": {
              "expected": { "minLength": 1, "type": "string" },
              "pattern": { "minLength": 1, "type": "string" },
              "type": { "minLength": 1, "type": "string" }
            },
            "required": ["type", "pattern", "expected"],
            "type": "object"
          },
          "type": "array"
        },
        "runtime_policy": {
          "additionalProperties": true,
          "properties": {
            "allowed_tools": {
              "items": { "type": "string" },
              "type": "array"
            },
            "denied_tools": {
              "items": { "type": "string" },
              "type": "array"
            },
            "mode": { "minLength": 1, "type": "string" },
            "network": {
              "additionalProperties": true,
              "properties": {
                "allowed_hosts": {
                  "items": { "type": "string" },
                  "type": "array"
                },
                "mode": { "minLength": 1, "type": "string" }
              },
              "required": ["mode"],
              "type": "object"
            }
          },
          "required": ["mode"],
          "type": "object"
        },
        "scenario_policy": { "type": "object" },
        "source": { "minLength": 1, "type": "string" }
      },
      "required": ["source", "scenario_policy", "runtime_policy", "blocked_action_canaries"],
      "type": "object"
    },
    "trace": {
      "additionalProperties": true,
      "properties": {
        "format": { "minLength": 1, "type": "string" },
        "path": { "minLength": 1, "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["format", "path", "sha256", "size_bytes"],
      "type": "object"
    }
  },
  "$defs": {
    "canary_artifact": {
      "additionalProperties": true,
      "oneOf": [
        {
          "properties": {
            "exists": { "const": true }
          },
          "required": ["artifact", "path", "exists", "sha256", "size_bytes"],
          "type": "object"
        },
        {
          "properties": {
            "exists": { "const": false }
          },
          "required": ["artifact", "path", "exists"],
          "type": "object"
        }
      ],
      "properties": {
        "artifact": { "minLength": 1, "type": "string" },
        "exists": { "type": "boolean" },
        "path": { "minLength": 1, "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["artifact", "path", "exists"],
      "type": "object"
    },
    "leaked_canary_artifact": {
      "allOf": [
        { "$ref": "#/$defs/canary_artifact" },
        {
          "additionalProperties": true,
          "properties": {
            "canary_names": {
              "items": { "minLength": 1, "type": "string" },
              "minItems": 1,
              "type": "array"
            }
          },
          "required": ["canary_names"],
          "type": "object"
        }
      ]
    }
  },
  "required": ["schema_version", "runner", "provider", "model", "scenario_id", "sandbox", "tool_policy", "trace", "scorecard", "artifacts", "replay"],
  "title": "Hermes Flight Recorder Harness Run Result",
  "type": "object"
}
