{
  "$id": "https://schemas.hermes-flight-recorder.dev/agentic_loop_ledger.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Longitudinal ledger over closed-loop agentic training iteration plans.",
  "properties": {
    "decision": {
      "additionalProperties": false,
      "properties": {
        "blocked_iteration_count": { "minimum": 0, "type": "integer" },
        "governance_action_count": { "minimum": 0, "type": "integer" },
        "governance_actions": {
          "items": { "$ref": "#/$defs/governance_action" },
          "type": "array"
        },
        "latest_iteration_id": { "minLength": 1, "type": "string" },
        "latest_iteration_index": { "minimum": 0, "type": "integer" },
        "readiness": { "enum": ["ready", "blocked"], "type": "string" },
        "recommendation": { "enum": ["ready_for_governance_review", "continue_iteration"], "type": "string" },
        "recommended_governance_action": {
          "enum": ["approve", "reject", "rollback", "request_another_iteration"],
          "type": "string"
        },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": [
        "readiness",
        "recommendation",
        "recommended_governance_action",
        "governance_action_count",
        "governance_actions",
        "summary",
        "latest_iteration_index",
        "latest_iteration_id",
        "blocked_iteration_count"
      ],
      "type": "object"
    },
    "execution_boundary": {
      "additionalProperties": false,
      "properties": {
        "cloud_jobs_started": { "const": false },
        "credential_values_recorded": { "const": false },
        "ledger_only": { "const": true },
        "live_benchmarks_started": { "const": false },
        "model_downloads_started": { "const": false },
        "paid_model_grader_calls_started": { "const": false },
        "weights_updated_by_flight_recorder": { "const": false }
      },
      "required": [
        "ledger_only",
        "cloud_jobs_started",
        "paid_model_grader_calls_started",
        "live_benchmarks_started",
        "model_downloads_started",
        "weights_updated_by_flight_recorder",
        "credential_values_recorded"
      ],
      "type": "object"
    },
    "iteration_count": { "minimum": 1, "type": "integer" },
    "iterations": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "artifact_count": { "minimum": 0, "type": "integer" },
          "artifact_group_counts": {
            "items": { "$ref": "#/$defs/group_count" },
            "type": "array"
          },
          "blocked_reason_count": { "minimum": 0, "type": "integer" },
          "cloud_training": { "$ref": "#/$defs/group_summary" },
          "cloud_training_receipt_state": { "$ref": "#/$defs/cloud_training_receipt_state" },
          "cloud_training_lineage": { "$ref": "#/$defs/cloud_training_lineage" },
          "cost_estimate": { "type": "object" },
          "evals": { "type": "object" },
          "exists": { "const": true },
          "governance": { "type": "object" },
          "index": { "minimum": 0, "type": "integer" },
          "iteration_id": { "minLength": 1, "type": "string" },
          "missing_phase_inputs": {
            "items": { "type": "string" },
            "type": "array"
          },
          "next_actions": { "type": "object" },
          "passed": { "type": "boolean" },
          "path": { "minLength": 1, "type": "string" },
          "phase_status_counts": {
            "items": { "$ref": "#/$defs/id_count" },
            "type": "array"
          },
          "readiness": { "minLength": 1, "type": "string" },
          "recommendation": { "minLength": 1, "type": "string" },
          "schema_version": { "const": "hfr.agentic_training_loop_plan.v1" },
          "serving": { "type": "object" },
          "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
          "size_bytes": { "minimum": 0, "type": "integer" },
          "training_outputs": { "type": "object" }
        },
        "required": [
          "index",
          "path",
          "exists",
          "schema_version",
          "iteration_id",
          "passed",
          "readiness",
          "recommendation",
          "missing_phase_inputs",
          "blocked_reason_count",
          "artifact_count",
          "phase_status_counts",
          "artifact_group_counts",
          "artifact_role_counts",
          "cloud_training",
          "cloud_training_receipt_state",
          "cloud_training_lineage",
          "cost_estimate",
          "serving",
          "evals",
          "training_outputs",
          "governance",
          "next_actions",
          "size_bytes",
          "sha256"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "ledger_path": { "type": "string" },
    "metrics": { "$ref": "#/$defs/metrics" },
    "notes": {
      "items": { "type": "string" },
      "type": "array"
    },
    "passed": { "type": "boolean" },
    "readiness_digest": {
      "additionalProperties": false,
      "description": "Operator-facing latest-iteration readiness summary derived from the ledger only.",
      "properties": {
        "blocked_reason_count": { "minimum": 0, "type": "integer" },
        "cloud_training_ambiguous_link_count": { "minimum": 0, "type": "integer" },
        "cloud_training_duplicate_role_count": { "minimum": 0, "type": "integer" },
        "cloud_training_lineage_bound": { "type": "boolean" },
        "cloud_training_receipts_fail_closed": { "type": "boolean" },
        "cloud_training_live_launch_requested": { "type": "boolean" },
        "cloud_training_cost_incurred_usd": { "minimum": 0, "type": "number" },
        "cloud_training_launch_mode": { "type": "string" },
        "cloud_training_status_provider_status": { "type": "string" },
        "cloud_training_mismatched_link_count": { "minimum": 0, "type": "integer" },
        "cloud_training_missing_link_count": { "minimum": 0, "type": "integer" },
        "cloud_training_provider_id": { "type": "string" },
        "decision_readiness": { "minLength": 1, "type": "string" },
        "decision_recommendation": { "minLength": 1, "type": "string" },
        "recommended_governance_action": {
          "enum": ["approve", "reject", "rollback", "request_another_iteration"],
          "type": "string"
        },
        "latest_iteration_id": { "minLength": 1, "type": "string" },
        "latest_iteration_index": { "minimum": 0, "type": "integer" },
        "live_spend_allowed": { "type": "boolean" },
        "missing_artifact_group_count": { "minimum": 0, "type": "integer" },
        "missing_artifact_groups": {
          "items": { "type": "string" },
          "type": "array"
        },
        "missing_phase_input_count": { "minimum": 0, "type": "integer" },
        "missing_phase_inputs": {
          "items": { "type": "string" },
          "type": "array"
        },
        "next_action_recommendation": { "type": "string" },
        "next_action_scheduled": { "type": "boolean" },
        "promotion_decision_present": { "type": "boolean" },
        "readiness": { "minLength": 1, "type": "string" },
        "ready_for_governance_review": { "type": "boolean" },
        "recommendation": { "minLength": 1, "type": "string" },
        "requires_governance_decision": { "type": "boolean" },
        "rollback_receipt_present": { "type": "boolean" },
        "side_effects_started": { "const": false },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": [
        "latest_iteration_index",
        "latest_iteration_id",
        "readiness",
        "recommendation",
        "decision_readiness",
        "decision_recommendation",
        "recommended_governance_action",
        "ready_for_governance_review",
        "missing_phase_input_count",
        "missing_phase_inputs",
        "missing_artifact_group_count",
        "missing_artifact_groups",
        "blocked_reason_count",
        "cloud_training_ambiguous_link_count",
        "cloud_training_duplicate_role_count",
        "cloud_training_lineage_bound",
        "cloud_training_receipts_fail_closed",
        "cloud_training_live_launch_requested",
        "cloud_training_cost_incurred_usd",
        "cloud_training_launch_mode",
        "cloud_training_status_provider_status",
        "cloud_training_provider_id",
        "cloud_training_missing_link_count",
        "cloud_training_mismatched_link_count",
        "next_action_scheduled",
        "next_action_recommendation",
        "requires_governance_decision",
        "promotion_decision_present",
        "rollback_receipt_present",
        "live_spend_allowed",
        "side_effects_started",
        "summary"
      ],
      "type": "object"
    },
    "schema_version": { "const": "hfr.agentic_loop_ledger.v1" }
  },
  "required": [
    "schema_version",
    "ledger_path",
    "passed",
    "iteration_count",
    "iterations",
    "metrics",
    "decision",
    "readiness_digest",
    "execution_boundary",
    "notes"
  ],
  "title": "Hermes Flight Recorder Agentic Loop Ledger",
  "type": "object",
  "$defs": {
    "cloud_training_lineage": {
      "additionalProperties": true,
      "properties": {
        "ambiguous_link_count": { "minimum": 0, "type": "integer" },
        "ambiguous_links": {
          "items": { "type": "string" },
          "type": "array"
        },
        "duplicate_role_count": { "minimum": 0, "type": "integer" },
        "duplicate_roles": {
          "items": { "type": "string" },
          "type": "array"
        },
        "links": {
          "items": { "$ref": "#/$defs/cloud_training_lineage_link" },
          "type": "array"
        },
        "matched_link_count": { "minimum": 0, "type": "integer" },
        "mismatched_link_count": { "minimum": 0, "type": "integer" },
        "mismatched_links": {
          "items": { "type": "string" },
          "type": "array"
        },
        "missing_link_count": { "minimum": 0, "type": "integer" },
        "missing_links": {
          "items": { "type": "string" },
          "type": "array"
        },
        "passed": { "type": "boolean" },
        "provider": { "$ref": "#/$defs/cloud_training_lineage_provider" },
        "required_link_count": { "minimum": 0, "type": "integer" },
        "role_counts": {
          "items": { "$ref": "#/$defs/role_count" },
          "type": "array"
        }
      },
      "required": [
        "passed",
        "required_link_count",
        "matched_link_count",
        "missing_link_count",
        "mismatched_link_count",
        "ambiguous_link_count",
        "duplicate_role_count",
        "missing_links",
        "mismatched_links",
        "ambiguous_links",
        "duplicate_roles",
        "role_counts",
        "provider",
        "links"
      ],
      "type": "object"
    },
    "metrics": {
      "additionalProperties": false,
      "properties": {
        "artifact_group_totals": {
          "items": { "$ref": "#/$defs/group_count" },
          "type": "array"
        },
        "blocked_iteration_count": { "minimum": 0, "type": "integer" },
        "iteration_count": { "minimum": 1, "type": "integer" },
        "latest_iteration_id": { "type": "string" },
        "latest_missing_phase_input_count": { "minimum": 0, "type": "integer" },
        "latest_readiness": { "type": "string" },
        "latest_recommendation": { "type": "string" },
        "promotion_ready_count": { "minimum": 0, "type": "integer" },
        "readiness_counts": {
          "items": { "$ref": "#/$defs/id_count" },
          "type": "array"
        },
        "ready_iteration_count": { "minimum": 0, "type": "integer" },
        "recommendation_counts": {
          "items": { "$ref": "#/$defs/id_count" },
          "type": "array"
        },
        "rollback_receipt_count": { "minimum": 0, "type": "integer" },
        "scheduled_next_iteration_count": { "minimum": 0, "type": "integer" },
        "total_max_cloud_cost_usd": { "minimum": 0, "type": "number" },
        "total_max_gpu_hours": { "minimum": 0, "type": "number" }
      },
      "required": [
        "iteration_count",
        "ready_iteration_count",
        "blocked_iteration_count",
        "latest_iteration_id",
        "latest_readiness",
        "latest_recommendation",
        "latest_missing_phase_input_count",
        "scheduled_next_iteration_count",
        "promotion_ready_count",
        "rollback_receipt_count",
        "total_max_cloud_cost_usd",
        "total_max_gpu_hours",
        "readiness_counts",
        "recommendation_counts",
        "artifact_group_totals"
      ],
      "type": "object"
    },
    "cloud_training_lineage_link": {
      "additionalProperties": false,
      "properties": {
        "id": { "minLength": 1, "type": "string" },
        "passed": { "type": "boolean" },
        "source_artifact_count": { "minimum": 0, "type": "integer" },
        "source_ref": { "minLength": 1, "type": "string" },
        "source_ref_sha256": { "type": "string" },
        "source_role": { "minLength": 1, "type": "string" },
        "source_schema_version": { "type": "string" },
        "status": { "minLength": 1, "type": "string" },
        "target_artifact_count": { "minimum": 0, "type": "integer" },
        "target_role": { "minLength": 1, "type": "string" },
        "target_schema_version": { "type": "string" },
        "target_sha256": { "type": "string" }
      },
      "required": [
        "id",
        "source_role",
        "source_ref",
        "target_role",
        "source_artifact_count",
        "target_artifact_count",
        "source_schema_version",
        "target_schema_version",
        "source_ref_sha256",
        "target_sha256",
        "passed",
        "status"
      ],
      "type": "object"
    },
    "cloud_training_lineage_provider": {
      "additionalProperties": false,
      "properties": {
        "pipeline_provider_id": { "type": "string" },
        "pipeline_provider_ids": {
          "items": { "type": "string" },
          "type": "array"
        },
        "provider_by_role": {
          "additionalProperties": { "type": "string" },
          "type": "object"
        },
        "provider_consistent": { "type": "boolean" },
        "registry_contains_pipeline_provider": { "type": "boolean" },
        "registry_provider_ids": {
          "items": { "type": "string" },
          "type": "array"
        }
      },
      "required": [
        "registry_provider_ids",
        "pipeline_provider_ids",
        "pipeline_provider_id",
        "provider_by_role",
        "provider_consistent",
        "registry_contains_pipeline_provider"
      ],
      "type": "object"
    },
    "cloud_training_receipt_state": {
      "additionalProperties": false,
      "properties": {
        "cloud_jobs_started": { "type": "boolean" },
        "cost_incurred_usd": { "minimum": 0, "type": "number" },
        "credential_values_recorded": { "type": "boolean" },
        "fail_closed": { "type": "boolean" },
        "launch_mode": { "type": "string" },
        "launch_readiness": { "type": "string" },
        "launch_receipt_count": { "minimum": 0, "type": "integer" },
        "launch_receipt_passed": { "type": "boolean" },
        "launch_recommendation": { "type": "string" },
        "live_launch_requested": { "type": "boolean" },
        "provider_api_calls_started": { "type": "boolean" },
        "provider_cancel_called": { "type": "boolean" },
        "receipts_passed": { "type": "boolean" },
        "status_not_started": { "type": "boolean" },
        "status_provider_status": { "type": "string" },
        "status_readiness": { "type": "string" },
        "status_receipt_count": { "minimum": 0, "type": "integer" },
        "status_receipt_passed": { "type": "boolean" },
        "status_recommendation": { "type": "string" },
        "status_terminal": { "type": "boolean" }
      },
      "required": [
        "launch_receipt_count",
        "status_receipt_count",
        "launch_receipt_passed",
        "status_receipt_passed",
        "receipts_passed",
        "launch_mode",
        "launch_readiness",
        "launch_recommendation",
        "live_launch_requested",
        "status_provider_status",
        "status_terminal",
        "status_not_started",
        "status_readiness",
        "status_recommendation",
        "provider_api_calls_started",
        "cloud_jobs_started",
        "provider_cancel_called",
        "credential_values_recorded",
        "cost_incurred_usd",
        "fail_closed"
      ],
      "type": "object"
    },
    "group_count": {
      "additionalProperties": false,
      "properties": {
        "count": { "minimum": 0, "type": "integer" },
        "group": { "minLength": 1, "type": "string" }
      },
      "required": ["group", "count"],
      "type": "object"
    },
    "governance_action": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "enum": ["approve", "reject", "rollback", "request_another_iteration"],
          "type": "string"
        },
        "available": { "type": "boolean" },
        "blocked_reason_count": { "minimum": 0, "type": "integer" },
        "blocked_reasons": {
          "items": { "type": "string" },
          "type": "array"
        },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["action", "available", "blocked_reason_count", "blocked_reasons", "summary"],
      "type": "object"
    },
    "group_summary": {
      "additionalProperties": true,
      "properties": {
        "artifact_count": { "minimum": 0, "type": "integer" },
        "artifact_manifest_present": { "type": "boolean" },
        "cloud_jobs_started": { "type": "boolean" },
        "credential_values_recorded": { "type": "boolean" },
        "group": { "minLength": 1, "type": "string" },
        "launch_plan_present": { "type": "boolean" },
        "launch_receipt_present": { "type": "boolean" },
        "live_spend_allowed": { "const": false },
        "preflight_present": { "type": "boolean" },
        "provider_api_calls_started": { "type": "boolean" },
        "provider_registry_present": { "type": "boolean" },
        "roles_missing": {
          "items": { "type": "string" },
          "type": "array"
        },
        "roles_present": {
          "items": { "type": "string" },
          "type": "array"
        },
        "status_receipt_present": { "type": "boolean" }
      },
      "required": [
        "group",
        "artifact_count",
        "roles_present",
        "roles_missing",
        "provider_registry_present",
        "preflight_present",
        "artifact_manifest_present",
        "launch_plan_present",
        "launch_receipt_present",
        "status_receipt_present",
        "provider_api_calls_started",
        "cloud_jobs_started",
        "credential_values_recorded",
        "live_spend_allowed"
      ],
      "type": "object"
    },
    "id_count": {
      "additionalProperties": false,
      "properties": {
        "count": { "minimum": 0, "type": "integer" },
        "id": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "count"],
      "type": "object"
    },
    "role_count": {
      "additionalProperties": false,
      "properties": {
        "count": { "minimum": 0, "type": "integer" },
        "role": { "minLength": 1, "type": "string" }
      },
      "required": ["role", "count"],
      "type": "object"
    }
  }
}
