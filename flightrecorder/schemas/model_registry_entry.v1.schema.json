{
  "$id": "https://schemas.hermes-flight-recorder.dev/model_registry_entry.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "One model registry entry linking a candidate snapshot to lifecycle metadata.",
  "properties": {
    "candidate": {"type": "object"},
    "candidate_id": {"minLength": 1, "type": "string"},
    "entry_id": {"minLength": 1, "type": "string"},
    "license_status": {"type": "string"},
    "links": {
      "additionalProperties": true,
      "properties": {
        "adapters": {"items": {"$ref": "#/$defs/linkRecord"}, "type": "array"},
        "datasets": {"items": {"$ref": "#/$defs/linkRecord"}, "type": "array"},
        "evals": {"items": {"$ref": "#/$defs/linkRecord"}, "type": "array"},
        "promotion_decisions": {"items": {"$ref": "#/$defs/linkRecord"}, "type": "array"},
        "serving_probes": {"items": {"$ref": "#/$defs/linkRecord"}, "type": "array"},
        "training_runs": {"items": {"$ref": "#/$defs/linkRecord"}, "type": "array"}
      },
      "required": ["datasets", "training_runs", "adapters", "evals", "serving_probes", "promotion_decisions"],
      "type": "object"
    },
    "notes": {"items": {"type": "string"}, "type": "array"},
    "registered_at": {"minLength": 1, "type": "string"},
    "schema_version": {"const": "hfr.model_registry_entry.v1"},
    "status": {"minLength": 1, "type": "string"},
    "training_eligible": {"type": "boolean"},
    "updated_at": {"minLength": 1, "type": "string"}
  },
  "required": [
    "schema_version",
    "entry_id",
    "candidate_id",
    "registered_at",
    "updated_at",
    "status",
    "training_eligible",
    "links",
    "candidate"
  ],
  "title": "Hermes Flight Recorder Model Registry Entry",
  "type": "object",
  "$defs": {
    "linkRecord": {
      "additionalProperties": true,
      "properties": {
        "id": {"minLength": 1, "type": "string"},
        "kind": {"minLength": 1, "type": "string"},
        "metadata": {"type": "object"},
        "path": {"minLength": 1, "type": "string"},
        "recorded_at": {"minLength": 1, "type": "string"},
        "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "size_bytes": {"minimum": 0, "type": "integer"},
        "status": {"minLength": 1, "type": "string"}
      },
      "required": ["id", "kind", "status", "recorded_at"],
      "if": {"required": ["path"]},
      "then": {"required": ["sha256", "size_bytes"]},
      "type": "object"
    }
  }
}
