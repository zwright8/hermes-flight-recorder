{
  "schema_version": "hfr.verifier_config.v1",
  "description": "Capture Slack channel history using a read-only bot token.",
  "secret_patterns": ["(?i)(api[_-]?key|secret|token|password)"],
  "sources": [
    {
      "id": "slack_channel_history",
      "type": "slack_history",
      "channel_id": "C123",
      "limit": 50,
      "token_env": "SLACK_BOT_TOKEN",
      "state_path": "slack"
    }
  ]
}
