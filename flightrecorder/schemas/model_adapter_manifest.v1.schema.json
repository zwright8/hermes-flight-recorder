{
  "$id": "https://schemas.hermes-flight-recorder.dev/model_adapter_manifest.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "No-download planned adapter manifest linking a base-model registry entry to a dry-run training plan.",
  "properties": {
    "adapter_id": {"minLength": 1, "type": "string"},
    "adapter_kind": {"minLength": 1, "type": "string"},
    "base_model": {"type": "object"},
    "blocked_reasons": {"items": {"type": "string"}, "type": "array"},
    "checks": {"items": {"type": "object"}, "type": "array"},
    "download_policy": {"type": "object"},
    "execution": {"type": "object"},
    "generated_at": {"minLength": 1, "type": "string"},
    "manifest_path": {"minLength": 1, "type": "string"},
    "notes": {"items": {"type": "string"}, "type": "array"},
    "output": {"type": "object"},
    "passed": {"const": true},
    "readiness": {"const": "planned"},
    "recommendation": {"const": "ready_for_training_worker"},
    "registry_link": {"type": "object"},
    "schema_version": {"const": "hfr.model_adapter_manifest.v1"},
    "status": {"const": "planned"},
    "training_plan": {
      "additionalProperties": true,
      "if": {"required": ["sha256"]},
      "properties": {
        "path": {"minLength": 1, "type": "string"},
        "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "size_bytes": {"minimum": 0, "type": "integer"}
      },
      "then": {"required": ["size_bytes"]},
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "manifest_path",
    "generated_at",
    "adapter_id",
    "adapter_kind",
    "status",
    "passed",
    "readiness",
    "recommendation",
    "base_model",
    "training_plan",
    "output",
    "download_policy",
    "execution",
    "registry_link",
    "checks",
    "blocked_reasons"
  ],
  "title": "Hermes Flight Recorder Model Adapter Manifest",
  "type": "object"
}
