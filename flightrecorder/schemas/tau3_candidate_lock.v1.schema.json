{
  "$id": "https://schemas.hermes-flight-recorder.dev/tau3_candidate_lock.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Public-safe hash-only lock for the single development-selected Tau-3 candidate.",
  "properties": {
    "adapter_tree_sha256": {"$ref": "#/$defs/sha256"},
    "base_identity_sha256": {"$ref": "#/$defs/sha256"},
    "base_tree_sha256": {"$ref": "#/$defs/sha256"},
    "candidate_identity_sha256": {"$ref": "#/$defs/sha256"},
    "created_at": {"minLength": 1, "type": "string"},
    "dataset_files_sha256": {"$ref": "#/$defs/sha256"},
    "dataset_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "development_benchmark_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "development_selection_report_sha256": {"$ref": "#/$defs/sha256"},
    "endpoint_model_sha256": {"$ref": "#/$defs/sha256"},
    "hashes_only": {"const": true},
    "local_paths_included": {"const": false},
    "protocol_sha256": {"$ref": "#/$defs/sha256"},
    "protocol_signature": {"$ref": "#/$defs/sha256"},
    "raw_payload_included": {"const": false},
    "recipe_sha256": {"$ref": "#/$defs/sha256"},
    "schema_version": {"const": "hfr.tau3_candidate_lock.v1"},
    "sealed_access_authorized": {"const": true},
    "selected_candidate_id_hash": {"$ref": "#/$defs/sha256"},
    "source_binding_sha256": {"$ref": "#/$defs/sha256"},
    "training_receipt_sha256": {"$ref": "#/$defs/sha256"}
  },
  "required": [
    "schema_version",
    "created_at",
    "selected_candidate_id_hash",
    "candidate_identity_sha256",
    "development_selection_report_sha256",
    "development_benchmark_manifest_sha256",
    "training_receipt_sha256",
    "endpoint_model_sha256",
    "adapter_tree_sha256",
    "recipe_sha256",
    "base_identity_sha256",
    "base_tree_sha256",
    "dataset_manifest_sha256",
    "dataset_files_sha256",
    "source_binding_sha256",
    "protocol_sha256",
    "protocol_signature",
    "hashes_only",
    "sealed_access_authorized",
    "local_paths_included",
    "raw_payload_included"
  ],
  "title": "Tau-3 Candidate Lock",
  "type": "object",
  "$defs": {
    "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
  }
}
