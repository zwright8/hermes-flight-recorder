        "dry_run_only": {
          "const": true
        },
        "external_runner_command": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cloud_jobs_started": {
          "const": false
        },
        "model_downloads_started": {
          "const": false
        },
        "paid_model_grader_calls_started": {
          "const": false
