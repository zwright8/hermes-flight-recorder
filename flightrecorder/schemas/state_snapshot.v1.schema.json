{
  "$id": "https://schemas.hermes-flight-recorder.dev/state_snapshot.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "External-state evidence snapshot emitted by capture-state, verify-state, and run state capture.",
  "properties": {
    "filesystem": { "$ref": "#/$defs/filesystem" },
    "json": {
      "additionalProperties": true,
      "type": "object"
    },
    "json_sources": {
      "additionalProperties": { "$ref": "#/$defs/file_record" },
      "type": "object"
    },
    "observations": {
      "additionalProperties": true,
      "type": "object"
    },
    "schema_version": { "const": "hfr.state_snapshot.v1" }
  },
  "required": ["schema_version", "filesystem", "json_sources", "json", "observations"],
  "title": "Hermes Flight Recorder State Snapshot",
  "type": "object",
  "$defs": {
    "directory_entry": {
      "additionalProperties": true,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "kind": { "const": "file" }
              },
              "required": ["name", "kind", "sha256", "size_bytes"],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "directory" },
                "name": { "minLength": 1, "type": "string" }
              },
              "required": ["name", "kind"],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "other" },
                "name": { "minLength": 1, "type": "string" }
              },
              "required": ["name", "kind"],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": { "const": "missing" },
                "name": { "minLength": 1, "type": "string" }
              },
              "required": ["name", "kind"],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "kind": { "enum": ["file", "directory", "other", "missing"], "type": "string" },
        "name": { "minLength": 1, "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" }
      },
      "required": ["name"],
      "type": "object"
    },
    "directory_record": {
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "required": ["entry_selection"]
          },
          "then": {
            "properties": {
              "kind": { "const": "directory" }
            },
            "required": [
              "entry_count",
              "entry_count_is_lower_bound",
              "scanned_entry_count",
              "scan_limit",
              "scan_incomplete",
              "entries_truncated",
              "entries"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "scan_incomplete": { "const": true }
            },
            "required": ["scan_incomplete", "entry_count_is_lower_bound"]
          },
          "then": {
            "properties": {
              "entry_count_is_lower_bound": { "const": true }
            }
          }
        },
        {
          "if": {
            "properties": {
              "scan_incomplete": { "const": false }
            },
            "required": ["scan_incomplete", "entry_count_is_lower_bound"]
          },
          "then": {
            "properties": {
              "entry_count_is_lower_bound": { "const": false }
            }
          }
        }
      ],
      "properties": {
        "entries": {
          "items": { "$ref": "#/$defs/directory_entry" },
          "type": "array"
        },
        "entries_truncated": { "type": "boolean" },
        "entry_count": { "minimum": 0, "type": "integer" },
        "entry_count_is_lower_bound": { "type": "boolean" },
        "entry_selection": {
          "const": "lexicographic_within_scanned_prefix"
        },
        "exists": { "type": "boolean" },
        "kind": { "enum": ["missing", "not_directory", "directory"], "type": "string" },
        "path": { "minLength": 1, "type": "string" },
        "scan_incomplete": { "type": "boolean" },
        "scan_limit": { "minimum": 1, "type": "integer" },
        "scanned_entry_count": { "minimum": 0, "type": "integer" }
      },
      "required": ["path", "exists", "kind"],
      "type": "object"
    },
    "file_record": {
      "additionalProperties": true,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "exists": { "const": true },
                "kind": { "const": "file" }
              },
              "required": ["path", "exists", "kind", "sha256", "size_bytes"],
              "type": "object"
            },
            {
              "properties": {
                "exists": { "const": false },
                "kind": { "const": "missing" }
              },
              "required": ["path", "exists", "kind"],
              "type": "object"
            },
            {
              "properties": {
                "exists": { "const": true },
                "kind": { "const": "directory" }
              },
              "required": ["path", "exists", "kind"],
              "type": "object"
            },
            {
              "properties": {
                "exists": { "const": true },
                "kind": { "const": "other" }
              },
              "required": ["path", "exists", "kind"],
              "type": "object"
            }
          ]
        }
      ],
      "properties": {
        "exists": { "type": "boolean" },
        "kind": { "enum": ["missing", "file", "directory", "other"], "type": "string" },
        "path": { "minLength": 1, "type": "string" },
        "sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "size_bytes": { "minimum": 0, "type": "integer" },
        "text": { "type": "string" },
        "text_truncated": { "type": "boolean" }
      },
      "required": ["path", "exists", "kind"],
      "type": "object"
    },
    "filesystem": {
      "additionalProperties": true,
      "properties": {
        "directories": {
          "additionalProperties": { "$ref": "#/$defs/directory_record" },
          "type": "object"
        },
        "files": {
          "additionalProperties": { "$ref": "#/$defs/file_record" },
          "type": "object"
        }
      },
      "required": ["files", "directories"],
      "type": "object"
    }
  }
}
