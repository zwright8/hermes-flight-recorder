{
  "$id": "https://schemas.hermes-flight-recorder.dev/trainer_launch_check.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Consumer-side trainer launch decision over a validated trainer preflight.",
  "properties": {
    "approved_command": {
      "$ref": "#/$defs/approvedCommand"
    },
    "artifacts": {
      "$ref": "#/$defs/artifactSummary"
    },
    "check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/check"
      },
      "type": "array"
    },
    "failed_check_count": {
      "minimum": 0,
      "type": "integer"
    },
    "dataset_selection": {
      "items": {
        "$ref": "#/$defs/datasetSelection"
      },
      "type": "array"
    },
    "gate_count": {
      "minimum": 0,
      "type": "integer"
    },
    "gates": {
      "items": {
        "$ref": "#/$defs/launchGate"
      },
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "passed": {
      "type": "boolean"
    },
    "passed_gate_count": {
      "minimum": 0,
      "type": "integer"
    },
    "preflight_path": {
      "minLength": 1,
      "type": "string"
    },
    "readiness": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "recommendation": {
      "enum": [
        "launch_allowed",
        "block_launch"
      ]
    },
    "required_gates": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_dataset_versions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "schema_version": {
      "const": "hfr.trainer_launch_check.v1"
    },
    "validation": {
      "$ref": "#/$defs/validation"
    }
  },
  "required": [
    "schema_version",
    "preflight_path",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "validation",
    "required_gates",
    "required_dataset_versions",
    "required_metadata",
    "gates",
    "gate_count",
    "passed_gate_count",
    "artifacts",
    "dataset_selection",
    "approved_command",
    "notes"
  ],
  "title": "Hermes Flight Recorder Trainer Launch Check",
  "type": "object",
  "$defs": {
    "approvedCommand": {
      "additionalProperties": false,
      "properties": {
        "approved": {
          "type": "boolean"
        },
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "parseable": {
          "type": "boolean"
        },
        "provided": {
          "type": "boolean"
        },
        "raw": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        }
      },
      "required": [
        "approved",
        "provided",
        "raw",
        "argv",
        "parseable",
        "shell"
      ],
      "type": "object"
    },
    "artifactSummary": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "minimum": 0,
          "type": "integer"
        },
        "names": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "count",
        "names"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "scope": {
          "type": "object"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "passed",
        "summary"
      ],
      "type": "object"
    },
    "launchGate": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "path",
        "schema_version",
        "passed"
      ],
      "type": "object"
    },
    "validation": {
      "additionalProperties": false,
      "properties": {
        "error_count": {
          "minimum": 0,
          "type": "integer"
        },
        "errors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "passed": {
          "type": "boolean"
        },
        "strict": {
          "type": "boolean"
        },
        "target_count": {
          "minimum": 0,
          "type": "integer"
        },
        "warning_count": {
          "minimum": 0,
          "type": "integer"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "passed",
        "strict",
        "target_count",
        "error_count",
        "warning_count",
        "errors",
        "warnings"
      ],
      "type": "object"
    },
    "datasetSelection": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "enum": [
            "reviewed_export",
            "training_export"
          ]
        },
        "dataset_version": {
          "type": "string"
        },
        "heldout_scenario_exclusive": {
          "type": "boolean"
        },
        "heldout_scenario_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "manifest_path": {
          "type": "string"
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "matches_required": {
          "type": "boolean"
        },
        "redaction_passed": {
          "type": "boolean"
        },
        "registry_dataset_version": {
          "type": "string"
        },
        "registry_manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "registry_path": {
          "type": "string"
        },
        "registry_selection_key": {
          "type": "string"
        },
        "registry_sha256": {
          "pattern": "^[0-9a-f]{64}$|^$",
          "type": "string"
        },
        "required_dataset_versions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "root": {
          "type": "string"
        },
        "trainer_modes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "trainer_views": {
          "$ref": "#/$defs/trainerViews"
        }
      },
      "required": [
        "artifact",
        "root",
        "manifest_path",
        "manifest_sha256",
        "registry_path",
        "registry_sha256",
        "dataset_version",
        "required_dataset_versions",
        "matches_required",
        "registry_dataset_version",
        "registry_selection_key",
        "registry_manifest_sha256",
        "redaction_passed",
        "trainer_views",
        "trainer_modes"
      ],
      "type": "object"
    },
    "trainerViews": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "type": "string"
        },
        "mode_to_view": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "root_views": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "views": {
          "items": {
            "$ref": "#/$defs/trainerView"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "trainerView": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "type": "string"
        },
        "artifact_format": {
          "enum": [
            "json",
            "jsonl"
          ]
        },
        "artifact_path": {
          "type": "string"
        },
        "available": {
          "type": "boolean"
        },
        "label_policy": {
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "row_count": {
          "minimum": 0,
          "type": "integer"
        },
        "schema_version": {
          "type": "string"
        },
        "source_artifacts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "split_paths": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "training_modes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "view_id": {
          "type": "string"
        }
      },
      "required": [
        "view_id",
        "training_modes",
        "artifact",
        "artifact_path",
        "artifact_format",
        "schema_version",
        "row_count",
        "source_artifacts",
        "label_policy",
        "available",
        "split_paths",
        "notes"
      ],
      "type": "object"
    }
  }
}
