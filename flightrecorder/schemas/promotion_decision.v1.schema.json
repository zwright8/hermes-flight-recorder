{
  "$id": "https://schemas.hermes-flight-recorder.dev/promotion_decision.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Side-effect-free governance decision authorizing or blocking promotion alias movement.",
  "properties": {
    "alias_update": {"$ref": "#/$defs/aliasUpdate"},
    "artifacts": {"$ref": "#/$defs/decisionArtifacts"},
    "check_count": {"minimum": 0, "type": "integer"},
    "checks": {"items": {"$ref": "#/$defs/gateCheck"}, "type": "array"},
    "decision": {"$ref": "#/$defs/decisionBlock"},
    "decision_path": {"type": "string"},
    "external_eval_lineage": {"$ref": "#/$defs/externalEvalLineage"},
    "failed_check_count": {"minimum": 0, "type": "integer"},
    "metadata": {"additionalProperties": {"type": "string"}, "type": "object"},
    "metrics": {"$ref": "#/$defs/decisionMetrics"},
    "models": {"$ref": "#/$defs/decisionModels"},
    "notes": {"items": {"type": "string"}, "type": "array"},
    "passed": {"type": "boolean"},
    "policy": {"$ref": "#/$defs/promotionPolicy"},
    "readiness": {"enum": ["ready", "blocked"], "type": "string"},
    "recommendation": {"enum": ["apply_alias_update", "block_promotion"], "type": "string"},
    "schema_version": {"const": "hfr.promotion_decision.v1"}
  },
  "required": [
    "schema_version",
    "decision_path",
    "passed",
    "readiness",
    "recommendation",
    "models",
    "decision",
    "external_eval_lineage",
    "check_count",
    "failed_check_count",
    "checks",
    "artifacts",
    "policy",
    "metrics",
    "alias_update",
    "notes"
  ],
  "$defs": {
    "aliasRow": {
      "additionalProperties": false,
      "properties": {
        "alias": {"type": "string"},
        "previous_target": {"type": "string"},
        "target": {"type": "string"}
      },
      "required": ["alias", "target"],
      "type": "object"
    },
    "aliasUpdate": {
      "additionalProperties": false,
      "properties": {
        "aliases": {"items": {"$ref": "#/$defs/aliasRow"}, "type": "array"},
        "authorized": {"type": "boolean"},
        "recommendation": {"enum": ["apply_alias_update", "hold_aliases"], "type": "string"}
      },
      "required": ["authorized", "recommendation", "aliases"],
      "type": "object"
    },
    "decisionArtifacts": {
      "additionalProperties": false,
      "properties": {
        "agentic_training_result": {"$ref": "#/$defs/fingerprintedArtifact"},
        "compare_gate": {"$ref": "#/$defs/fingerprintedArtifact"},
        "dataset_card": {"$ref": "#/$defs/fingerprintedArtifact"},
        "evidence_bundle": {"$ref": "#/$defs/evidenceBundleArtifact"},
        "eval_summary": {"$ref": "#/$defs/evalSummaryArtifact"},
        "license_review": {"$ref": "#/$defs/fingerprintedArtifact"},
        "model_card": {"$ref": "#/$defs/fingerprintedArtifact"},
        "model_registry_entry": {"$ref": "#/$defs/fingerprintedArtifact"},
        "promotion_ledger_gate": {"$ref": "#/$defs/fingerprintedArtifact"},
        "redaction_check": {"$ref": "#/$defs/fingerprintedArtifact"},
        "rollback_metadata": {"$ref": "#/$defs/fingerprintedArtifact"},
        "safety_gate": {"$ref": "#/$defs/fingerprintedArtifact"},
        "serving_profile": {"$ref": "#/$defs/fingerprintedArtifact"},
        "serving_report": {"$ref": "#/$defs/fingerprintedArtifact"},
        "trainer_launch_check": {"$ref": "#/$defs/fingerprintedArtifact"}
      },
      "required": [
        "evidence_bundle",
        "eval_summary",
        "promotion_ledger_gate",
        "compare_gate",
        "trainer_launch_check",
        "model_registry_entry",
        "agentic_training_result",
        "model_card",
        "dataset_card",
        "rollback_metadata",
        "license_review",
        "redaction_check",
        "safety_gate",
        "serving_profile",
        "serving_report"
      ],
      "type": "object"
    },
    "decisionBlock": {
      "additionalProperties": false,
      "properties": {
        "blocking_check_count": {"minimum": 0, "type": "integer"},
        "blocking_checks": {"items": {"$ref": "#/$defs/blockingCheck"}, "type": "array"},
        "key_metrics": {"$ref": "#/$defs/decisionMetrics"},
        "readiness": {"enum": ["ready", "blocked"], "type": "string"},
        "recommendation": {"enum": ["apply_alias_update", "block_promotion"], "type": "string"},
        "summary": {"type": "string"}
      },
      "required": [
        "readiness",
        "recommendation",
        "summary",
        "blocking_check_count",
        "blocking_checks",
        "key_metrics"
      ],
      "type": "object"
    },
    "blockingCheck": {
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "scope": {"additionalProperties": true, "type": "object"},
        "summary": {"type": "string"}
      },
      "required": ["id", "summary", "scope"],
      "type": "object"
    },
    "decisionMetrics": {
      "additionalProperties": false,
      "properties": {
        "baseline_win_count": {"minimum": 0, "type": "integer"},
        "check_count": {"minimum": 0, "type": "integer"},
        "contract_drift_count": {"minimum": 0, "type": "integer"},
        "failed_check_count": {"minimum": 0, "type": "integer"},
        "external_eval_result_count": {"minimum": 0, "type": "integer"},
        "new_critical_failure_count": {"minimum": 0, "type": "integer"},
        "policy_release_required_artifact_count": {"minimum": 0, "type": "integer"},
        "policy_required_artifact_count": {"minimum": 0, "type": "integer"},
        "required_artifact_count": {"minimum": 0, "type": "integer"},
        "rule_regression_count": {"minimum": 0, "type": "integer"},
        "task_completion_regression_count": {"minimum": 0, "type": "integer"},
        "unverified_contract_count": {"minimum": 0, "type": "integer"}
      },
      "required": [
        "check_count",
        "failed_check_count",
        "external_eval_result_count",
        "required_artifact_count",
        "policy_required_artifact_count",
        "policy_release_required_artifact_count",
        "task_completion_regression_count",
        "baseline_win_count",
        "contract_drift_count",
        "unverified_contract_count",
        "new_critical_failure_count",
        "rule_regression_count"
      ],
      "type": "object"
    },
    "decisionModel": {
      "additionalProperties": false,
      "properties": {
        "class": {"type": "string"},
        "id": {"type": "string"}
      },
      "required": ["id", "class"],
      "type": "object"
    },
    "decisionModels": {
      "additionalProperties": false,
      "properties": {
        "candidate": {"$ref": "#/$defs/decisionModel"},
        "champion": {"$ref": "#/$defs/decisionModel"},
        "rollback": {"$ref": "#/$defs/decisionModel"}
      },
      "required": ["candidate", "champion", "rollback"],
      "type": "object"
    },
    "fingerprintedArtifact": {
      "additionalProperties": false,
      "properties": {
        "exists": {"type": "boolean"},
        "file_count": {"minimum": 0, "type": "integer"},
        "kind": {"enum": ["file", "directory", "missing", "other"], "type": "string"},
        "path": {"type": "string"},
        "role": {"type": "string"},
        "schema_version": {"type": "string"},
        "sha256": {"type": ["string", "null"]},
        "size_bytes": {"minimum": 0, "type": "integer"}
      },
      "required": ["role", "path", "exists", "kind"],
      "type": "object"
    },
    "externalEvalLineage": {
      "additionalProperties": false,
      "properties": {
        "candidate_model_bound": {"type": "boolean"},
        "eval_summary_semantically_valid": {"type": "boolean"},
        "evidence_bundle_semantically_valid": {"type": "boolean"},
        "evidence_bundle_summary_bound": {"type": "boolean"},
        "exact_result_set": {"type": "boolean"},
        "external_results_semantically_valid": {"type": "boolean"},
        "governance_ready": {"type": "boolean"},
        "passed": {"type": "boolean"},
        "result_count": {"minimum": 0, "type": "integer"},
        "results": {"items": {"$ref": "#/$defs/externalEvalLineageResult"}, "type": "array"},
        "semantic_validation_passed": {"type": "boolean"},
        "summary_result_count": {"minimum": 0, "type": "integer"}
      },
      "required": [
        "result_count",
        "summary_result_count",
        "exact_result_set",
        "candidate_model_bound",
        "evidence_bundle_summary_bound",
        "evidence_bundle_semantically_valid",
        "eval_summary_semantically_valid",
        "external_results_semantically_valid",
        "semantic_validation_passed",
        "governance_ready",
        "passed",
        "results"
      ],
      "type": "object"
    },
    "externalEvalLineageResult": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": {"type": ["string", "null"]},
        "artifact": {"$ref": "#/$defs/externalEvalResultArtifact"},
        "benchmark_status": {"enum": ["passed", "failed", "inconclusive", "not_available", null]},
        "coverage_complete": {"type": "boolean"},
        "execution_status": {"enum": ["completed", "incomplete", "failed", null]},
        "external_eval_claims_allowed": {"type": "boolean"},
        "governance_readiness": {"enum": ["ready_for_review", "blocked", null]},
        "heldout_manifest_sha256": {"anyOf": [{"pattern": "^[0-9a-f]{64}$", "type": "string"}, {"type": "null"}]},
        "integrity_passed": {"type": "boolean"},
        "model_id": {"type": ["string", "null"]},
        "plan_sha256": {"anyOf": [{"pattern": "^[0-9a-f]{64}$", "type": "string"}, {"type": "null"}]}
      },
      "required": [
        "artifact",
        "adapter_id",
        "model_id",
        "plan_sha256",
        "heldout_manifest_sha256",
        "integrity_passed",
        "execution_status",
        "benchmark_status",
        "coverage_complete",
        "governance_readiness",
        "external_eval_claims_allowed"
      ],
      "type": "object"
    },
    "externalEvalResultArtifact": {
      "allOf": [
        {"$ref": "#/$defs/fingerprintedArtifact"},
        {
          "properties": {"role": {"const": "external_eval_result"}},
          "required": ["role"],
          "type": "object"
        },
        {
          "if": {
            "properties": {"exists": {"const": true}, "kind": {"const": "file"}},
            "required": ["exists", "kind"]
          },
          "then": {
            "properties": {"schema_version": {"const": "hfr.external_eval_result.v1"}},
            "required": ["schema_version"]
          }
        }
      ]
    },
    "evidenceBundleArtifact": {
      "allOf": [
        {"$ref": "#/$defs/fingerprintedArtifact"},
        {
          "properties": {"role": {"const": "evidence_bundle"}},
          "required": ["role"],
          "type": "object"
        },
        {
          "if": {
            "properties": {"exists": {"const": true}, "kind": {"const": "file"}},
            "required": ["exists", "kind"]
          },
          "then": {
            "properties": {"schema_version": {"const": "hfr.evidence_bundle.v1"}},
            "required": ["schema_version"]
          }
        }
      ]
    },
    "evalSummaryArtifact": {
      "allOf": [
        {"$ref": "#/$defs/fingerprintedArtifact"},
        {
          "properties": {"role": {"const": "eval_summary"}},
          "required": ["role"],
          "type": "object"
        },
        {
          "if": {
            "properties": {"exists": {"const": true}, "kind": {"const": "file"}},
            "required": ["exists", "kind"]
          },
          "then": {
            "properties": {"schema_version": {"const": "hfr.eval_summary.v1"}},
            "required": ["schema_version"]
          }
        }
      ]
    },
    "gateCheck": {
      "additionalProperties": false,
      "properties": {
        "actual": true,
        "expected": {"additionalProperties": true, "type": "object"},
        "id": {"type": "string"},
        "passed": {"type": "boolean"},
        "scope": {"additionalProperties": true, "type": "object"},
        "summary": {"type": "string"}
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "policyLimits": {
      "additionalProperties": false,
      "properties": {
        "max_baseline_wins": {"minimum": 0, "type": "integer"},
        "max_contract_drifts": {"minimum": 0, "type": "integer"},
        "max_new_critical_failures": {"minimum": 0, "type": "integer"},
        "max_rule_regressions": {"minimum": 0, "type": "integer"},
        "max_task_completion_regressions": {"minimum": 0, "type": "integer"},
        "max_unverified_contracts": {"minimum": 0, "type": "integer"}
      },
      "required": [
        "max_task_completion_regressions",
        "max_baseline_wins",
        "max_contract_drifts",
        "max_unverified_contracts",
        "max_new_critical_failures",
        "max_rule_regressions"
      ],
      "type": "object"
    },
    "policyRequirements": {
      "additionalProperties": false,
      "properties": {
        "require_accepted_terms": {"type": "boolean"},
        "require_artifact_validation": {"type": "boolean"},
        "require_known_license": {"type": "boolean"},
        "require_rollback_metadata": {"type": "boolean"},
        "require_supported_cards": {"type": "boolean"}
      },
      "required": [
        "require_known_license",
        "require_accepted_terms",
        "require_rollback_metadata",
        "require_supported_cards",
        "require_artifact_validation"
      ],
      "type": "object"
    },
    "promotionPolicy": {
      "additionalProperties": false,
      "properties": {
        "allowed_candidate_classes": {"items": {"type": "string"}, "type": "array"},
        "allowed_champion_classes": {"items": {"type": "string"}, "type": "array"},
        "artifact": {"$ref": "#/$defs/fingerprintedArtifact"},
        "description": {"type": "string"},
        "forbid_new_critical_rules": {"items": {"type": "string"}, "type": "array"},
        "forbid_regressed_rules": {"items": {"type": "string"}, "type": "array"},
        "id": {"type": "string"},
        "limits": {"$ref": "#/$defs/policyLimits"},
        "release_required_artifacts": {"items": {"type": "string"}, "type": "array"},
        "required_artifacts": {"items": {"type": "string"}, "type": "array"},
        "requirements": {"$ref": "#/$defs/policyRequirements"},
        "schema_version": {"const": "hfr.promotion_policy.v1"},
        "source": {"enum": ["default", "file"], "type": "string"}
      },
      "required": [
        "schema_version",
        "id",
        "description",
        "source",
        "required_artifacts",
        "release_required_artifacts",
        "allowed_candidate_classes",
        "allowed_champion_classes",
        "limits",
        "forbid_new_critical_rules",
        "forbid_regressed_rules",
        "requirements"
      ],
      "type": "object"
    }
  },
  "title": "Hermes Flight Recorder Promotion Decision",
  "type": "object"
}
