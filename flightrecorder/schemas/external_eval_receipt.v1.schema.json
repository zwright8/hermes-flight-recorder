{
  "$id": "https://schemas.hermes-flight-recorder.dev/external_eval_receipt.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Dry-run or blocked live external benchmark adapter receipt.",
  "properties": {
    "adapter_count": { "minimum": 0, "type": "integer" },
    "adapter_receipts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "adapter_contract": { "$ref": "#/$defs/adapterContract" },
          "blocking_reasons": { "items": { "type": "string" }, "type": "array" },
          "cost_incurred_usd": { "const": 0 },
          "credential_values_recorded": { "const": false },
          "dependency_status": { "$ref": "#/$defs/dependencyStatus" },
          "domain": { "minLength": 1, "type": "string" },
          "id": { "enum": ["bfcl", "inspect_ai", "lm_eval_harness", "local_mock", "swe_bench"], "type": "string" },
          "live_benchmark_started": { "const": false },
          "model_downloads_started": { "const": false },
          "name": { "minLength": 1, "type": "string" },
          "planned_ready": { "type": "boolean" },
          "provided_inputs": { "items": { "type": "string" }, "type": "array" },
          "provider_api_called": { "const": false },
          "ready": { "type": "boolean" },
          "required_inputs": { "items": { "type": "string" }, "type": "array" }
        },
        "required": [
          "id",
          "name",
          "domain",
          "ready",
          "planned_ready",
          "blocking_reasons",
          "dependency_status",
          "required_inputs",
          "provided_inputs",
          "adapter_contract",
          "live_benchmark_started",
          "provider_api_called",
          "model_downloads_started",
          "credential_values_recorded",
          "cost_incurred_usd"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "blocked_reasons": { "items": { "type": "string" }, "type": "array" },
    "check_count": { "minimum": 0, "type": "integer" },
    "checks": { "items": { "$ref": "#/$defs/check" }, "type": "array" },
    "created_at": { "type": "string" },
    "execution_boundary": {
      "additionalProperties": false,
      "properties": {
        "cloud_cost_incurred_usd": { "const": 0 },
        "credential_values_recorded": { "const": false },
        "dry_run_only": { "const": true },
        "live_benchmarks_started": { "const": false },
        "model_downloads_started": { "const": false },
        "provider_api_called": { "const": false },
        "weights_updated_by_flight_recorder": { "const": false }
      },
      "required": [
        "dry_run_only",
        "live_benchmarks_started",
        "provider_api_called",
        "model_downloads_started",
        "cloud_cost_incurred_usd",
        "credential_values_recorded",
        "weights_updated_by_flight_recorder"
      ],
      "type": "object"
    },
    "failed_check_count": { "minimum": 0, "type": "integer" },
    "launch": {
      "additionalProperties": false,
      "properties": {
        "cost_incurred_usd": { "const": 0 },
        "live_benchmarks_started": { "const": false },
        "mode": { "enum": ["dry_run", "live"], "type": "string" },
        "model_downloads_started": { "const": false },
        "provider_api_called": { "const": false }
      },
      "required": ["mode", "live_benchmarks_started", "provider_api_called", "model_downloads_started", "cost_incurred_usd"],
      "type": "object"
    },
    "notes": { "items": { "type": "string" }, "type": "array" },
    "passed": { "type": "boolean" },
    "readiness": { "enum": ["dry_run_recorded", "blocked"], "type": "string" },
    "ready_adapter_count": { "minimum": 0, "type": "integer" },
    "recommendation": { "enum": ["archive_external_eval_dry_run", "keep_external_eval_claims_disabled"], "type": "string" },
    "schema_version": { "const": "hfr.external_eval_receipt.v1" },
    "source_plan": { "$ref": "#/$defs/sourcePlan" }
  },
  "required": [
    "schema_version",
    "created_at",
    "passed",
    "readiness",
    "recommendation",
    "check_count",
    "failed_check_count",
    "checks",
    "blocked_reasons",
    "source_plan",
    "adapter_count",
    "ready_adapter_count",
    "adapter_receipts",
    "launch",
    "execution_boundary",
    "notes"
  ],
  "title": "Hermes Flight Recorder External Eval Receipt",
  "type": "object",
  "$defs": {
    "adapterContract": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "minLength": 1, "type": "string" },
        "cost_incurred_usd": { "const": 0 },
        "credential_values_recorded": { "const": false },
        "dry_run_transport": { "const": "plan_and_receipt_only" },
        "external_adapter_id": { "enum": ["bfcl", "inspect_ai", "lm_eval_harness", "local_mock", "swe_bench"], "type": "string" },
        "live_benchmark_supported": { "const": false },
        "model_downloads_started_by_flight_recorder": { "const": false },
        "provider_api_called_by_flight_recorder": { "const": false },
        "receipt_types": {
          "items": {
            "enum": ["hfr.external_eval_adapters.v1", "hfr.external_eval_receipt.v1"],
            "type": "string"
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "type": "array"
        },
        "requires_dependency_probe_before_live": { "const": true },
        "requires_explicit_live_opt_in": { "const": true },
        "requires_external_runner_receipt_for_live": { "const": true },
        "requires_identical_heldout_scenarios": { "const": true },
        "schema_version": { "const": "hfr.external_eval_adapter_contract.v1" }
      },
      "required": [
        "schema_version",
        "adapter_id",
        "external_adapter_id",
        "receipt_types",
        "dry_run_transport",
        "live_benchmark_supported",
        "provider_api_called_by_flight_recorder",
        "model_downloads_started_by_flight_recorder",
        "credential_values_recorded",
        "cost_incurred_usd",
        "requires_identical_heldout_scenarios",
        "requires_external_runner_receipt_for_live",
        "requires_dependency_probe_before_live",
        "requires_explicit_live_opt_in"
      ],
      "type": "object"
    },
    "check": {
      "additionalProperties": false,
      "properties": {
        "actual": { "type": "object" },
        "expected": { "type": "object" },
        "id": { "minLength": 1, "type": "string" },
        "passed": { "type": "boolean" },
        "summary": { "minLength": 1, "type": "string" }
      },
      "required": ["id", "passed", "actual", "expected", "summary"],
      "type": "object"
    },
    "dependencyStatus": {
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "commands": {
          "additionalProperties": { "type": "boolean" },
          "type": "object"
        },
        "imports": {
          "additionalProperties": { "type": "boolean" },
          "type": "object"
        }
      },
      "required": ["available", "imports", "commands"],
      "type": "object"
    },
    "sourcePlan": {
      "additionalProperties": false,
      "properties": {
        "adapter_count": { "minimum": 0, "type": ["integer", "null"] },
        "exists": { "type": "boolean" },
        "path": { "type": "string" },
        "ready": { "type": ["boolean", "null"] },
        "schema_version": { "type": ["string", "null"] },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": ["string", "null"]
        },
        "size_bytes": { "minimum": 0, "type": ["integer", "null"] }
      },
      "required": ["path", "exists", "sha256", "size_bytes", "schema_version", "ready", "adapter_count"],
      "type": "object"
    }
  }
}
